---
const pathname = new URL(Astro.request.url).pathname;
const currentPath = pathname.slice(1);
---

<div class="h-20 lg:hidden"></div>
<footer class="fixed bottom-0 left-0 w-full bg-white border-t border-gray-100 z-[100] pb-[env(safe-area-inset-bottom)] lg:hidden">
	<div class="flex justify-around items-center py-3">
		<a href="/" class={`flex flex-col items-center gap-1 w-16 text-[0.65rem] font-medium transition-colors ${currentPath === '' ? 'text-mint-500 font-bold' : 'text-gray-500 hover:text-gray-900'}`}>
			<span class={`material-symbols-outlined text-2xl ${currentPath === '' ? 'material-symbols-filled' : ''}`}>home</span>
			<span>ホーム</span>
		</a>
		<a href="/logs" class={`flex flex-col items-center gap-1 w-16 text-[0.65rem] font-medium transition-colors ${currentPath.startsWith('logs') ? 'text-mint-500 font-bold' : 'text-gray-500 hover:text-gray-900'}`}>
			<span class={`material-symbols-outlined text-2xl ${currentPath.startsWith('logs') ? 'material-symbols-filled' : ''}`}>menu_book</span>
			<span>実験ログ</span>
		</a>
		<a href="/tools" class={`flex flex-col items-center gap-1 w-16 text-[0.65rem] font-medium transition-colors ${currentPath.startsWith('tools') ? 'text-mint-500 font-bold' : 'text-gray-500 hover:text-gray-900'}`}>
			<span class={`material-symbols-outlined text-2xl ${currentPath.startsWith('tools') ? 'material-symbols-filled' : ''}`}>handyman</span>
			<span>無料ツール</span>
		</a>
		<a href="/request" class={`flex flex-col items-center gap-1 w-16 text-[0.65rem] font-medium transition-colors ${currentPath.startsWith('request') ? 'text-mint-500 font-bold' : 'text-gray-500 hover:text-gray-900'}`}>
			<span class={`material-symbols-outlined text-2xl ${currentPath.startsWith('request') ? 'material-symbols-filled' : ''}`}>mail</span>
			<span>リクエスト</span>
		</a>
	</div>
</footer>
