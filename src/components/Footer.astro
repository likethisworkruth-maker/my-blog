---
import { SITE_TITLE } from "../consts";
import { UI } from "../i18n/ja";

const pathname =
	new URL(
		Astro
			.request
			.url,
	)
		.pathname;
const currentPath =
	pathname.slice(
		1,
	);
const today =
	new Date();
---

<div
	class="h-20 lg:hidden"
>
</div>
<footer
	class="fixed bottom-0 left-0 w-full bg-white border-t border-gray-100 z-[100] pb-[env(safe-area-inset-bottom)] lg:hidden"
>
	<div
		class="flex justify-around items-center py-3"
	>
		<a
			href="/"
			class={`flex-1 flex flex-col items-center gap-1 text-[0.65rem] font-medium transition-colors ${currentPath === "" ? "text-mint-500 font-bold" : "text-gray-500 hover:text-gray-900"}`}
		>
			<span
				class={`material-symbols-outlined text-2xl ${currentPath === "" ? "material-symbols-filled" : ""}`}
				>home</span
			>
			<span
				>{
					UI
						.footerNav
						.home
				}</span
			>
		</a>

		<a
			href="/knowhow"
			class={`flex-1 flex flex-col items-center gap-1 text-[0.65rem] font-medium transition-colors ${currentPath.startsWith("knowhow") ? "text-mint-500 font-bold" : "text-gray-500 hover:text-gray-900"}`}
		>
			<span
				class={`material-symbols-outlined text-2xl ${currentPath.startsWith("knowhow") ? "material-symbols-filled" : ""}`}
				>checklist</span
			>
			<span
				>{
					UI
						.footerNav
						.knowhow
				}</span
			>
		</a>
		<a
			href="/apps"
			class={`flex-1 flex flex-col items-center gap-1 text-[0.65rem] font-medium transition-colors ${currentPath.startsWith("apps") ? "text-mint-500 font-bold" : "text-gray-500 hover:text-gray-900"}`}
		>
			<span
				class={`material-symbols-outlined text-2xl ${currentPath.startsWith("apps") ? "material-symbols-filled" : ""}`}
				>apps</span
			>
			<span
				>{
					UI
						.footerNav
						.apps
				}</span
			>
		</a>
		<a
			href="/items"
			class={`flex-1 flex flex-col items-center gap-1 text-[0.65rem] font-medium transition-colors ${currentPath.startsWith("items") ? "text-mint-500 font-bold" : "text-gray-500 hover:text-gray-900"}`}
		>
			<span
				class={`material-symbols-outlined text-2xl ${currentPath.startsWith("items") ? "material-symbols-filled" : ""}`}
				>toys_and_games</span
			>
			<span
				>{
					UI
						.footerNav
						.items
				}</span
			>
		</a>
	</div>
</footer>

<footer
	class="bg-white border-t border-gray-100 py-12 pb-28 lg:pb-12 mt-auto"
>
	<div
		class="max-w-6xl mx-auto px-6 flex flex-col md:flex-row justify-between items-center gap-6"
	>
		<div
			class="text-center md:text-left"
		>
			<div
				class="font-bold text-navy-900 text-[1.1rem] flex items-center gap-2 justify-center md:justify-start mb-2"
			>
				<span
					class="material-symbols-outlined text-mint-500"
					>edit</span
				>
				{
					SITE_TITLE
				}
			</div>
			<p
				class="text-[0.8rem] text-gray-400"
			>
				&copy;
				{
					today.getFullYear()
				}
				{
					SITE_TITLE
				}.
				{
					UI
						.common
						.copyrightPrefix
				}
			</p>
		</div>
		<div
			class="flex items-center gap-6"
		>
			<a
				href="https://www.threads.com/@likethis.work.ruth"
				target="_blank"
				rel="noopener noreferrer"
				class="text-gray-400 hover:text-black transition-colors"
				aria-label="Threads"
			>
				<svg
					xmlns="http://www.w3.org/2000/svg"
					viewBox="0 0 192 192"
					width="24"
					height="24"
					fill="currentColor"
				>
					<path
						d="M141.537 88.9883C140.71 88.5919 139.87 88.2104 139.019 87.8451C137.537 60.5382 122.616 44.905 97.5619 44.745C97.4484 44.7443 97.3355 44.7443 97.222 44.7443C82.2364 44.7443 69.7731 51.1409 62.102 62.7807L75.881 72.3109C81.6116 63.5383 90.6052 61.6848 97.2286 61.6848C97.3051 61.6848 97.3819 61.6848 97.4576 61.6855C105.707 61.7381 111.932 64.1366 115.961 68.814C118.893 72.2193 120.854 76.925 121.825 82.8638C114.511 81.6207 106.601 81.2385 98.145 81.7233C74.3247 83.0954 59.0111 96.9879 60.0396 116.292C60.5615 126.084 65.4397 134.508 73.775 140.011C80.8224 144.663 89.899 146.938 99.3323 146.423C111.79 145.74 121.563 140.987 128.381 132.296C133.559 125.696 136.834 117.143 138.28 106.366C144.217 109.949 148.617 114.664 151.047 120.332C155.179 129.967 155.42 145.8 142.501 158.708C131.182 170.016 117.561 174.908 97.0135 175.059C74.2042 174.89 56.9538 167.575 45.7381 153.317C35.2355 139.966 29.8077 120.682 29.6052 96C29.8077 71.3178 35.2355 52.0336 45.7381 38.6827C56.9538 24.4249 74.2039 17.11 97.0132 16.9405C119.988 17.1113 137.539 24.4614 149.184 38.788C154.894 45.8136 159.199 54.6488 162.037 64.9503L178.184 60.6422C174.744 47.9622 169.331 37.0357 161.965 27.974C147.036 9.60668 125.202 0.195148 97.0695 0H96.9569C68.8816 0.19477 47.2921 9.6418 32.7883 28.0793C19.8819 44.4864 13.2244 67.3157 13.0007 95.9325L13 96L13.0007 96.0675C13.2244 124.684 19.8819 147.514 32.7883 163.921C47.2921 182.358 68.8816 191.805 96.9569 192H97.0695C122.03 191.827 139.624 185.292 154.118 170.811C173.081 151.866 172.51 128.119 166.26 113.541C161.776 103.087 153.227 94.5962 141.537 88.9883ZM98.4405 129.507C88.0005 130.095 77.1544 125.409 76.6196 115.372C76.2232 107.93 81.9158 99.626 99.0812 98.0476C101.049 97.8663 102.994 97.7376 104.934 97.6514C104.464 105.641 98.9282 114.049 92.7388 115.812L97.3551 131.956C104.341 129.967 111.455 123.633 116.51 115.934C118.847 112.42 120.406 108.069 121.144 103.221C115.659 104.425 108.384 105.77 98.4405 129.507Z"
					>
					</path>
				</svg>
			</a>
			<a
				href="https://note.com/alert_weasel3202"
				target="_blank"
				rel="noopener noreferrer"
				class="text-gray-400 hover:text-[#41C9B4] transition-colors flex items-center"
				aria-label="note"
			>
				<span
					class="font-black text-[1.3rem] tracking-tighter leading-none -mt-1"
					style="font-family: system-ui, -apple-system, sans-serif;"
					>note</span
				>
			</a>
		</div>
	</div>
</footer>
