---
const problem = {
	slug: 'vaccine-schedule-sharing',
	title: '予防接種・健診の予定共有',
	questionText: '予防接種・健診の予定を、家族でどう共有する？',
	description: '予定の伝え忘れや確認漏れを減らすために、わが家で試した方法をまとめています。',
};
---

<section class="px-6 py-12 lg:py-20">
	<div class="mx-auto max-w-3xl">
		<h1 class="text-3xl font-bold text-navy-900">困りごと</h1>

		<article class="mt-8 rounded-3xl border border-gray-200 bg-white p-6 shadow-sm lg:p-8">
			<h2 class="text-xl font-bold leading-relaxed text-navy-900">{problem.questionText}</h2>
			<p class="mt-4 leading-relaxed text-gray-600 text-sm sm:text-base">{problem.description}</p>
			
			<div class="mt-6">
				<a href={'/problems/' + problem.slug + '/'} class="inline-block rounded-full bg-mint-500 hover:bg-mint-600 text-white font-bold py-3 px-8 text-sm transition-colors">試した方法を見る</a>
			</div>
		</article>
	</div>
</section>
