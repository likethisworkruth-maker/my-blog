<div class="relative shrink-0" data-google-auth>
	<button
		type="button"
		class="h-9 items-center justify-center gap-2 whitespace-nowrap rounded-md border border-gray-300 bg-white px-2.5 text-xs font-bold text-navy-900 transition-colors hover:bg-gray-50 disabled:cursor-wait disabled:opacity-60 sm:px-3 sm:text-[0.8125rem]"
		data-google-login
		aria-label="GoogleでログインしてDriveバックアップを有効にする"
		title="Googleログインと同時にDriveバックアップを有効にします"
		style="display: inline-flex;"
	>
		<svg class="h-4 w-4 shrink-0 fill-current text-[#4285f4]" viewBox="0 0 24 24" aria-hidden="true">
			<path d="M12.545 10.239v3.821h5.445c-.712 2.315-2.647 3.972-5.445 3.972-3.332 0-6.033-2.701-6.033-6.032s2.701-6.032 6.033-6.032c1.498 0 2.866.549 3.921 1.453l2.814-2.814C17.503 2.988 15.139 2 12.545 2 7.021 2 2.543 6.477 2.543 12s4.478 10 10.002 10c8.396 0 10.249-7.85 9.426-11.748l-9.426-.013Z" />
		</svg>
		<span class="hidden sm:inline" data-login-label>Googleでログイン</span>
	</button>

	<div class="relative" data-google-signed-in aria-live="polite" style="display: none;">
		<button
			type="button"
			class="flex h-10 w-10 items-center justify-center rounded-full border border-gray-200 bg-gray-100 text-gray-500 transition-colors hover:bg-gray-200 hover:text-navy-900 disabled:cursor-wait disabled:opacity-60"
			data-google-account-trigger
			aria-label="アカウントメニュー"
			aria-expanded="false"
		>
			<img
				class="h-full w-full rounded-full object-cover"
				data-google-avatar
				src=""
				alt="アカウント"
				referrerpolicy="no-referrer"
				style="display: none;"
			/>
			<span class="items-center justify-center" data-google-default-icon style="display: flex;">
				<svg class="h-[22px] w-[22px] fill-current" viewBox="0 0 24 24" aria-hidden="true">
					<path d="M12 5.9c1.16 0 2.1.94 2.1 2.1s-.94 2.1-2.1 2.1S9.9 9.16 9.9 8s.94-2.1 2.1-2.1m0 9c2.97 0 6.1 1.46 6.1 2.1v1.1H5.9V17c0-.64 3.13-2.1 6.1-2.1M12 4C9.79 4 8 5.79 8 8s1.79 4 4 4 4-1.79 4-4-1.79-4-4-4m0 9c-2.67 0-8 1.34-8 4v2c0 .55.45 1 1 1h14c.55 0 1-.45 1-1v-2c0-2.66-5.33-4-8-4" />
				</svg>
			</span>
		</button>

		<div class="absolute right-0 top-full z-50 mt-2 w-64 rounded-lg border border-gray-200 bg-white p-2 shadow-lg" data-google-account-menu style="display: none;">
			<p class="truncate border-b border-gray-100 px-3 py-2 text-xs font-bold text-navy-900" data-google-email></p>
			<button
				type="button"
				class="mt-1 flex w-full items-center gap-2 rounded-md px-3 py-2 text-left text-sm font-medium text-gray-600 transition-colors hover:bg-gray-100 hover:text-navy-900 disabled:cursor-wait disabled:opacity-60"
				data-google-logout
			>
				<svg class="h-5 w-5 fill-current" viewBox="0 0 24 24" aria-hidden="true">
					<path d="m17 7-1.41 1.41L18.17 11H8v2h10.17l-2.58 2.58L17 17l5-5zM4 5h8V3H4c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h8v-2H4z" />
				</svg>
				ログアウト
			</button>
		</div>
	</div>

	<p class="absolute right-0 top-full z-50 mt-2 hidden w-64 rounded-lg bg-red-700 px-3 py-2 text-xs leading-relaxed text-white shadow-lg" data-google-auth-error role="status"></p>
</div>

<script>
	import { getGoogleUser, signInWithGoogle, signOutGoogleUser } from '../scripts/google-auth';
	import { getSupabaseClient } from '../scripts/supabase-client';

	function initGoogleAuthButtons() {
		document.querySelectorAll<HTMLElement>('[data-google-auth]').forEach((root) => {
			if (root.dataset.initialized) return;
			root.dataset.initialized = 'true';

			const loginButton = root.querySelector<HTMLButtonElement>('[data-google-login]');
			const logoutButton = root.querySelector<HTMLButtonElement>('[data-google-logout]');
			const signedIn = root.querySelector<HTMLElement>('[data-google-signed-in]');
			const email = root.querySelector<HTMLElement>('[data-google-email]');
			const loginLabel = root.querySelector<HTMLElement>('[data-login-label]');
			const errorMessage = root.querySelector<HTMLElement>('[data-google-auth-error]');
			const accountTrigger = root.querySelector<HTMLButtonElement>('[data-google-account-trigger]');
			const accountMenu = root.querySelector<HTMLElement>('[data-google-account-menu]');
			const avatar = root.querySelector<HTMLImageElement>('[data-google-avatar]');
			const defaultIcon = root.querySelector<HTMLElement>('[data-google-default-icon]');

			const showDefaultIcon = () => {
				if (avatar) {
					avatar.style.display = 'none';
					avatar.removeAttribute('src');
				}
				if (defaultIcon) defaultIcon.style.display = 'flex';
			};

			avatar?.addEventListener('error', showDefaultIcon);

			const setAccountMenuOpen = (open: boolean) => {
				if (accountMenu) accountMenu.style.display = open ? 'block' : 'none';
				accountTrigger?.setAttribute('aria-expanded', String(open));
			};

			const showError = (message = '') => {
				if (!errorMessage) return;
				errorMessage.textContent = message;
				errorMessage.classList.toggle('hidden', !message);
			};

			const setBusy = (busy: boolean) => {
				if (loginButton) loginButton.disabled = busy;
				if (logoutButton) logoutButton.disabled = busy;
				if (accountTrigger) accountTrigger.disabled = busy;
				if (loginLabel) loginLabel.textContent = busy ? '処理中…' : 'Googleでログイン';
			};

			const renderUser = (user: Awaited<ReturnType<typeof getGoogleUser>>) => {
				if (loginButton) loginButton.style.display = user ? 'none' : 'inline-flex';
				if (signedIn) signedIn.style.display = user ? 'flex' : 'none';
				if (email) email.textContent = user?.email ?? 'ログイン中';
				if (signedIn) signedIn.title = user?.email ?? 'Googleアカウントでログイン中';

				const metadata = user?.user_metadata;
				const avatarUrl = metadata?.avatar_url ?? metadata?.picture;
				if (avatar && typeof avatarUrl === 'string' && avatarUrl.startsWith('https://')) {
					avatar.src = avatarUrl;
					avatar.alt = user?.email ? `${user.email}のプロフィール画像` : 'Googleプロフィール画像';
					avatar.style.display = 'block';
					if (defaultIcon) defaultIcon.style.display = 'none';
				} else {
					showDefaultIcon();
				}

				if (!user) setAccountMenuOpen(false);
			};

			accountTrigger?.addEventListener('click', () => {
				setAccountMenuOpen(accountMenu?.style.display !== 'block');
			});

			const handleOutsideClick = (event: MouseEvent) => {
				if (!root.contains(event.target as Node)) setAccountMenuOpen(false);
			};
			const handleEscape = (event: KeyboardEvent) => {
				if (event.key === 'Escape') setAccountMenuOpen(false);
			};
			document.addEventListener('click', handleOutsideClick);
			document.addEventListener('keydown', handleEscape);

			loginButton?.addEventListener('click', async () => {
				setBusy(true);
				showError();
				try {
					await signInWithGoogle(window.location.href);
				} catch (error) {
					console.error(error);
					showError(error instanceof Error ? error.message : 'Googleログインを開始できませんでした。');
					setBusy(false);
				}
			});

			logoutButton?.addEventListener('click', async () => {
				setBusy(true);
				showError();
				try {
					await signOutGoogleUser();
					setAccountMenuOpen(false);
					renderUser(null);
				} catch (error) {
					console.error(error);
					showError('ログアウトできませんでした。時間をおいて再度お試しください。');
				} finally {
					setBusy(false);
				}
			});

			const supabase = getSupabaseClient();
			if (!supabase) {
				document.removeEventListener('click', handleOutsideClick);
				document.removeEventListener('keydown', handleEscape);
				if (loginButton) {
					loginButton.disabled = true;
					loginButton.title = 'Googleログインは現在利用できません';
				}
				return;
			}

			const { data: authListener } = supabase.auth.onAuthStateChange((_event, session) => {
				renderUser(session?.user ?? null);
				setBusy(false);
			});

			const cleanup = () => {
				authListener.subscription.unsubscribe();
				document.removeEventListener('click', handleOutsideClick);
				document.removeEventListener('keydown', handleEscape);
				document.removeEventListener('astro:before-swap', cleanup);
			};
			document.addEventListener('astro:before-swap', cleanup);

			void getGoogleUser()
				.then(renderUser)
				.catch((error) => {
					console.error(error);
					showError('ログイン状態を確認できませんでした。');
				})
				.finally(() => setBusy(false));
		});
	}

	document.addEventListener('DOMContentLoaded', initGoogleAuthButtons);
	document.addEventListener('astro:page-load', initGoogleAuthButtons);
</script>
