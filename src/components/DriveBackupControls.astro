<section data-drive-backup class="mt-8 border-t border-white/10 pt-6">
	<div class="flex items-start justify-between gap-4">
		<div>
			<h2 class="text-sm font-bold text-white">Google Driveバックアップ</h2>
			<p class="mt-1 text-xs leading-5 text-gray-400">Googleログイン時に許可したアカウントのアプリ専用領域へ、自動でバックアップします。</p>
		</div>
		<span class="material-symbols-outlined text-mint-300" aria-hidden="true">cloud_upload</span>
	</div>

	<p data-drive-status class="mt-4 text-xs text-gray-300" aria-live="polite">
		GoogleログインするとDriveバックアップが有効になります。
	</p>

	<div class="mt-4 flex flex-wrap gap-2">
		<button type="button" data-drive-now disabled class="rounded-full bg-white px-4 py-2 text-xs font-bold text-navy-900 hover:bg-gray-100 disabled:cursor-not-allowed disabled:opacity-40">今すぐバックアップ</button>
		<button type="button" data-drive-reauth class="hidden rounded-full border border-white/20 px-4 py-2 text-xs font-bold text-white hover:bg-white/10">Googleへ再ログイン</button>
	</div>

	<div data-drive-choice class="mt-5 hidden rounded-xl border border-amber-400/20 bg-amber-400/10 p-4">
		<p data-drive-choice-message class="text-xs leading-5 text-amber-100"></p>
		<div class="mt-3 flex flex-wrap gap-2">
			<button type="button" data-use-local class="rounded-full bg-white px-4 py-2 text-xs font-bold text-navy-900">この端末を使う</button>
			<button type="button" data-use-drive class="rounded-full border border-white/30 px-4 py-2 text-xs font-bold text-white">Driveを復元する</button>
			<button type="button" data-keep-both class="rounded-full border border-white/30 px-4 py-2 text-xs font-bold text-white">両方を残す</button>
		</div>
	</div>

	<p class="mt-4 text-[0.7rem] leading-5 text-gray-500">通常のDriveファイルは読み取りません。Driveでエラーが発生しても端末への保存は継続します。</p>
</section>

<script>
	import { getGoogleUser, signInWithGoogle } from '../scripts/google-auth';
	import {
		forgetGoogleDriveAuthorization,
		getGoogleDriveAuthorization,
	} from '../scripts/drive-authorization';
	import {
		type BackupSituation,
		getLastDriveBackupAt,
		inspectDriveBackup,
		restoreDriveBackup,
		uploadDriveBackup,
	} from '../scripts/drive-backup';
	import { getSupabaseClient } from '../scripts/supabase-client';

	function initDriveBackupControls() {
		document.querySelectorAll<HTMLElement>('[data-drive-backup]').forEach((root) => {
			if (root.dataset.initialized) return;
			root.dataset.initialized = 'true';
			void initializeDriveControls(root);
		});
	}

	async function initializeDriveControls(root: HTMLElement) {
		const status = root.querySelector<HTMLElement>('[data-drive-status]');
		const backupNow = root.querySelector<HTMLButtonElement>('[data-drive-now]');
		const reauth = root.querySelector<HTMLButtonElement>('[data-drive-reauth]');
		const choice = root.querySelector<HTMLElement>('[data-drive-choice]');
		const choiceMessage = root.querySelector<HTMLElement>('[data-drive-choice-message]');
		const keepBoth = root.querySelector<HTMLButtonElement>('[data-keep-both]');
		let situation: BackupSituation | null = null;
		let backupTimer: ReturnType<typeof setTimeout> | undefined;
		let busy = false;

		const setStatus = (message: string, failed = false) => {
			if (!status) return;
			status.textContent = message;
			status.classList.toggle('text-red-300', failed);
			status.classList.toggle('text-gray-300', !failed);
		};
		const setAvailability = (available: boolean, needsReauth = false) => {
			if (backupNow) backupNow.disabled = !available;
			reauth?.classList.toggle('hidden', !needsReauth);
		};
		const renderLastBackup = async () => {
			const lastBackup = await getLastDriveBackupAt();
			if (!lastBackup) {
				setStatus('Googleログイン済みです。端末の更新後にDriveへ自動バックアップします。');
				return;
			}
			const time = new Date(lastBackup).toLocaleTimeString('ja-JP', {
				hour: '2-digit',
				minute: '2-digit',
			});
			setStatus('Driveにバックアップ済み ' + time);
		};
		const showChoice = (next: BackupSituation) => {
			situation = next;
			choice?.classList.remove('hidden');
			const conflict = next.decision === 'conflict';
			if (choiceMessage) {
				choiceMessage.textContent = conflict
					? 'この端末とDriveの両方が更新されています。自動では上書きしません。残す内容を選んでください。'
					: 'Driveに新しいバックアップがあります。復元するか、この端末の内容で上書きするか選んでください。';
			}
			keepBoth?.classList.toggle('hidden', !conflict);
			setStatus(conflict ? 'バックアップの競合があります。' : 'Driveに復元できるデータがあります。');
		};
		const runBackup = async () => {
			if (busy) return;
			busy = true;
			setAvailability(false);
			setStatus('Driveを確認しています…');
			try {
				const { accessToken } = await getGoogleDriveAuthorization();
				const next = await inspectDriveBackup(accessToken);
				if (next.decision === 'remote-newer' || next.decision === 'conflict') {
					showChoice(next);
				} else if (next.decision === 'empty') {
					setStatus('バックアップする端末データはまだありません。');
				} else if (next.decision === 'same') {
					choice?.classList.add('hidden');
					await renderLastBackup();
				} else {
					await uploadDriveBackup(accessToken, next.file);
					choice?.classList.add('hidden');
					await renderLastBackup();
				}
				setAvailability(true);
			} catch (error) {
				const message = error instanceof Error ? error.message : 'Driveバックアップに失敗しました。';
				const needsReauth = message.includes('再ログイン') || message.includes('一致しません');
				const needsLogin = message.includes('先にヘッダーからGoogleへログイン');
				if (needsReauth) forgetGoogleDriveAuthorization();
				setAvailability(!needsReauth && !needsLogin, needsReauth);
				setStatus(message, true);
			} finally {
				busy = false;
			}
		};
		const refreshAuthorization = async (startBackup = false) => {
			try {
				const user = await getGoogleUser();
				if (!user) {
					forgetGoogleDriveAuthorization();
					setAvailability(false);
					setStatus('GoogleログインするとDriveバックアップが有効になります。');
					return;
				}
				await getGoogleDriveAuthorization();
				setAvailability(true);
				if (startBackup) await runBackup();
				else await renderLastBackup();
			} catch (error) {
				const message = error instanceof Error ? error.message : 'Googleへ再ログインしてください。';
				const needsLogin = message.includes('先にヘッダーからGoogleへログイン');
				setAvailability(false, !needsLogin);
				setStatus(
					message,
					true,
				);
			}
		};

		backupNow?.addEventListener('click', () => void runBackup());
		reauth?.addEventListener('click', () => {
			setStatus('Googleログイン画面へ移動しています…');
			void signInWithGoogle(window.location.href).catch((error) => {
				setStatus(error instanceof Error ? error.message : 'Googleログインを開始できませんでした。', true);
			});
		});
		const resolveChoice = async (mode: 'local' | 'drive' | 'both') => {
			if (!situation || busy) return;
			busy = true;
			setAvailability(false);
			setStatus('選択した内容を反映しています…');
			try {
				const { accessToken } = await getGoogleDriveAuthorization();
				if (mode === 'local') await uploadDriveBackup(accessToken, situation.file);
				if (mode === 'drive') await restoreDriveBackup(accessToken, situation, 'replace');
				if (mode === 'both') await restoreDriveBackup(accessToken, situation, 'merge');
				choice?.classList.add('hidden');
				if (mode === 'drive') setStatus('Driveのバックアップをこの端末へ復元しました。');
				else await renderLastBackup();
				setAvailability(true);
			} catch (error) {
				const message = error instanceof Error ? error.message : '選択した内容を反映できませんでした。';
				const needsReauth = message.includes('再ログイン') || message.includes('一致しません');
				const needsLogin = message.includes('先にヘッダーからGoogleへログイン');
				if (needsReauth) forgetGoogleDriveAuthorization();
				setAvailability(!needsReauth && !needsLogin, needsReauth);
				setStatus(message, true);
			} finally {
				busy = false;
			}
		};
		root.querySelector<HTMLButtonElement>('[data-use-local]')?.addEventListener('click', () => void resolveChoice('local'));
		root.querySelector<HTMLButtonElement>('[data-use-drive]')?.addEventListener('click', () => void resolveChoice('drive'));
		keepBoth?.addEventListener('click', () => void resolveChoice('both'));

		const scheduleBackup = () => {
			void getGoogleDriveAuthorization().then(() => {
				setStatus('バックアップ待ち');
				if (backupTimer) clearTimeout(backupTimer);
				backupTimer = setTimeout(() => void runBackup(), 20_000);
			}).catch(() => {
				// 未ログインまたは再ログイン待ちでは、端末保存だけを継続する。
			});
		};
		const handleVisibilityChange = () => {
			if (document.visibilityState === 'visible') scheduleBackup();
		};
		window.addEventListener('checklist-runs-changed', scheduleBackup);
		window.addEventListener('online', scheduleBackup);
		document.addEventListener('visibilitychange', handleVisibilityChange);

		const supabase = getSupabaseClient();
		const authSubscription = supabase
			? supabase.auth.onAuthStateChange((event) => {
				if (event === 'SIGNED_OUT') {
					forgetGoogleDriveAuthorization();
					setAvailability(false);
					setStatus('GoogleログインするとDriveバックアップが有効になります。');
					return;
				}
				if (event === 'SIGNED_IN') {
					window.setTimeout(() => void refreshAuthorization(true), 0);
				}
			}).data.subscription
			: undefined;

		const cleanup = () => {
			if (backupTimer) clearTimeout(backupTimer);
			authSubscription?.unsubscribe();
			window.removeEventListener('checklist-runs-changed', scheduleBackup);
			window.removeEventListener('online', scheduleBackup);
			document.removeEventListener('visibilitychange', handleVisibilityChange);
			document.removeEventListener('astro:before-swap', cleanup);
		};
		document.addEventListener('astro:before-swap', cleanup);

		await refreshAuthorization(true);
	}

	document.addEventListener('DOMContentLoaded', initDriveBackupControls);
	document.addEventListener('astro:page-load', initDriveBackupControls);
</script>
