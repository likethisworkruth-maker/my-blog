---
interface Props {
	slug: string | null;
	variant?: 'large' | 'compact' | 'footer' | 'reels';
}

const { slug, variant = 'large' } = Astro.props;

// Disabled state for pages without a slug
const disabledAttr = { disabled: true };
---

{variant === 'large' && (
	<button
		type="button"
		data-slug={slug}
		aria-pressed="false"
		aria-label="いいね"
		class="like-btn group relative flex items-center gap-2 transition-all active:scale-95 disabled:opacity-80 disabled:cursor-not-allowed"
		{...disabledAttr}
	>
		<div class="relative flex h-8 w-8 items-center justify-center">
			<span class="material-symbols-outlined icon-empty text-gray-400 group-hover:text-pink-400 transition-colors text-[1.4rem]" aria-hidden="true">favorite</span>
			<span class="material-symbols-outlined icon-filled text-pink-500 absolute inset-0 m-auto h-[1.4rem] w-[1.4rem] opacity-0 transition-opacity text-[1.4rem] leading-none" style="font-variation-settings: 'FILL' 1;" aria-hidden="true">favorite</span>
		</div>
		<span class="like-count font-bold text-gray-500 group-hover:text-pink-500 group-[.liked]:text-pink-500 transition-colors text-lg">...</span>
	</button>
)}

{variant === 'compact' && (
	<button
		type="button"
		data-slug={slug}
		aria-pressed="false"
		aria-label="いいね"
		class="like-btn group relative flex items-center gap-1.5 transition-all active:scale-95 disabled:opacity-80 disabled:cursor-not-allowed"
		{...disabledAttr}
	>
		<div class="relative flex items-center justify-center">
			<span class="material-symbols-outlined icon-empty text-gray-400 group-hover:text-pink-400 transition-colors text-[1.2rem]" aria-hidden="true">favorite</span>
			<span class="material-symbols-outlined icon-filled text-pink-500 absolute inset-0 opacity-0 transition-opacity text-[1.2rem]" style="font-variation-settings: 'FILL' 1;" aria-hidden="true">favorite</span>
		</div>
		<span class="like-count font-bold text-gray-500 group-hover:text-pink-500 transition-colors text-[0.9rem]">...</span>
	</button>
)}

{variant === 'footer' && (
	<button
		type="button"
		data-slug={slug}
		aria-pressed="false"
		aria-label="いいね"
		class="like-btn group relative flex-1 flex flex-col items-center gap-1 text-[0.65rem] font-medium text-gray-500 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
		{...disabledAttr}
	>
		<div class="relative flex items-center justify-center">
			<span class="material-symbols-outlined icon-empty text-2xl group-hover:text-pink-400 transition-colors" aria-hidden="true">favorite</span>
			<span class="material-symbols-outlined icon-filled text-pink-500 absolute inset-0 opacity-0 transition-opacity text-2xl" style="font-variation-settings: 'FILL' 1;" aria-hidden="true">favorite</span>
		</div>
		<span class="like-count-footer">いいね (<span class="like-count">...</span>)</span>
	</button>
)}

{variant === 'reels' && (
	<button
		type="button"
		data-slug={slug}
		aria-pressed="false"
		aria-label="いいね"
		class="like-btn group relative flex flex-col items-center gap-1 transition-all active:scale-95 disabled:opacity-80 disabled:cursor-not-allowed"
		{...disabledAttr}
	>
		<div class="relative flex items-center justify-center">
			<span class="material-symbols-outlined icon-empty text-white group-hover:text-pink-400 transition-colors text-[2rem] drop-shadow-[0_2px_5px_rgba(0,0,0,0.8)]" aria-hidden="true">favorite</span>
			<span class="material-symbols-outlined icon-filled text-pink-500 absolute inset-0 opacity-0 transition-opacity text-[2rem] drop-shadow-[0_2px_5px_rgba(0,0,0,0.8)]" style="font-variation-settings: 'FILL' 1;" aria-hidden="true">favorite</span>
		</div>
		<span class="like-count font-medium text-white group-hover:text-pink-400 transition-colors text-[0.8rem] drop-shadow-[0_2px_5px_rgba(0,0,0,0.8)]">...</span>
	</button>
)}

<script>
	import {
		getCurrentArticleLikeState,
		notifyArticleLikeChanged,
		setArticleLikeState,
		type ArticleLikeState,
	} from '../scripts/article-likes';
	import { getSupabaseClient } from '../scripts/supabase-client';

	const showLikeError = (message: string) => {
		const existing = document.querySelector<HTMLElement>('[data-like-error-toast]');
		existing?.remove();
		const toast = document.createElement('p');
		toast.dataset.likeErrorToast = 'true';
		toast.setAttribute('role', 'status');
		toast.className = 'fixed bottom-20 left-1/2 z-[100] max-w-[calc(100vw-2rem)] -translate-x-1/2 rounded-lg bg-red-700 px-4 py-3 text-sm text-white shadow-lg';
		toast.textContent = message;
		document.body.appendChild(toast);
		window.setTimeout(() => toast.remove(), 5_000);
	};

	const initLikes = () => {
		const buttonsBySlug: Record<string, HTMLButtonElement[]> = {};
		document.querySelectorAll<HTMLButtonElement>('.like-btn').forEach((btn) => {
			if (btn.hasAttribute('data-initialized')) return;
			btn.setAttribute('data-initialized', 'true');
			const slug = btn.getAttribute('data-slug');
			if (!slug) return;
			if (!buttonsBySlug[slug]) buttonsBySlug[slug] = [];
			buttonsBySlug[slug].push(btn);
		});

		Object.entries(buttonsBySlug).forEach(([slug, buttons]) => {
			let state: ArticleLikeState | null = null;
			let busy = false;

			const updateCount = (count: number) => {
				buttons.forEach((button) => {
					const countSpan = button.querySelector('.like-count');
					if (countSpan) countSpan.textContent = String(count);
				});
			};

			const setLikedUi = (isLiked: boolean) => {
				buttons.forEach((button) => {
					const countSpan = button.querySelector('.like-count');
					const iconEmpty = button.querySelector('.icon-empty');
					const iconFilled = button.querySelector('.icon-filled');
					button.setAttribute('aria-pressed', String(isLiked));
					button.setAttribute('aria-label', isLiked ? 'いいねを取り消す' : 'いいね');
					button.title = isLiked ? 'いいねを取り消す' : 'いいね';
					if (isLiked) {
						button.classList.add('liked', 'text-pink-500');
						if (button.classList.contains('bg-white')) {
							button.classList.add('border-pink-200', 'bg-pink-50');
						}
						iconEmpty?.classList.add('opacity-0');
						iconFilled?.classList.remove('opacity-0');
						if (iconEmpty?.classList.contains('text-white')) {
							countSpan?.classList.remove('text-white');
							countSpan?.classList.add('text-pink-500');
						} else {
							countSpan?.classList.remove('text-gray-400', 'text-gray-500');
							countSpan?.classList.add('text-pink-500');
						}
					} else {
						button.classList.remove('liked', 'border-pink-200', 'bg-pink-50', 'text-pink-500');
						iconEmpty?.classList.remove('opacity-0');
						iconFilled?.classList.add('opacity-0');
						if (iconEmpty?.classList.contains('text-white')) {
							countSpan?.classList.remove('text-pink-500');
							countSpan?.classList.add('text-white');
						} else {
							countSpan?.classList.remove('text-pink-500');
						}
					}
				});
			};

			const setLoading = (loading: boolean) => {
				busy = loading;
				buttons.forEach((button) => {
					button.disabled = loading || !state;
					button.toggleAttribute('data-loading', loading);
				});
			};

			const render = (next: ArticleLikeState) => {
				state = next;
				updateCount(next.likeCount);
				setLikedUi(next.liked);
			};

			const refresh = async () => {
				setLoading(true);
				try {
					render(await getCurrentArticleLikeState(slug));
				} catch (error) {
					console.error('Error fetching like state:', error);
					updateCount(0);
					setLikedUi(false);
					showLikeError('いいねの状態を確認できませんでした。');
				} finally {
					setLoading(false);
				}
			};

			buttons.forEach((button) => {
				button.addEventListener('click', async () => {
					if (busy || !state) return;
					setLoading(true);
					try {
						const next = await setArticleLikeState(slug, !state.liked);
						render(next);
						notifyArticleLikeChanged(next);
						if (next.liked) {
							button.classList.add('scale-110');
							window.setTimeout(() => button.classList.remove('scale-110'), 150);
						}
					} catch (error) {
						console.error('Error updating like:', error);
						showLikeError('いいねを更新できませんでした。時間をおいて再度お試しください。');
					} finally {
						setLoading(false);
					}
				});
			});

			const supabase = getSupabaseClient();
			const authSubscription = supabase?.auth.onAuthStateChange(() => {
				window.setTimeout(() => void refresh(), 0);
			}).data.subscription;
			const cleanup = () => {
				authSubscription?.unsubscribe();
				document.removeEventListener('astro:before-swap', cleanup);
			};
			document.addEventListener('astro:before-swap', cleanup);
			void refresh();
		});
	};

	document.addEventListener('DOMContentLoaded', initLikes);
	document.addEventListener('astro:page-load', initLikes);
</script>
