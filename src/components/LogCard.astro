---
import type { CollectionEntry } from "astro:content";
import { UI } from "../i18n/ja";

interface Props {
	log: CollectionEntry<"logs">;
}

const { log } = Astro.props;
const likeSlug = `logs/${log.id}`;
---

<a
	href={`/logs/${log.id}/`}
	class="log-card flex flex-col bg-white border-b border-gray-100 md:border md:border-gray-200 md:rounded-2xl transition-colors hover:bg-gray-50 group overflow-hidden"
	data-categories={(log.data.categories || []).join(",")}
	data-age={log.data.childAgeMonths ?? "none"}
	data-lognumber={log.data.logNumber}
	data-id={log.id}
>
	<div class="flex flex-row-reverse sm:flex-col">
		<div class="w-[120px] sm:w-full h-auto aspect-video bg-gray-100 shrink-0 relative flex items-center justify-center border-l sm:border-l-0 sm:border-b border-gray-100 overflow-hidden">
			{log.data.coverImage ? (
				<img src={log.data.coverImage} alt={log.data.title} class="w-full h-full object-cover" />
			) : (
				<span class="material-symbols-outlined text-gray-300 text-4xl sm:text-5xl" aria-hidden="true">image</span>
			)}
		</div>

		<div class="flex-grow p-3 sm:p-5 sm:pb-0 flex flex-col justify-center">
			<div class="mb-1.5 flex items-center gap-1.5 flex-wrap">
				<span class="text-[0.75rem] font-bold text-gray-500">{log.data.pubDate.toLocaleDateString("ja-JP")}</span>
				{log.data.childAgeMonths !== undefined && (
					<span class="bg-gray-100 text-gray-600 px-1.5 py-0.5 rounded text-[0.65rem] font-bold shrink-0">
						生後{log.data.childAgeMonths}ヶ月
					</span>
				)}
				<span class="inline-flex items-center gap-1.5 text-[0.75rem] font-bold text-gray-500" title="いいね数" data-log-like-display={likeSlug}>
					<span class="log-like-circle relative h-5 w-5 shrink-0">
						<span class="log-like-icon-empty absolute inset-0 flex items-center justify-center transition-opacity">
							<span class="material-symbols-outlined text-[1.2rem] leading-none text-gray-400" aria-hidden="true">favorite</span>
						</span>
						<span class="log-like-icon-filled absolute inset-0 flex items-center justify-center opacity-0 transition-opacity">
							<span class="material-symbols-outlined text-[1.2rem] leading-none text-pink-500" style="font-variation-settings: 'FILL' 1;" aria-hidden="true">favorite</span>
						</span>
					</span>
					<span data-log-like-slug={likeSlug}>0</span>
				</span>
			</div>
			<h3 class="text-[0.95rem] sm:text-[1.1rem] lg:text-[1.15rem] font-bold leading-snug text-navy-900 m-0">{log.data.title}</h3>
		</div>
	</div>

	<div class="p-3 pt-1.5 sm:p-5 sm:pt-4 flex flex-col gap-1.5 relative flex-grow">
		<div class="flex flex-col gap-1.5">
			{log.data.createdTool && (
				<div class="flex items-center gap-2 text-[0.8rem]">
					<span class="bg-mint-50 text-mint-500 px-1.5 py-0.5 rounded text-[0.65rem] font-bold shrink-0">{UI.common.createdToolBadge}</span>
					<span class="text-gray-600 leading-tight">{log.data.createdTool}</span>
				</div>
			)}
			{log.data.result && (
				<div class="flex items-center gap-2 text-[0.8rem]">
					<span class="bg-mint-50 text-mint-500 px-1.5 py-0.5 rounded text-[0.65rem] font-bold shrink-0">{UI.common.resultBadge}</span>
					<span class="text-gray-600 leading-tight">{log.data.result}</span>
				</div>
			)}
		</div>
	</div>
</a>

<script>
	import { createClient } from "@supabase/supabase-js";

	const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
	const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

	const initLogLikeCounts = async () => {
		const countElements = Array.from(
			document.querySelectorAll<HTMLElement>("[data-log-like-slug]:not([data-like-count-initialized])"),
		);
		if (countElements.length === 0) return;

		const elementsBySlug = new Map<string, HTMLElement[]>();
		countElements.forEach((element) => {
			element.dataset.likeCountInitialized = "true";
			const slug = element.dataset.logLikeSlug;
			if (!slug) return;

			if (localStorage.getItem(`liked:${encodeURIComponent(slug)}`)) {
				const display = element.closest<HTMLElement>("[data-log-like-display]");
				display?.querySelector(".log-like-icon-empty")?.classList.add("opacity-0");
				display?.querySelector(".log-like-icon-filled")?.classList.remove("opacity-0");
				element.classList.add("text-pink-500");
			}

			const elements = elementsBySlug.get(slug) ?? [];
			elements.push(element);
			elementsBySlug.set(slug, elements);
		});

		if (!supabaseUrl || !supabaseAnonKey || elementsBySlug.size === 0) return;

		if (!(window as any).__supabaseClient) {
			(window as any).__supabaseClient = createClient(supabaseUrl, supabaseAnonKey);
		}
		const supabase = (window as any).__supabaseClient;

		try {
			const slugs = Array.from(elementsBySlug.keys());
			const { data, error } = await supabase
				.from("likes")
				.select("slug, like_count")
				.in("slug", slugs);
			if (error) throw error;

			const counts = new Map<string, number>();
			(data ?? []).forEach((row: { slug: string; like_count: number }) => {
				counts.set(row.slug, row.like_count);
			});
			elementsBySlug.forEach((elements, slug) => {
				const count = String(counts.get(slug) ?? 0);
				elements.forEach((element) => {
					element.textContent = count;
				});
			});
		} catch (error) {
			console.error("Error fetching log like counts:", error);
		}
	};

	const runLogLikeCounts = () => void initLogLikeCounts();
	if (document.readyState === "loading") {
		document.addEventListener("DOMContentLoaded", runLogLikeCounts, { once: true });
	} else {
		runLogLikeCounts();
	}
	document.addEventListener("astro:page-load", runLogLikeCounts);
</script>
