	#caption-content a, .content-area a { color: #60a5fa; text-decoration: underline; }

    /* Keep the surrounding UI fixed and animate only the media region. */
    ::view-transition-old(root),
    ::view-transition-new(root) {
		animation: none;
	}

	::view-transition-group(knowhow-media) {
		animation-duration: 0.45s;
		animation-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
