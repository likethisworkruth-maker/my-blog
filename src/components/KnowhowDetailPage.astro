    html[data-scroll-direction="next"]::view-transition-old(knowhow-media) {
        animation: slideUpOut 0.45s cubic-bezier(0.4, 0, 0.2, 1) both;
    }
    html[data-scroll-direction="next"]::view-transition-new(knowhow-media) {
        animation: slideUpIn 0.45s cubic-bezier(0.4, 0, 0.2, 1) both;
    }

    html[data-scroll-direction="prev"]::view-transition-old(knowhow-media) {
        animation: slideDownOut 0.45s cubic-bezier(0.4, 0, 0.2, 1) both;
