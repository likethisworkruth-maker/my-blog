---
import type { ChecklistTemplate } from '../scripts/checklist-state';

interface Props {
	checklist: ChecklistTemplate;
}

const { checklist } = Astro.props;
const templateJson = JSON.stringify(checklist).replace(/</g, '\\u003c');
---

<section
	class="checklist-runner h-full w-full min-w-0 overflow-y-auto bg-[#262626] p-4 text-gray-100 sm:p-6"
	data-checklist-id={checklist.checklistId}
>
	<script is:inline type="application/json" data-checklist-template set:html={templateJson}></script>

	<div data-checklist-active>
		<ul data-checklist-items class="space-y-2"></ul>

		<p data-run-message class="mt-3 min-h-5 text-center text-sm text-gray-300" aria-live="polite"></p>

		<div class="mt-8 border-t border-white/10 pt-6">
			<div data-auth-signed-out>
				<button type="button" data-google-save class="flex w-full items-center justify-center gap-2 rounded-full border border-white/20 px-5 py-3 font-bold text-white hover:bg-white/10 active:scale-[0.99]">
					<span class="material-symbols-outlined" aria-hidden="true">cloud_upload</span>
					Googleアカウントへ保存
				</button>
				<p class="mt-2 text-center text-xs leading-relaxed text-gray-400">別の端末でも続きから確認できます。</p>
			</div>
			<div data-auth-signed-in class="hidden rounded-xl bg-white/5 p-4">
				<div class="flex items-center justify-between gap-3">
					<div class="min-w-0">
						<p class="text-sm font-bold text-white">Googleへ保存中</p>
						<p data-auth-email class="truncate text-xs text-gray-400"></p>
					</div>
					<span class="material-symbols-outlined text-mint-300" aria-hidden="true">cloud_done</span>
				</div>
				<button type="button" data-sign-out class="mt-3 text-xs text-gray-400 underline hover:text-white">ログアウト</button>
			</div>
		</div>

	</div>
</section>

<script>
	import {
		type ChecklistRunItem,
		type ChecklistTemplate,
		createChecklistRun,
		getActiveChecklistRun,
		saveChecklistRun,
	} from '../scripts/checklist-state';
	import {
		getChecklistUser,
		hydrateChecklistRunsFromSupabase,
		signInToSaveChecklist,
		signOutChecklistUser,
		syncAllLocalChecklistRuns,
		syncChecklistRun,
	} from '../scripts/checklist-sync';
	import { getSupabaseClient } from '../scripts/supabase-client';

	function initChecklistRunners() {
		document.querySelectorAll<HTMLElement>('.checklist-runner').forEach((root) => {
			if (root.dataset.initialized) return;
			root.dataset.initialized = 'true';

			const source = root.querySelector<HTMLScriptElement>('[data-checklist-template]');
			if (!source?.textContent) return;
			const template = JSON.parse(source.textContent) as ChecklistTemplate;
			const itemsContainer = root.querySelector<HTMLElement>('[data-checklist-items]');
			const runMessage = root.querySelector<HTMLElement>('[data-run-message]');
			let run = getActiveChecklistRun(template.checklistId);
			let draftRun = run ?? createChecklistRun(template);
			let currentUser: Awaited<ReturnType<typeof getChecklistUser>> = null;
			let cloudTimer: ReturnType<typeof setTimeout> | undefined;

			const setMessage = (message: string, isError = false) => {
				if (!runMessage) return;
				runMessage.textContent = message;
				runMessage.classList.toggle('text-red-300', isError);
				runMessage.classList.toggle('text-gray-300', !isError);
			};

			const scheduleCloudSync = () => {
				if (!run || !currentUser) return;
				if (cloudTimer) clearTimeout(cloudTimer);
				cloudTimer = setTimeout(async () => {
					if (!run || !currentUser) return;
					try {
						await syncChecklistRun(run, currentUser);
					} catch (error) {
						console.error(error);
						setMessage('Googleと同期できませんでした。再接続後に保存します。', true);
					}
				}, 700);
			};

			const persist = (shouldRender = true) => {
				if (!run) return;
				run.updatedAt = new Date().toISOString();
				saveChecklistRun(run);
				scheduleCloudSync();
				if (shouldRender) render();
			};

			const markRunEdited = () => {
				if (!run) return;
				if (run.status !== 'in_progress') {
					run.status = 'in_progress';
					run.preparedAt = undefined;
					run.reviewStartedAt = undefined;
					run.completedAt = undefined;
					run.items.forEach((item) => { item.outcome = undefined; });
				}
			};

			const renderItem = (item: ChecklistRunItem) => {
				const row = document.createElement('li');
				row.className = 'rounded-xl border border-white/10 bg-white/5 p-3';

				const label = document.createElement('label');
				label.className = 'flex cursor-pointer items-start gap-3';
				const checkbox = document.createElement('input');
				checkbox.type = 'checkbox';
				checkbox.checked = item.checked;
				checkbox.className = 'mt-0.5 h-5 w-5 shrink-0 accent-emerald-400';
				checkbox.setAttribute('aria-label', item.label);
				checkbox.addEventListener('change', () => {
					if (!run) run = draftRun;
					item.checked = checkbox.checked;
					item.checkedAt = item.checked ? new Date().toISOString() : undefined;
					markRunEdited();
					persist();
				});

				const text = document.createElement('span');
				text.className = 'min-w-0 flex-1 text-sm font-medium leading-relaxed text-white';
				text.textContent = item.label;
				if (item.checked) text.classList.add('text-gray-400', 'line-through');

				label.append(checkbox, text);
				row.append(label);
				return row;
			};

			const renderItems = () => {
				if (!itemsContainer) return;
				const displayedRun = run ?? draftRun;
				itemsContainer.replaceChildren();
				displayedRun.items
					.slice()
					.sort((a, b) => a.order - b.order)
					.forEach((item) => itemsContainer.append(renderItem(item)));
			};

			const renderAuth = () => {
				root.querySelector<HTMLElement>('[data-auth-signed-out]')?.classList.toggle('hidden', Boolean(currentUser));
				root.querySelector<HTMLElement>('[data-auth-signed-in]')?.classList.toggle('hidden', !currentUser);
				const email = root.querySelector<HTMLElement>('[data-auth-email]');
				if (email) email.textContent = currentUser?.email ?? '';
			};

			const render = () => {
				renderAuth();
				renderItems();
			};

			root.querySelector<HTMLButtonElement>('[data-google-save]')?.addEventListener('click', async () => {
				try {
					if (run) saveChecklistRun(run);
					setMessage('Googleログインへ移動します。');
					await signInToSaveChecklist();
				} catch (error) {
					console.error(error);
					setMessage(error instanceof Error ? error.message : 'Googleログインを開始できませんでした。', true);
				}
			});

			root.querySelector<HTMLButtonElement>('[data-sign-out]')?.addEventListener('click', async () => {
				try {
					await signOutChecklistUser();
					currentUser = null;
					renderAuth();
				} catch (error) {
					console.error(error);
					setMessage('ログアウトできませんでした。', true);
				}
			});

			const initializeAuth = async () => {
				try {
					currentUser = await getChecklistUser();
					if (currentUser) {
						await hydrateChecklistRunsFromSupabase(currentUser);
						run = getActiveChecklistRun(template.checklistId);
						if (run) draftRun = run;
						await syncAllLocalChecklistRuns(currentUser);
					}
				} catch (error) {
					console.error(error);
					setMessage('Googleと同期できませんでした。', true);
				}
				render();
			};

			const supabase = getSupabaseClient();
			supabase?.auth.onAuthStateChange((_event, session) => {
				currentUser = session?.user ?? null;
				renderAuth();
			});

			window.addEventListener('storage', (event) => {
				if (event.key !== 'likethis:checklist-runs:v1') return;
				run = getActiveChecklistRun(template.checklistId);
				if (run) draftRun = run;
				else draftRun = createChecklistRun(template);
				render();
			});

			render();
			void initializeAuth();
		});
	}

	document.addEventListener('DOMContentLoaded', initChecklistRunners);
	document.addEventListener('astro:page-load', initChecklistRunners);
</script>
