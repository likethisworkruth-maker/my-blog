---
import LikeButton from './LikeButton.astro';

interface Props {
	slug: string;
	variant?: 'default' | 'feed' | 'reels';
	checklistId?: string;
}

const { slug, variant = 'default', checklistId } = Astro.props;
const id = slug.split('/')[1];
---

{variant === 'reels' ? (
	<div class="flex flex-col items-center gap-6">
		<LikeButton slug={slug} variant="reels" />
		<div data-public-actions class="contents">
			<button
				class="flex flex-col items-center text-white hover:text-gray-200 transition-colors active:scale-95"
				onclick="if(window.toggleCommentsPanel) window.toggleCommentsPanel()"
			>
				<span class="material-symbols-outlined text-[2rem] font-light drop-shadow-[0_2px_5px_rgba(0,0,0,0.8)]" style="font-variation-settings: 'FILL' 1;">chat_bubble</span>
				<span class="text-[0.75rem] font-medium drop-shadow-[0_2px_5px_rgba(0,0,0,0.8)] mt-1">コメント</span>
			</button>
			{checklistId && (
				<button class="relative flex flex-col items-center text-white hover:text-gray-200 transition-colors active:scale-95" onclick="if(window.startChecklist) window.startChecklist()" aria-label="このチェックリストを始める">
					<span class="material-symbols-outlined text-[2rem] font-light drop-shadow-[0_2px_5px_rgba(0,0,0,0.8)]">playlist_add</span>
					<span class="mt-1 text-[0.75rem] font-medium drop-shadow-[0_2px_5px_rgba(0,0,0,0.8)]">始める</span>
				</button>
			)}
		</div>
		<div data-private-actions class="hidden">
			<button class="relative flex flex-col items-center text-white hover:text-gray-200 transition-colors active:scale-95" onclick="if(window.toggleProgressPanel) window.toggleProgressPanel()" aria-label="チェックリストの進捗を開く">
				<span class="material-symbols-outlined text-[2rem] font-light drop-shadow-[0_2px_5px_rgba(0,0,0,0.8)]">checklist</span>
				<span class="mt-1 text-[0.75rem] font-medium drop-shadow-[0_2px_5px_rgba(0,0,0,0.8)]">進捗</span>
			</button>
			<button class="relative flex flex-col items-center text-white hover:text-gray-200 transition-colors active:scale-95" onclick="if(window.toggleMemoPanel) window.toggleMemoPanel()" aria-label="このチェックリストのメモを開く">
				<span class="material-symbols-outlined text-[2rem] font-light drop-shadow-[0_2px_5px_rgba(0,0,0,0.8)]">edit_note</span>
				<span class="mt-1 text-[0.75rem] font-medium drop-shadow-[0_2px_5px_rgba(0,0,0,0.8)]">メモ</span>
			</button>
		</div>
		<button class="flex flex-col items-center text-white hover:text-gray-200 transition-colors active:scale-95" data-share-trigger onclick="window.openShareModal?.()" aria-label="このページを共有">
			<span class="material-symbols-outlined text-[2rem] font-light drop-shadow-[0_2px_5px_rgba(0,0,0,0.8)]">send</span>
			<span class="text-[0.75rem] font-medium drop-shadow-[0_2px_5px_rgba(0,0,0,0.8)] mt-1">シェア</span>
		</button>
	</div>
) : (
	<div class={`flex items-center justify-start gap-3 ${variant === 'default' ? 'my-12 pt-8 border-t border-gray-100' : 'my-3'}`}>
		<LikeButton slug={slug} />
		<button
			class="flex h-8 w-8 items-center justify-center text-gray-400 transition-colors hover:text-mint-600 active:scale-95"
			onclick={variant === 'feed'
				? `if(window.openModal) window.openModal('${id}')`
				: `const form = document.querySelector('[data-slug="${slug}"][data-variant] #comment-form'); form?.scrollIntoView({ behavior: 'smooth', block: 'center' }); setTimeout(() => form?.querySelector('textarea[name="content"]')?.focus(), 450);`}
			aria-label="コメントを投稿"
		>
			<span class="material-symbols-outlined text-[1.5rem] font-light" aria-hidden="true">chat_bubble</span>
		</button>
		<button class="flex h-8 w-8 items-center justify-center text-gray-400 transition-colors hover:text-mint-600 active:scale-95" data-share-trigger onclick="window.openShareModal?.()" aria-label="このページを共有">
			<span class="material-symbols-outlined text-[1.5rem] font-light" aria-hidden="true">send</span>
		</button>
	</div>
)}
