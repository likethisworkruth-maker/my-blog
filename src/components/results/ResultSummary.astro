---
const { problemSlug, methodSlug } = Astro.props as { problemSlug?: string; methodSlug?: string };
---
<section class="result-summary rounded-3xl border border-gray-200 bg-white p-6 lg:p-8" data-problem={problemSlug} data-method={methodSlug}>
  <div class="flex items-center justify-between gap-4"><h2 class="text-lg font-bold text-navy-900">回答結果</h2><span class="result-count rounded-full bg-mint-50 px-3 py-1 text-xs font-bold text-mint-600">読み込み中</span></div>
  <p class="result-message mt-5 text-sm leading-7 text-gray-600">審査済みの回答だけを集計しています。</p>
  <div class="result-bars mt-5 space-y-4" aria-live="polite"></div>
  <p class="mt-5 text-xs leading-5 text-gray-400">回答が20件未満の場合は割合を表示しません。細かな内訳は5件以上集まった項目だけを表示します。</p>
</section>

<script>
  import { trialApi } from '../../lib/trialApi';
  const labels: Record<string, string> = { easier: '少し楽になった', no_change: '変わらない', harder: 'むしろ大変になった' };
  function initResultSummaries() {
  document.querySelectorAll<HTMLElement>('.result-summary').forEach(async (root) => {
    if (root.dataset.resultInitialized === 'true') return;
    root.dataset.resultInitialized = 'true';
    const count = root.querySelector<HTMLElement>('.result-count')!;
    const message = root.querySelector<HTMLElement>('.result-message')!;
    const bars = root.querySelector<HTMLElement>('.result-bars')!;
    try {
      const data = root.dataset.problem ? await trialApi.getProblemResults(root.dataset.problem) : await trialApi.getMethodResults(root.dataset.method!);
      const total = Number(data?.total ?? 0); count.textContent = `${total}件`;
      if (!total) { message.textContent = 'まだ公開できる回答がありません。最初の回答をお待ちしています。'; return; }
      message.textContent = data.show_percentages ? '回答が集まったため、件数と割合を表示しています。' : '現在は件数だけを表示しています。';
      const outcomes = Array.isArray(data.outcomes) ? data.outcomes : [];
      bars.innerHTML = outcomes.map((item: { key: string; count: number }) => {
        const percent = total ? Math.round(item.count / total * 100) : 0;
        return `<div><div class="flex justify-between text-sm"><span class="font-bold text-navy-900">${labels[item.key] ?? item.key}</span><span>${item.count}件${data.show_percentages ? `・${percent}%` : ''}</span></div><div class="mt-2 h-2 overflow-hidden rounded-full bg-gray-100"><div class="h-full rounded-full bg-mint-500" style="width:${data.show_percentages ? percent : Math.min(100, item.count * 8)}%"></div></div></div>`;
      }).join('');
    } catch (error) {
      count.textContent = '取得できませんでした'; message.textContent = error instanceof Error ? error.message : '結果の取得に失敗しました。';
    }
  });
  }
  initResultSummaries();
  document.addEventListener('astro:page-load', initResultSummaries);
</script>
