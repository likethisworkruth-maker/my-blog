---
const { problemSlug, questionText } = Astro.props as { problemSlug: string; questionText: string };
---
<section class="share-result rounded-2xl border border-gray-200 bg-white p-5" data-problem={problemSlug} data-question={questionText}>
  <h2 class="font-bold text-navy-900">結果をSNSへ共有する</h2><p class="mt-2 text-sm leading-6 text-gray-600">現在の審査済み件数を入れた画像と投稿文を作れます。投稿前に内容をご確認ください。</p>
  <div class="mt-4 flex flex-wrap gap-3"><button data-download class="rounded-full bg-navy-900 px-5 py-2 text-sm font-bold text-white">結果画像を保存</button><button data-share-text class="rounded-full border border-gray-300 px-5 py-2 text-sm font-bold text-navy-900">投稿文を共有</button></div><p data-share-status class="mt-3 text-xs text-gray-500" role="status"></p>
</section>
<script>
  import { trackTrialEvent } from '../../lib/analytics';
  import { trialApi } from '../../lib/trialApi';
  function initShareCards() {
  document.querySelectorAll<HTMLElement>('.share-result').forEach((root) => {
    if (root.dataset.shareInitialized === 'true') return;
    root.dataset.shareInitialized = 'true';
    const status = root.querySelector<HTMLElement>('[data-share-status]')!;
    async function values() { const data = await trialApi.getProblemResults(root.dataset.problem!); return { total: Number(data?.total ?? 0), question: root.dataset.question!, url: `${location.origin}/answer/${root.dataset.problem}/` }; }
    root.querySelector('[data-download]')?.addEventListener('click', async () => { try { const { total, question, url } = await values(); const canvas = document.createElement('canvas'); canvas.width = 1080; canvas.height = 1080; const c = canvas.getContext('2d')!; c.fillStyle = '#e9fbf6'; c.fillRect(0,0,1080,1080); c.fillStyle = '#16254c'; c.font = 'bold 44px sans-serif'; c.fillText('みんなの育児の試行結果', 90, 130); c.font = 'bold 58px sans-serif'; const lines = question.match(/.{1,16}/g) ?? [question]; lines.slice(0,4).forEach((line,i) => c.fillText(line,90,270+i*78)); c.fillStyle = '#3ec7a6'; c.font = 'bold 120px sans-serif'; c.fillText(`${total}家庭`,90,690); c.fillStyle = '#16254c'; c.font = '32px sans-serif'; c.fillText('審査済み回答を集計・少数データは非表示',90,790); c.font = '28px sans-serif'; c.fillText(url,90,930); const link = document.createElement('a'); link.download = `result-${root.dataset.problem}.png`; link.href = canvas.toDataURL('image/png'); link.click(); status.textContent = '画像を保存しました。'; trackTrialEvent('result_share', { problem_slug: root.dataset.problem }); } catch (e) { status.textContent = e instanceof Error ? e.message : '画像を作成できませんでした。'; } });
    root.querySelector('[data-share-text]')?.addEventListener('click', async () => { try { const { total, question, url } = await values(); const text = `${question}\n現在、審査済み${total}件の回答結果を公開しています。\n${url}`; if (navigator.share) await navigator.share({ title: '回答結果', text, url }); else { await navigator.clipboard.writeText(text); status.textContent = '投稿文をコピーしました。'; } trackTrialEvent('result_share', { problem_slug: root.dataset.problem }); } catch (e) { if ((e as Error).name !== 'AbortError') status.textContent = '共有できませんでした。'; } });
  });
  }
  initShareCards();
  document.addEventListener('astro:page-load', initShareCards);
</script>
