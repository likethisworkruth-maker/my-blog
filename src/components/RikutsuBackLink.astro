---
interface Props {
	label: string;
}

const { label } = Astro.props;
---

<nav aria-label="パンくず" class="flex items-center gap-1 text-xs font-bold text-gray-500">
	<a href="/rikutsu/" class="transition-colors hover:text-mint-600">理屈さんち</a>
	<span class="material-symbols-outlined text-sm text-gray-300" aria-hidden="true">chevron_right</span>
	<span aria-current="page" class="text-gray-700">{label}</span>
</nav>
