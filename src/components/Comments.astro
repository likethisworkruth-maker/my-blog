---
interface Props {
	slug: string;
	variant?: 'default' | 'modal' | 'reels';
}

const { slug, variant = 'default' } = Astro.props;

const wrapperClass = variant === 'modal'
	? 'flex flex-col h-full overflow-hidden'
	: variant === 'reels'
	? 'flex flex-col h-full overflow-hidden bg-[#262626] text-white w-full'
	: 'mt-16 pt-8 border-t border-gray-100';

const listClass = (variant === 'modal' || variant === 'reels')
	? 'flex-grow overflow-y-auto p-4 sm:p-6 space-y-4 scrollbar-hide'
	: 'space-y-4 mb-8';

const formClass = variant === 'modal'
	? 'shrink-0 p-4 sm:p-6 bg-white border-t border-gray-100'
	: variant === 'reels'
	? 'shrink-0 p-4 sm:p-6 bg-[#262626] border-t border-gray-800'
	: 'bg-gray-50 rounded-2xl p-4 sm:p-6';
---

<div id="comments" class={wrapperClass} data-slug={slug} data-variant={variant}>
	{variant === 'default' && (
		<h3 class="text-xl font-bold text-navy-900 mb-6 flex items-center gap-2">
			みんなのコメント
		</h3>
	)}

	<div id="comments-list" class={listClass}>
		<div class="text-center text-sm py-8 text-gray-400" id="comments-empty">
			コメントはまだありません。
		</div>
	</div>
	<nav id="comments-pagination" class={`hidden items-center justify-center gap-3 mb-8 text-sm ${variant === 'reels' ? 'text-gray-300' : 'text-gray-500'}`} aria-label="コメントのページ切り替え">
		<button type="button" id="comments-prev" class="w-9 h-9 rounded-full border border-current/20 flex items-center justify-center transition-colors hover:text-mint-500 disabled:opacity-30 disabled:cursor-not-allowed" aria-label="前の10件">
			<span class="material-symbols-outlined text-xl" aria-hidden="true">chevron_left</span>
		</button>
		<span id="comments-page-status" class="min-w-16 text-center font-bold">1 / 1</span>
		<button type="button" id="comments-next" class="w-9 h-9 rounded-full border border-current/20 flex items-center justify-center transition-colors hover:text-mint-500 disabled:opacity-30 disabled:cursor-not-allowed" aria-label="次の10件">
			<span class="material-symbols-outlined text-xl" aria-hidden="true">chevron_right</span>
		</button>
	</nav>

	<form id="comment-form" class={formClass}>
		<p data-comment-feedback class="mb-3 hidden whitespace-pre-line rounded-lg px-3 py-2 text-xs leading-5" role="status" aria-live="polite"></p>
		<details data-comment-info class={`group mb-3 text-xs leading-5 ${variant === 'reels' ? 'text-gray-300' : 'text-gray-600'}`}>
			<summary class="flex cursor-pointer list-none items-center gap-1.5 [&::-webkit-details-marker]:hidden">
				<span aria-hidden="true" class={variant === 'reels' ? 'text-mint-300' : 'text-mint-600'}>ⓘ</span>
				<span>公開コメントです。個人情報は入力しないでください</span>
			</summary>
			<div class={`mt-2 rounded-xl border p-3 ${variant === 'reels' ? 'border-white/10 bg-white/5 text-gray-300' : 'border-gray-200 bg-gray-50 text-gray-600'}`}>
				<p>氏名、連絡先、病院名などは入力しないでください。</p>
				<p data-anonymous-comment-info class="mt-2">未ログイン投稿は運営確認後に公開され、投稿後は削除できません。</p>
			</div>
		</details>
		<div class="flex items-end">
			<div class={`flex-grow flex items-end rounded-3xl border ${variant === 'reels' ? 'border-gray-700 bg-black/30' : 'border-gray-200 bg-white'} px-4 py-2`}>
				<textarea
					name="content"
					rows="1"
					maxlength="1000"
					placeholder="コメントを追加..."
					class={`min-h-9 max-h-40 w-full resize-none overflow-y-auto bg-transparent py-2 text-sm leading-5 focus:outline-none ${variant === 'reels' ? 'text-white placeholder-gray-500' : 'text-gray-800'}`}
					required
				></textarea>
				<button
					type="submit"
					id="comment-submit"
					class={`mb-0.5 ml-3 flex h-9 w-9 shrink-0 items-center justify-center rounded-full text-white transition-all active:scale-95 disabled:cursor-not-allowed disabled:opacity-40 ${variant === 'reels' ? 'bg-blue-500 hover:bg-blue-400' : 'bg-mint-500 hover:bg-mint-600'}`}
					aria-label="コメントを投稿"
					title="コメントを投稿"
				>
					<span class="material-symbols-outlined text-xl" aria-hidden="true">arrow_upward</span>
				</button>
			</div>
		</div>
	</form>

	<dialog data-comment-confirm class="comment-confirm-dialog w-[calc(100%_-_2rem)] max-w-sm rounded-2xl border-0 bg-white p-0 text-navy-900 shadow-2xl">
		<div class="p-6">
			<h3 class="text-base font-bold">コメントを送信しますか？</h3>
			<p class="mt-4 whitespace-pre-line text-sm leading-6 text-gray-600">コメントに氏名、連絡先、病院名などの
個人情報が含まれていないか確認してください。</p>
			<p class="mt-4 whitespace-pre-line text-sm leading-6 text-gray-600">未ログインで投稿したコメントは、
運営確認後に公開され、投稿後は削除できません。</p>
			<div class="mt-6 flex justify-end gap-2">
				<button type="button" data-comment-confirm-back class="rounded-full border border-gray-200 px-4 py-2.5 text-sm font-bold text-gray-600 hover:bg-gray-50">入力に戻る</button>
				<button type="button" data-comment-confirm-send class="rounded-full bg-mint-500 px-4 py-2.5 text-sm font-bold text-white hover:bg-mint-600 disabled:cursor-not-allowed disabled:opacity-40">確認して送信</button>
			</div>
		</div>
	</dialog>
</div>

<script>
	import { getSupabaseClient } from '../scripts/supabase-client';

	interface PublicComment {
		id: string;
		slug: string;
		author_name: string;
		content: string;
		created_at: string;
		is_mine: boolean;
	}

	interface CommentsPayload {
		comments?: unknown;
		total_count?: unknown;
	}

	const formatDate = (dateString: string) => new Intl.DateTimeFormat('ja-JP', {
		year: 'numeric',
		month: 'short',
		day: 'numeric',
		hour: '2-digit',
		minute: '2-digit',
	}).format(new Date(dateString));

	const isPublicComment = (value: unknown): value is PublicComment => {
		if (!value || typeof value !== 'object') return false;
		const comment = value as Partial<PublicComment>;
		return typeof comment.id === 'string'
			&& typeof comment.slug === 'string'
			&& typeof comment.author_name === 'string'
			&& typeof comment.content === 'string'
			&& typeof comment.created_at === 'string'
			&& typeof comment.is_mine === 'boolean';
	};

	const initCommentSection = async (section: HTMLElement) => {
		if (section.dataset.initialized === 'true') return;
		section.dataset.initialized = 'true';

		const slug = section.dataset.slug;
		const variant = section.dataset.variant;
		if (!slug) return;

		const supabase = getSupabaseClient();
		const commentsList = section.querySelector<HTMLElement>('#comments-list');
		const form = section.querySelector<HTMLFormElement>('#comment-form');
		const submitButton = section.querySelector<HTMLButtonElement>('#comment-submit');
		const textarea = section.querySelector<HTMLTextAreaElement>('textarea[name="content"]');
		const pagination = section.querySelector<HTMLElement>('#comments-pagination');
		const previousButton = section.querySelector<HTMLButtonElement>('#comments-prev');
		const nextButton = section.querySelector<HTMLButtonElement>('#comments-next');
		const pageStatus = section.querySelector<HTMLElement>('#comments-page-status');
		const anonymousInfo = section.querySelector<HTMLElement>('[data-anonymous-comment-info]');
		const feedback = section.querySelector<HTMLElement>('[data-comment-feedback]');
		const confirmDialog = section.querySelector<HTMLDialogElement>('[data-comment-confirm]');
		const confirmBack = section.querySelector<HTMLButtonElement>('[data-comment-confirm-back]');
		const confirmSend = section.querySelector<HTMLButtonElement>('[data-comment-confirm-send]');
		const pageSize = 10;
		let currentPage = 1;
		let totalCount = 0;
		let loggedIn = false;
		let pendingContent = '';

		const resizeTextarea = () => {
			if (!textarea) return;
			textarea.style.height = 'auto';
			textarea.style.height = `${Math.min(textarea.scrollHeight, 160)}px`;
		};
		textarea?.addEventListener('input', resizeTextarea);
		resizeTextarea();

		const setFeedback = (message = '', failed = false) => {
			if (!feedback) return;
			feedback.textContent = message;
			feedback.classList.toggle('hidden', !message);
			feedback.classList.toggle('bg-red-100', failed);
			feedback.classList.toggle('text-red-800', failed);
			feedback.classList.toggle('bg-mint-50', Boolean(message) && !failed);
			feedback.classList.toggle('text-mint-700', Boolean(message) && !failed);
		};

		if (!supabase || !commentsList) {
			if (submitButton) submitButton.disabled = true;
			setFeedback('コメント機能は現在利用できません。', true);
			return;
		}

		const updatePagination = () => {
			const totalPages = Math.max(1, Math.ceil(totalCount / pageSize));
			const showPagination = totalCount > pageSize;
			pagination?.classList.toggle('hidden', !showPagination);
			pagination?.classList.toggle('flex', showPagination);
			if (pageStatus) pageStatus.textContent = `${currentPage} / ${totalPages}`;
			if (previousButton) previousButton.disabled = currentPage <= 1;
			if (nextButton) nextButton.disabled = currentPage >= totalPages;
		};

		const loadComments = async () => {
			commentsList.setAttribute('aria-busy', 'true');
			try {
				const { data, error } = await supabase.rpc('get_approved_comments', {
					p_slug: slug,
					p_limit: pageSize,
					p_offset: (currentPage - 1) * pageSize,
				});
				if (error) throw error;
				const payload = data && typeof data === 'object' ? data as CommentsPayload : {};
				const comments = Array.isArray(payload.comments)
					? payload.comments.filter(isPublicComment)
					: [];
				totalCount = typeof payload.total_count === 'number' ? payload.total_count : comments.length;
				commentsList.replaceChildren();

				if (comments.length === 0) {
					const empty = document.createElement('div');
					empty.id = 'comments-empty';
					empty.className = 'text-center text-sm py-8 text-gray-400';
					empty.textContent = 'コメントはまだありません。';
					commentsList.appendChild(empty);
				} else {
					comments.forEach((comment) => {
						const card = document.createElement('article');
						const reels = variant === 'reels';
						card.className = reels
							? 'bg-transparent p-2 relative flex gap-3'
							: 'bg-white border border-gray-100 rounded-2xl p-4 sm:p-5 shadow-sm relative';

						const header = document.createElement('div');
						header.className = 'mb-2 flex items-start justify-between gap-3';
						const identity = document.createElement('div');
						const author = document.createElement('p');
						author.className = reels ? 'font-bold text-white text-[0.85rem]' : 'font-bold text-gray-700 text-[0.8rem] sm:text-sm';
						author.textContent = '匿名さん';
						const date = document.createElement('p');
						date.className = reels ? 'text-[0.7rem] text-gray-500' : 'text-[0.65rem] text-gray-400';
						date.textContent = formatDate(comment.created_at);
						identity.append(author, date);
						header.appendChild(identity);

						if (comment.is_mine) {
							const deleteButton = document.createElement('button');
							deleteButton.type = 'button';
							deleteButton.className = reels
								? 'shrink-0 text-xs font-bold text-gray-400 hover:text-red-300 disabled:opacity-40'
								: 'shrink-0 text-xs font-bold text-gray-400 hover:text-red-600 disabled:opacity-40';
							deleteButton.textContent = '削除';
							deleteButton.addEventListener('click', async () => {
								if (!window.confirm('このコメントを削除しますか？')) return;
								deleteButton.disabled = true;
								try {
									const { data: deleted, error: deleteError } = await supabase.rpc('delete_my_comment', {
										p_comment_id: comment.id,
									});
									if (deleteError) throw deleteError;
									if (deleted !== true) throw new Error('コメントを削除する権限がありません。');
									setFeedback('コメントを削除しました。');
									totalCount = Math.max(0, totalCount - 1);
									currentPage = Math.min(currentPage, Math.max(1, Math.ceil(totalCount / pageSize)));
									await loadComments();
								} catch (error) {
									console.error('Error deleting comment:', error);
									setFeedback('コメントを削除できませんでした。', true);
								} finally {
									deleteButton.disabled = false;
								}
							});
							header.appendChild(deleteButton);
						}

						const content = document.createElement('p');
						content.className = reels
							? 'whitespace-pre-wrap text-[0.85rem] text-gray-200 leading-relaxed'
							: 'whitespace-pre-wrap text-[0.85rem] sm:text-sm text-gray-600 leading-relaxed';
						content.textContent = comment.content;
						const body = document.createElement('div');
						body.className = 'min-w-0 flex-grow';
						body.append(header, content);
						card.appendChild(body);
						commentsList.appendChild(card);
					});
				}
				updatePagination();
			} catch (error) {
				console.error('Error fetching comments:', error);
				setFeedback('コメントを読み込めませんでした。', true);
			} finally {
				commentsList.removeAttribute('aria-busy');
			}
		};

		const changePage = async (page: number) => {
			currentPage = page;
			await loadComments();
			if (variant === 'modal' || variant === 'reels') commentsList.scrollTop = 0;
			else commentsList.scrollIntoView({ behavior: 'smooth', block: 'start' });
		};

		previousButton?.addEventListener('click', () => {
			if (currentPage > 1) void changePage(currentPage - 1);
		});
		nextButton?.addEventListener('click', () => {
			const totalPages = Math.max(1, Math.ceil(totalCount / pageSize));
			if (currentPage < totalPages) void changePage(currentPage + 1);
		});

		const submitComment = async (content: string, anonymous: boolean) => {
			if (!submitButton) return;
			submitButton.disabled = true;
			submitButton.setAttribute('aria-busy', 'true');
			if (confirmSend) confirmSend.disabled = true;
			setFeedback();
			try {
				const { data, error } = await supabase.rpc('submit_comment', {
					p_slug: slug,
					p_content: content,
				});
				if (error) throw error;
				const result = data && typeof data === 'object' ? data as { status?: unknown } : {};
				form?.reset();
				resizeTextarea();
				if (result.status === 'approved') {
					setFeedback('コメントを投稿しました。');
					currentPage = 1;
					await loadComments();
					commentsList.scrollTop = 0;
				} else {
					setFeedback(anonymous
						? 'コメントを受け付けました。\n運営による確認後に掲載されます。'
						: 'コメントを送信しました。運営による確認後に掲載されます。');
				}
			} catch (error) {
				console.error('Error posting comment:', error);
				setFeedback('コメントの送信に失敗しました。', true);
			} finally {
				submitButton.disabled = false;
				submitButton.removeAttribute('aria-busy');
				if (confirmSend) confirmSend.disabled = false;
			}
		};

		form?.addEventListener('submit', async (event) => {
			event.preventDefault();
			if (!submitButton || submitButton.disabled) return;
			const formData = new FormData(form);
			const content = String(formData.get('content') ?? '').trim();
			if (!content) return;

			if (!loggedIn && confirmDialog) {
				pendingContent = content;
				confirmDialog.showModal();
				return;
			}
			await submitComment(content, false);
		});

		const returnToInput = () => {
			pendingContent = '';
			confirmDialog?.close();
			window.setTimeout(() => textarea?.focus(), 0);
		};
		confirmBack?.addEventListener('click', returnToInput);
		confirmDialog?.addEventListener('cancel', (event) => {
			event.preventDefault();
			returnToInput();
		});
		confirmSend?.addEventListener('click', async () => {
			const content = pendingContent;
			if (!content) {
				returnToInput();
				return;
			}
			pendingContent = '';
			confirmDialog?.close();
			await submitComment(content, true);
		});

		const updatePolicy = (authenticated: boolean) => {
			loggedIn = authenticated;
			anonymousInfo?.classList.toggle('hidden', authenticated);
		};

		const { data: sessionData } = await supabase.auth.getSession();
		updatePolicy(Boolean(sessionData.session?.user));
		await loadComments();
		const authSubscription = supabase.auth.onAuthStateChange((_event, session) => {
			updatePolicy(Boolean(session?.user));
			window.setTimeout(() => void loadComments(), 0);
		}).data.subscription;

		const cleanup = () => {
			authSubscription.unsubscribe();
			document.removeEventListener('astro:before-swap', cleanup);
		};
		document.addEventListener('astro:before-swap', cleanup);
	};

	const initComments = () => {
		document.querySelectorAll<HTMLElement>('[data-slug][data-variant]').forEach((section) => {
			const panel = section.closest<HTMLElement>('[role="tabpanel"]');
			if (panel && (panel.hidden || panel.classList.contains('hidden'))) return;
			void initCommentSection(section);
		});
	};

	document.addEventListener('DOMContentLoaded', initComments);
	document.addEventListener('astro:page-load', initComments);
	document.addEventListener('comments:activate', initComments);
</script>

<style>
	.scrollbar-hide::-webkit-scrollbar {
		display: none;
	}
	.scrollbar-hide {
		-ms-overflow-style: none;
		scrollbar-width: none;
	}
	.comment-confirm-dialog::backdrop {
		background: rgb(0 0 0 / 0.55);
	}
</style>
