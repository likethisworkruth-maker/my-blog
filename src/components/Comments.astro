---
interface Props {
	slug: string;
}

const { slug } = Astro.props;
---

<div id="comments" class="mt-16 pt-8 border-t border-gray-100" data-slug={slug}>
	<h3 class="text-xl font-bold text-navy-900 mb-6 flex items-center gap-2">
		<span class="material-symbols-outlined text-gray-400">chat_bubble</span>
		コメント
	</h3>

	<!-- Comments List -->
	<div id="comments-list" class="space-y-4 mb-8">
		<!-- Comments will be injected here -->
		<div class="text-center text-gray-400 text-sm py-4" id="comments-loading">
			読み込み中...
		</div>
	</div>

	<!-- Comment Form -->
	<form id="comment-form" class="bg-gray-50 rounded-2xl p-4 sm:p-6">
		<h4 class="text-sm font-bold text-gray-700 mb-4">コメントを投稿する</h4>
		<div class="mb-4">
			<label for="comment-author" class="block text-xs font-medium text-gray-500 mb-1">お名前 (任意)</label>
			<input 
				type="text" 
				id="comment-author" 
				name="author" 
				value="匿名ままさん"
				placeholder="名無しさん"
				class="w-full px-4 py-2 rounded-xl border border-gray-200 focus:outline-none focus:border-navy-900 focus:ring-1 focus:ring-navy-900 transition-colors bg-white text-sm"
			/>
		</div>
		<div class="mb-4">
			<label for="comment-content" class="block text-xs font-medium text-gray-500 mb-1">コメント本文</label>
			<textarea 
				id="comment-content" 
				name="content" 
				rows="3"
				required
				placeholder="記事の感想など..."
				class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:border-navy-900 focus:ring-1 focus:ring-navy-900 transition-colors bg-white text-sm resize-y"
			></textarea>
		</div>
		<button 
			type="submit" 
			id="comment-submit"
			class="w-full sm:w-auto px-6 py-3 bg-navy-900 hover:bg-navy-800 text-white font-bold rounded-full transition-colors flex items-center justify-center gap-2 text-sm disabled:opacity-50 disabled:cursor-not-allowed"
		>
			<span class="material-symbols-outlined text-[1.2rem]">send</span>
			送信する
		</button>
	</form>
</div>

<script>
	import { createClient } from '@supabase/supabase-js';

	// Format date nicely
	const formatDate = (dateString: string) => {
		const date = new Date(dateString);
		return new Intl.DateTimeFormat('ja-JP', {
			year: 'numeric',
			month: 'short',
			day: 'numeric',
			hour: '2-digit',
			minute: '2-digit'
		}).format(date);
	};

	// Escape HTML to prevent XSS
	const escapeHtml = (unsafe: string) => {
		return unsafe
			.replace(/&/g, "&amp;")
			.replace(/</g, "&lt;")
			.replace(/>/g, "&gt;")
			.replace(/"/g, "&quot;")
			.replace(/'/g, "&#039;");
	};

	const initComments = async () => {
		const section = document.getElementById('comments');
		if (!section || section.hasAttribute('data-initialized')) return;
		section.setAttribute('data-initialized', 'true');

		const slug = section.getAttribute('data-slug');
		if (!slug) return;

		const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
		const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
		
		if (!supabaseUrl || !supabaseAnonKey) {
			const loadingEl = document.getElementById('comments-loading');
			if (loadingEl) loadingEl.remove();
			return;
		}

		const supabase = createClient(supabaseUrl, supabaseAnonKey);
		const commentsList = document.getElementById('comments-list');
		const form = document.getElementById('comment-form') as HTMLFormElement;
		const submitBtn = document.getElementById('comment-submit') as HTMLButtonElement;
		const loadingEl = document.getElementById('comments-loading');

		// Render single comment
		const renderComment = (comment: any, isPending = false) => {
			const div = document.createElement('div');
			div.className = `bg-white border border-gray-100 rounded-2xl p-4 sm:p-5 shadow-sm relative ${isPending ? 'opacity-60' : ''}`;
			
			// Simple fallback for empty names
			const authorName = comment.author_name?.trim() ? comment.author_name : '名無しさん';
			
			// Replace newlines with <br> after escaping
			const contentHtml = escapeHtml(comment.content).replace(/\n/g, '<br/>');

			const pendingBadge = isPending 
				? `<div class="absolute top-4 right-4 bg-gray-100 text-gray-500 text-[0.65rem] px-2 py-1 rounded-full font-bold">認証待機中</div>`
				: '';

			div.innerHTML = `
				${pendingBadge}
				<div class="flex justify-between items-start mb-2">
					<div class="font-bold text-gray-700 text-[0.8rem] sm:text-sm flex items-center gap-2">
						<div class="w-6 h-6 rounded-full bg-gray-100 flex items-center justify-center text-gray-500">
							<span class="material-symbols-outlined text-[1rem]">person</span>
						</div>
						${escapeHtml(authorName)}
					</div>
					<div class="text-[0.65rem] text-gray-400">${isPending ? '送信完了' : formatDate(comment.created_at)}</div>
				</div>
				<div class="text-[0.85rem] sm:text-sm text-gray-600 leading-relaxed sm:pl-8">
					${contentHtml}
				</div>
			`;
			return div;
		};

		// Fetch comments
		try {
			const { data: comments, error } = await supabase
				.from('comments')
				.select('*')
				.eq('slug', slug)
				.order('created_at', { ascending: false });

			if (error) throw error;

			if (commentsList && loadingEl) {
				loadingEl.remove(); // Remove loading text
				
				if (comments.length === 0) {
					const emptyEl = document.createElement('div');
					emptyEl.id = 'comments-empty';
					emptyEl.className = 'text-center text-gray-400 text-sm py-8';
					emptyEl.textContent = 'まだコメントはありません。一番乗りでコメントしてみましょう！';
					commentsList.appendChild(emptyEl);
				} else {
					comments.forEach(c => commentsList.appendChild(renderComment(c)));
				}
			}
		} catch (err) {
			console.error('Error fetching comments:', err);
			if (loadingEl) loadingEl.remove();
		}

		// Handle form submission
		if (form) {
			form.addEventListener('submit', async (e) => {
				e.preventDefault();
				if (submitBtn.disabled) return;

				const formData = new FormData(form);
				let author_name = (formData.get('author') as string)?.trim();
				const content = (formData.get('content') as string)?.trim();

				if (!content) return;
				if (!author_name) author_name = '名無しさん';

				// Disable form
				submitBtn.disabled = true;
				const originalText = submitBtn.innerHTML;
				submitBtn.innerHTML = '<span class="material-symbols-outlined text-[1.2rem] animate-spin">refresh</span> 送信中...';

				try {
					const { error } = await supabase
						.from('comments')
						.insert([
							{ slug, author_name, content }
						]);

					if (error) throw error;

					// Success
					form.reset();
					
					// Remove empty state message if exists
					const emptyEl = document.getElementById('comments-empty');
					if (emptyEl) emptyEl.remove();

					// Render as pending and prepend to list
					const pendingComment = {
						author_name,
						content,
						created_at: new Date().toISOString()
					};
					const newEl = renderComment(pendingComment, true);
					if (commentsList) {
						commentsList.insertBefore(newEl, commentsList.firstChild);
					}
					
				} catch (err) {
					console.error('Error posting comment:', err);
					alert('コメントの送信に失敗しました。');
				} finally {
					// Enable form
					submitBtn.disabled = false;
					submitBtn.innerHTML = originalText;
				}
			});
		}
	};

	// Initialize
	document.addEventListener('DOMContentLoaded', initComments);
	document.addEventListener('astro:page-load', initComments);
</script>
