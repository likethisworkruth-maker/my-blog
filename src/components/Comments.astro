---
interface Props {
	slug: string;
	variant?: 'default' | 'modal' | 'reels';
}

const { slug, variant = 'default' } = Astro.props;

const wrapperClass = variant === 'modal'
	? 'flex flex-col h-full overflow-hidden'
	: variant === 'reels'
	? 'flex flex-col h-full overflow-hidden bg-[#262626] text-white w-full'
	: 'mt-16 pt-8 border-t border-gray-100';

const listClass = (variant === 'modal' || variant === 'reels')
	? 'flex-grow overflow-y-auto p-4 sm:p-6 space-y-4 scrollbar-hide'
	: 'space-y-4 mb-8';

const formClass = variant === 'modal'
	? 'shrink-0 p-4 sm:p-6 bg-white border-t border-gray-100'
	: variant === 'reels'
	? 'shrink-0 p-4 sm:p-6 bg-[#262626] border-t border-gray-800'
	: 'bg-gray-50 rounded-2xl p-4 sm:p-6';
---

<div id="comments" class={wrapperClass} data-slug={slug} data-variant={variant}>
	{variant === 'default' && (
		<h3 class="text-xl font-bold text-navy-900 mb-6 flex items-center gap-2">
			みんなのコメント
		</h3>
	)}

	<!-- Comments List -->
	<div id="comments-list" class={listClass}>
		<!-- Comments will be injected here -->
		<div class={`text-center text-sm py-8 ${variant === 'reels' ? 'text-gray-400' : 'text-gray-400'}`} id="comments-empty">
			コメントはまだありません。
		</div>
	</div>
	<nav id="comments-pagination" class={`hidden items-center justify-center gap-3 mb-8 text-sm ${variant === 'reels' ? 'text-gray-300' : 'text-gray-500'}`} aria-label="コメントのページ切り替え">
		<button type="button" id="comments-prev" class="w-9 h-9 rounded-full border border-current/20 flex items-center justify-center transition-colors hover:text-mint-500 disabled:opacity-30 disabled:cursor-not-allowed" aria-label="前の10件">
			<span class="material-symbols-outlined text-xl" aria-hidden="true">chevron_left</span>
		</button>
		<span id="comments-page-status" class="min-w-16 text-center font-bold">
			1 / 1
		</span>
		<button type="button" id="comments-next" class="w-9 h-9 rounded-full border border-current/20 flex items-center justify-center transition-colors hover:text-mint-500 disabled:opacity-30 disabled:cursor-not-allowed" aria-label="次の10件">
			<span class="material-symbols-outlined text-xl" aria-hidden="true">chevron_right</span>
		</button>
	</nav>

	<!-- Comment Form -->
	<form id="comment-form" class={formClass}>
		{variant === 'default' && (
			<h4 class="text-sm font-bold text-gray-700 mb-4">コメントを投稿する</h4>
		)}
		<div class="flex items-end">
			<div class={`flex-grow flex items-end rounded-3xl border ${variant === 'reels' ? 'border-gray-700 bg-black/30' : 'border-gray-200 bg-white'} px-4 py-2`}>
				<textarea
					name="content"
					rows="1"
					placeholder="コメントを追加..."
					class={`min-h-9 max-h-40 w-full resize-none overflow-y-auto bg-transparent py-2 text-sm leading-5 focus:outline-none ${variant === 'reels' ? 'text-white placeholder-gray-500' : 'text-gray-800'}`}
					required
				></textarea>
				<button
					type="submit"
					id="comment-submit"
					class={`mb-0.5 ml-3 flex h-9 w-9 shrink-0 items-center justify-center rounded-full text-white transition-all active:scale-95 disabled:cursor-not-allowed disabled:opacity-40 ${variant === 'reels' ? 'bg-blue-500 hover:bg-blue-400' : 'bg-mint-500 hover:bg-mint-600'}`}
					aria-label="コメントを投稿"
					title="コメントを投稿"
				>
					<span class="material-symbols-outlined text-xl" aria-hidden="true">arrow_upward</span>
				</button>
			</div>
		</div>
		<input type="hidden" name="author" value="匿名ままさん" />
	</form>
</div>

<script>
	import { createClient } from '@supabase/supabase-js';

	// Format date nicely
	const formatDate = (dateString: string) => {
		const date = new Date(dateString);
		return new Intl.DateTimeFormat('ja-JP', {
			year: 'numeric',
			month: 'short',
			day: 'numeric',
			hour: '2-digit',
			minute: '2-digit'
		}).format(date);
	};

	// Escape HTML to prevent XSS
	const escapeHtml = (unsafe: string) => {
		return unsafe
			.replace(/&/g, "&amp;")
			.replace(/</g, "&lt;")
			.replace(/>/g, "&gt;")
			.replace(/"/g, "&quot;")
			.replace(/'/g, "&#039;");
	};

	const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
	const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
	
	let supabase: ReturnType<typeof createClient> | null = null;
	if (supabaseUrl && supabaseAnonKey) {
		if (!(window as any).__supabaseClient) {
			(window as any).__supabaseClient = createClient(supabaseUrl, supabaseAnonKey);
		}
		supabase = (window as any).__supabaseClient;
	}

	const initCommentSection = async (section: HTMLElement) => {
		if (section.hasAttribute('data-initialized')) return;
		section.setAttribute('data-initialized', 'true');

		const slug = section.getAttribute('data-slug');
		const variant = section.getAttribute('data-variant');
		if (!slug) return;

		const commentsList = section.querySelector('#comments-list') as HTMLElement;
		const form = section.querySelector('#comment-form') as HTMLFormElement;
		const submitBtn = section.querySelector('#comment-submit') as HTMLButtonElement;
		const textarea = section.querySelector('textarea[name="content"]') as HTMLTextAreaElement;
		const pagination = section.querySelector('#comments-pagination') as HTMLElement;
		const prevButton = section.querySelector('#comments-prev') as HTMLButtonElement;
		const nextButton = section.querySelector('#comments-next') as HTMLButtonElement;
		const pageStatus = section.querySelector('#comments-page-status') as HTMLElement;
		const pageSize = 10;
		let currentPage = 1;
		let totalCount = 0;

		const resizeTextarea = () => {
			if (!textarea) return;
			textarea.style.height = 'auto';
			textarea.style.height = `${Math.min(textarea.scrollHeight, 160)}px`;
		};
		textarea?.addEventListener('input', resizeTextarea);
		resizeTextarea();

		if (!supabase) {
			// Supabase is not configured, leave empty message
			return;
		}

		// Render single comment
		const renderComment = (comment: any, isPending = false) => {
			const div = document.createElement('div');
			const isReels = variant === 'reels';
			
			div.className = isReels 
				? `bg-transparent p-2 relative flex gap-3 ${isPending ? 'opacity-60' : ''}`
				: `bg-white border border-gray-100 rounded-2xl p-4 sm:p-5 shadow-sm relative ${isPending ? 'opacity-60' : ''}`;
			
			// Simple fallback for empty names
			const authorName = comment.author_name?.trim() ? comment.author_name : '名無しさん';
			
			// Replace newlines with <br> after escaping
			const contentHtml = escapeHtml(comment.content).replace(/\n/g, '<br/>');

			const pendingBadge = isPending 
				? `<div class="absolute top-4 right-4 bg-gray-100 text-gray-500 text-[0.65rem] px-2 py-1 rounded-full font-bold">待機中</div>`
				: '';

			if (isReels) {
				div.innerHTML = `
					${pendingBadge}
					<div class="flex-grow">
						<div class="flex items-baseline gap-2 mb-1">
							<span class="font-bold text-white text-[0.85rem]">${escapeHtml(authorName)}</span>
							<span class="text-[0.7rem] text-gray-500">${isPending ? '送信完了' : formatDate(comment.created_at)}</span>
						</div>
						<div class="text-[0.85rem] text-gray-200 leading-relaxed">
							${contentHtml}
						</div>
					</div>
				`;
			} else {
				div.innerHTML = `
					${pendingBadge}
					<div class="flex justify-between items-start mb-2">
						<div class="font-bold text-gray-700 text-[0.8rem] sm:text-sm">
							${escapeHtml(authorName)}
						</div>
						<div class="text-[0.65rem] text-gray-400">${isPending ? '送信完了' : formatDate(comment.created_at)}</div>
					</div>
					<div class="text-[0.85rem] sm:text-sm text-gray-600 leading-relaxed">
						${contentHtml}
					</div>
				`;
			}
			return div;
		};

		// Fetch paginated comments
		const updatePagination = () => {
			const totalPages = Math.max(1, Math.ceil(totalCount / pageSize));
			const showPagination = totalCount > pageSize;
			pagination?.classList.toggle('hidden', !showPagination);
			pagination?.classList.toggle('flex', showPagination);
			if (pageStatus) pageStatus.textContent = `${currentPage} / ${totalPages}`;
			if (prevButton) prevButton.disabled = currentPage <= 1;
			if (nextButton) nextButton.disabled = currentPage >= totalPages;
		};

		const loadComments = async () => {
			const from = (currentPage - 1) * pageSize;
			const to = from + pageSize - 1;
			commentsList?.setAttribute('aria-busy', 'true');

			try {
				const { data: comments, error, count } = await supabase
					.from('comments')
					.select('*', { count: 'exact' })
					.eq('slug', slug)
					.order('created_at', { ascending: false })
					.range(from, to);

				if (error) throw error;

				totalCount = count ?? comments?.length ?? 0;
				commentsList?.replaceChildren();
				if (comments?.length) {
					comments.forEach((comment) => commentsList?.appendChild(renderComment(comment)));
				} else if (commentsList) {
					const emptyMessage = document.createElement('div');
					emptyMessage.id = 'comments-empty';
					emptyMessage.className = 'text-center text-sm py-8 text-gray-400';
					emptyMessage.textContent = 'コメントはまだありません。';
					commentsList.appendChild(emptyMessage);
				}
				updatePagination();
			} catch (err) {
				console.error('Error fetching comments:', err);
			} finally {
				commentsList?.removeAttribute('aria-busy');
			}
		};

		const changePage = async (page: number) => {
			currentPage = page;
			await loadComments();
			if (variant === 'modal' || variant === 'reels') {
				commentsList.scrollTop = 0;
			} else {
				commentsList.scrollIntoView({ behavior: 'smooth', block: 'start' });
			}
		};

		prevButton?.addEventListener('click', () => {
			if (currentPage > 1) void changePage(currentPage - 1);
		});
		nextButton?.addEventListener('click', () => {
			const totalPages = Math.max(1, Math.ceil(totalCount / pageSize));
			if (currentPage < totalPages) void changePage(currentPage + 1);
		});

		await loadComments();

		// Handle form submission
		if (form) {
			form.addEventListener('submit', async (e) => {
				e.preventDefault();
				if (submitBtn.disabled) return;

				const formData = new FormData(form);
				let author_name = (formData.get('author') as string)?.trim();
				const content = (formData.get('content') as string)?.trim();

				if (!content) return;
				if (!author_name) author_name = '名無しさん';

				// Disable form
				submitBtn.disabled = true;
				submitBtn.setAttribute('aria-busy', 'true');

				try {
					const { error } = await supabase
						.from('comments')
						.insert([
							{ slug, author_name, content } as never
						]);

					if (error) throw error;

					form.reset();
					resizeTextarea();
					currentPage = 1;
					await loadComments();
					commentsList.scrollTop = 0;

				} catch (err) {
					console.error('Error posting comment:', err);
					alert('コメントの送信に失敗しました。');
				} finally {
					// Enable form
					submitBtn.disabled = false;
					submitBtn.removeAttribute('aria-busy');
				}
			});
		}
	};

	const initComments = () => {
		document.querySelectorAll<HTMLElement>('[data-slug][data-variant]').forEach((section) => {
			void initCommentSection(section);
		});
	};

	// Initialize
	document.addEventListener('DOMContentLoaded', initComments);
	document.addEventListener('astro:page-load', initComments);
</script>

<style>
	.scrollbar-hide::-webkit-scrollbar {
		display: none;
	}
	.scrollbar-hide {
		-ms-overflow-style: none;
		scrollbar-width: none;
	}
</style>
