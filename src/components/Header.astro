---
import { SHOW_NARAIBASE, SITE_TITLE } from "../consts";
import { UI } from "../i18n/ja";
import GoogleAuthButton from "./GoogleAuthButton.astro";

const pathname =
	new URL(
		Astro
			.request
			.url,
	)
		.pathname;
const currentPath =
	pathname.slice(
		1,
	);
const isRikutsuPath = ["rikutsu", "apps", "items", "logs"].some((path) =>
	currentPath.startsWith(path),
);
---

<header
	class="sticky top-0 z-50 w-full bg-white border-b border-gray-100 lg:border-none"
>
	<div
		class="mx-auto grid max-w-6xl grid-cols-[minmax(0,1fr)_auto] items-center gap-3 px-4 py-4 sm:px-6 lg:grid-cols-[minmax(0,1fr)_auto_minmax(0,1fr)]"
	>
		<!-- Logo -->
		<a
			href="/"
			class="flex min-w-0 items-center gap-2 justify-self-start whitespace-nowrap font-bold text-[1.1rem] text-navy-900"
		>
			{SITE_TITLE}
		</a>

		<!-- PC Navigation -->
		<nav
			class="hidden items-center gap-6 justify-self-center lg:flex xl:gap-8"
		>
			<a
				href="/"
				class={`font-bold transition-colors pb-1 border-b-2 ${currentPath === "" ? "text-mint-500 border-mint-500" : "text-gray-600 border-transparent hover:text-navy-900"}`}
			>
				{UI.headerNav.home}
			</a>
			<a
				href="/knowhow/"
				class={`font-bold transition-colors pb-1 border-b-2 ${currentPath.startsWith("knowhow") ? "text-mint-500 border-mint-500" : "text-gray-600 border-transparent hover:text-navy-900"}`}
			>
				{UI.headerNav.knowhow}
			</a>
			<a
				href="/rikutsu/"
				class={`font-bold transition-colors pb-1 border-b-2 ${isRikutsuPath ? "text-mint-500 border-mint-500" : "text-gray-600 border-transparent hover:text-navy-900"}`}
			>
				{UI.headerNav.rikutsu}
			</a>
		</nav>

	</div>

	<div class="absolute right-4 top-1/2 flex -translate-y-1/2 items-center gap-2 sm:right-6">
		{SHOW_NARAIBASE && (
			<a href="https://naraibase.likethis.work/" class="hidden rounded-full bg-[#1d224b] px-4 py-2 text-sm font-bold text-white transition-colors hover:opacity-90 sm:inline-flex">
				{UI.headerNav.naraibase}
			</a>
		)}
		<GoogleAuthButton />
	</div>
</header>
