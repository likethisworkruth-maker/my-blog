---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import LogCard from "../components/LogCard.astro";
import { SHOW_NARAIBASE, SITE_TITLE } from "../consts";

const logs = await getCollection("logs");
logs.sort((a, b) => b.data.logNumber.localeCompare(a.data.logNumber));
const recentLogs = logs.slice(0, 3);
---

<Layout title={SITE_TITLE} description="初めての子育てで直面した困りごとへの具体的な対策や、アプリの活用法などをまとめています。">
	<section class="relative bg-[url('/hero-bg.png')] bg-cover bg-right bg-no-repeat px-6 pt-12 pb-16 lg:pt-24 lg:pb-28">
		<div class="absolute inset-0 bg-gradient-to-b from-white via-white/80 to-white/30 backdrop-blur-[2px] sm:bg-none sm:bg-transparent sm:backdrop-blur-none"></div>
		<div class="relative z-10 max-w-xl">
			<h1 class="text-[1.25rem] lg:text-[1.6rem] leading-[1.8] lg:leading-loose font-bold text-navy-900 tracking-wide">
				初めての子育てで直面した困りごとと、<br class="hidden lg:block" />その対策や試行錯誤をまとめています。
			</h1>
		</div>
	</section>

	<section class="px-6 py-12 lg:py-16">
		<div class="max-w-6xl mx-auto">
			<div class="grid gap-4 sm:grid-cols-3">
				<a href="/knowhow/" class="block rounded-2xl border border-gray-200 p-6 hover:bg-gray-50 hover:border-mint-500 transition-all group">
					<span class="material-symbols-outlined text-mint-500 text-3xl mb-3" aria-hidden="true">description</span>
					<h2 class="font-bold text-navy-900 text-lg group-hover:text-mint-600 transition-colors">チェクリスト</h2>
					<p class="mt-2 text-xs leading-relaxed text-gray-600">冷蔵庫のカレンダーやメモ、連絡時のルールなど工夫した仕組みです。</p>
				</a>
				<a href="/apps/" class="block rounded-2xl border border-gray-200 p-6 hover:bg-gray-50 hover:border-mint-500 transition-all group">
					<span class="material-symbols-outlined text-mint-500 text-3xl mb-3" aria-hidden="true">apps</span>
					<h2 class="font-bold text-navy-900 text-lg group-hover:text-mint-600 transition-colors">アプリ</h2>
					<p class="mt-2 text-xs leading-relaxed text-gray-600">実際に使ってみたアプリやサービスを紹介しています。</p>
				</a>
				<a href="/items/" class="block rounded-2xl border border-gray-200 p-6 hover:bg-gray-50 hover:border-mint-500 transition-all group">
					<span class="material-symbols-outlined text-mint-500 text-3xl mb-3" aria-hidden="true">toys_and_games</span>
					<h2 class="font-bold text-navy-900 text-lg group-hover:text-mint-600 transition-colors">アイテム</h2>
					<p class="mt-2 text-xs leading-relaxed text-gray-600">子育ての困りごとをラクにするために使ったアイテムを紹介しています。</p>
				</a>
			</div>
		</div>
	</section>
	<section class="px-6 py-12 lg:py-16 bg-gray-50/20 border-b border-gray-50">
		<div class="max-w-6xl mx-auto">
			<div class="flex items-center justify-between mb-8">
				<h2 class="text-lg font-bold text-navy-900">子育てログ</h2>
				<a href="/logs/" class="text-xs font-bold text-mint-600 hover:underline flex items-center gap-0.5">すべての記録を見る <span class="material-symbols-outlined text-sm" aria-hidden="true">chevron_right</span></a>
			</div>
			
			<div class="flex flex-col gap-0 md:grid md:grid-cols-2 lg:grid-cols-3 md:gap-6">
				{recentLogs.map((log) => <LogCard log={log} />)}
			</div>
		</div>
	</section>

	{/* Naraibase */}
	{SHOW_NARAIBASE && (
	<section class="px-6 py-12 lg:py-16">
		<div class="max-w-6xl mx-auto">
			<div class="bg-navy-900 text-white p-8 sm:p-12 rounded-3xl shadow-sm">
				<h2 class="mt-3 text-2xl font-bold">Naraibase（ナライベース）</h2>
				<p class="mt-4 max-w-2xl text-sm leading-7 text-gray-200">
					習い事を経験した大人に、大人になった今「役立ったか」「自分の子どもにも勧めたいか」を聞き、その回答を掲載します。
				</p>
				<div class="mt-7 flex flex-wrap gap-3">
					<a href="https://naraibase.likethis.work/" class="rounded-full bg-mint-500 px-6 py-3 text-sm font-bold text-white hover:bg-mint-600">Naraibaseを見る</a>
				</div>
			</div>
		</div>
	</section>
	)}

</Layout>
