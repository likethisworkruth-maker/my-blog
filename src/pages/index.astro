---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
import { UI } from "../i18n/ja";

const logs = await getCollection("logs");
logs.sort((a, b) => b.data.logNumber.localeCompare(a.data.logNumber));
const recentLogs = logs.slice(0, 3);
---

<Layout title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<!-- Hero: このサイトでできること -->
	<section class="px-6 pt-12 pb-16 lg:pt-20 lg:pb-24 bg-[url('/hero-bg.png')] bg-cover bg-right bg-no-repeat relative border-b border-gray-100">
		<div class="absolute inset-0 bg-gradient-to-b from-white via-white/80 to-white/30 backdrop-blur-[2px] sm:bg-none sm:bg-transparent sm:backdrop-blur-none"></div>
		<div class="relative z-10 max-w-2xl">
			<span class="text-xs font-bold text-mint-600 bg-mint-50 px-3 py-1 rounded-full uppercase tracking-wider">育児の試行錯誤データベース</span>
			<h1 class="text-2xl lg:text-3xl leading-[1.6] lg:leading-normal font-bold mt-4 mb-6 text-navy-900 tracking-wide" set:html={UI.home.heroTitle} />
			<p class="text-sm lg:text-base text-gray-700 leading-relaxed font-medium" set:html={UI.home.heroDesc} />
			
			<div class="mt-8 grid gap-4 sm:grid-cols-3">
				<div class="bg-white/80 backdrop-blur border border-gray-200 rounded-xl p-4">
					<h3 class="text-xs font-bold text-navy-900 flex items-center gap-1"><span class="material-symbols-outlined text-mint-500 text-sm" aria-hidden="true">search</span>1. 困りごとを探す</h3>
					<p class="text-[0.75rem] text-gray-500 mt-1 leading-normal">同じ困りごとを持つ家庭の事例から解決のヒントを探せます。</p>
				</div>
				<div class="bg-white/80 backdrop-blur border border-gray-200 rounded-xl p-4">
					<h3 class="text-xs font-bold text-navy-900 flex items-center gap-1"><span class="material-symbols-outlined text-mint-500 text-sm" aria-hidden="true">bar_chart</span>2. 方法と結果を比較</h3>
					<p class="text-[0.75rem] text-gray-500 mt-1 leading-normal">工夫・アプリ・道具の効果や続けやすさを同じ項目で比較できます。</p>
				</div>
				<div class="bg-white/80 backdrop-blur border border-gray-200 rounded-xl p-4">
					<h3 class="text-xs font-bold text-navy-900 flex items-center gap-1"><span class="material-symbols-outlined text-mint-500 text-sm" aria-hidden="true">history_edu</span>3. 試した結果を共有</h3>
					<p class="text-[0.75rem] text-gray-500 mt-1 leading-normal">わが家で試してどうだったかを短時間でデータベースに残せます。</p>
				</div>
			</div>
		</div>
	</section>

	<!-- 現在検証中の困りごと -->
	<section class="px-6 py-12 lg:py-16 border-b border-gray-50">
		<div class="max-w-4xl mx-auto">
			<div class="flex items-center justify-between mb-6">
				<div>
					<h2 class="text-lg lg:text-xl font-bold text-navy-900">現在検証中の困りごと</h2>
					<p class="text-xs text-gray-500 mt-1">実体験をもとに「何が効果的か」を検証しているテーマです。</p>
				</div>
				<a href="/problems/" class="text-xs font-bold text-mint-600 hover:underline flex items-center gap-1">すべての困りごと <span class="material-symbols-outlined text-sm" aria-hidden="true">arrow_forward</span></a>
			</div>
			
			<div class="bg-mint-50/50 border border-mint-100 rounded-2xl p-6 lg:p-8 flex flex-col md:flex-row gap-6 justify-between items-start md:items-center">
				<div class="flex-grow">
					<div class="flex items-center gap-2 mb-3 text-xs font-bold text-mint-600">
						<span class="material-symbols-outlined text-sm" aria-hidden="true">campaign</span>現在のフォーカス
					</div>
					<h3 class="text-lg lg:text-xl font-bold text-navy-900">予防接種・健診の予定共有</h3>
					<p class="text-sm text-gray-600 mt-2 leading-relaxed max-w-xl">
						予定の伝え忘れや確認漏れを減らすために、各家庭で試した方法と結果を比べます。医療判断ではなく、予定共有の方法についての調査です。
					</p>
					<div class="mt-4 flex flex-wrap gap-4 text-xs font-bold text-gray-500">
						<span>運営者の記録：1件</span>
						<span class="text-gray-300">•</span>
						<span>試した方法：5件</span>
						<span class="text-gray-300">•</span>
						<span class="text-mint-600 bg-mint-50 px-2 py-0.5 rounded-full">外部回答：準備中（内部テスト）</span>
					</div>
				</div>
				<div class="flex shrink-0 gap-3 w-full md:w-auto">
					<a href="/problems/vaccine-schedule-sharing/" class="flex-1 md:flex-initial text-center bg-mint-500 hover:bg-mint-600 text-white font-bold py-3 px-6 rounded-full text-sm transition-colors shadow-sm">詳細と比較を見る</a>
				</div>
			</div>
		</div>
	</section>

	<!-- 運営者が試した記録（読みもの） -->
	<section class="px-6 py-12 lg:py-16 bg-gray-50/30 border-b border-gray-50">
		<div class="max-w-4xl mx-auto">
			<div class="flex items-center justify-between mb-8">
				<div>
					<h2 class="text-lg lg:text-xl font-bold text-navy-900">運営者が試した記録（読みもの）</h2>
					<p class="text-xs text-gray-500 mt-1">困りごとに直面し、どのような工夫やツールを試したかのプロセスを綴っています。</p>
				</div>
				<a href="/logs/" class="text-xs font-bold text-mint-600 hover:underline flex items-center gap-1">すべての記録 <span class="material-symbols-outlined text-sm" aria-hidden="true">arrow_forward</span></a>
			</div>
			
			<div class="grid gap-6 md:grid-cols-3">
				{recentLogs.map((log) => (
					<a href={`/logs/${log.id}/`} class="flex flex-col bg-white border border-gray-200 rounded-2xl overflow-hidden hover:shadow-md transition-shadow group">
						{log.data.coverImage && (
							<div class="aspect-video w-full overflow-hidden bg-gray-100">
								<img src={log.data.coverImage} alt={log.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
							</div>
						)}
						<div class="p-5 flex-grow flex flex-col justify-between">
							<div>
								<span class="text-[0.7rem] font-bold text-gray-400">{log.data.pubDate.toLocaleDateString('ja-JP')}</span>
								<h3 class="font-bold text-navy-900 mt-1 leading-snug group-hover:text-mint-600 transition-colors line-clamp-2">{log.data.title}</h3>
								<p class="text-xs text-gray-500 mt-2 line-clamp-2 leading-relaxed">{log.data.problem}</p>
							</div>
							<span class="text-xs font-bold text-mint-600 mt-4 flex items-center gap-0.5">記事を読む <span class="material-symbols-outlined text-xs" aria-hidden="true">chevron_right</span></span>
						</div>
					</a>
				))}
			</div>
		</div>
	</section>

	<!-- 試した方法（下位分類） -->
	<section class="px-6 py-12 lg:py-16 border-b border-gray-50">
		<div class="max-w-4xl mx-auto">
			<div class="flex items-center justify-between mb-8">
				<div>
					<h2 class="text-lg lg:text-xl font-bold text-navy-900">試した方法</h2>
					<p class="text-xs text-gray-500 mt-1">検証済みの工夫・アプリ・商品を、カテゴリーごとに探せます。</p>
				</div>
				<a href="/methods/" class="text-xs font-bold text-mint-600 hover:underline flex items-center gap-1">すべての方法を横断して見る <span class="material-symbols-outlined text-sm" aria-hidden="true">arrow_forward</span></a>
			</div>
			
			<div class="grid gap-6 md:grid-cols-3">
				<a href="/knowhow/" class="flex flex-col bg-white border border-gray-200 rounded-2xl p-6 hover:bg-mint-50/20 hover:border-mint-200 transition-all group">
					<div class="w-12 h-12 rounded-xl bg-mint-50 text-mint-600 flex items-center justify-center mb-4 group-hover:scale-105 transition-transform">
						<span class="material-symbols-outlined text-2xl" aria-hidden="true">rule</span>
					</div>
					<h3 class="font-bold text-navy-900">家庭で試した工夫・仕組み</h3>
					<p class="text-xs text-gray-500 mt-2 leading-relaxed flex-grow">
						日曜の予定確認ルールや、玄関のチェックリストなど、家庭内で再現できる工夫や仕組みです。
					</p>
					<span class="text-xs font-bold text-mint-600 mt-4 flex items-center gap-0.5">一覧を見る <span class="material-symbols-outlined text-xs" aria-hidden="true">chevron_right</span></span>
				</a>
				
				<a href="/apps/" class="flex flex-col bg-white border border-gray-200 rounded-2xl p-6 hover:bg-mint-50/20 hover:border-mint-200 transition-all group">
					<div class="w-12 h-12 rounded-xl bg-mint-50 text-mint-600 flex items-center justify-center mb-4 group-hover:scale-105 transition-transform">
						<span class="material-symbols-outlined text-2xl" aria-hidden="true">edit_document</span>
					</div>
					<h3 class="font-bold text-navy-900">使ってみたアプリ・サービス</h3>
					<p class="text-xs text-gray-500 mt-2 leading-relaxed flex-grow">
						LINE、Notion、TimeTree、Googleカレンダーなど、実際に育児で使用したアプリの運用事例です。
					</p>
					<span class="text-xs font-bold text-mint-600 mt-4 flex items-center gap-0.5">一覧を見る <span class="material-symbols-outlined text-xs" aria-hidden="true">chevron_right</span></span>
				</a>

				<a href="/items/" class="flex flex-col bg-white border border-gray-200 rounded-2xl p-6 hover:bg-mint-50/20 hover:border-mint-200 transition-all group">
					<div class="w-12 h-12 rounded-xl bg-mint-50 text-mint-600 flex items-center justify-center mb-4 group-hover:scale-105 transition-transform">
						<span class="material-symbols-outlined text-2xl" aria-hidden="true">shopping_bag</span>
					</div>
					<h3 class="font-bold text-navy-900">使ってみたアイテム</h3>
					<p class="text-xs text-gray-500 mt-2 leading-relaxed flex-grow">
						おむつポーチや調乳用品など、具体的な困りごとに対して導入した商品や道具の実体験です。
					</p>
					<span class="text-xs font-bold text-mint-600 mt-4 flex items-center gap-0.5">一覧を見る <span class="material-symbols-outlined text-xs" aria-hidden="true">chevron_right</span></span>
				</a>
			</div>
		</div>
	</section>

	<!-- サイトの注意事項 (免責) -->
	<section class="px-6 py-10 lg:py-16 max-w-4xl mx-auto">
		<div class="bg-orange-50 border border-orange-100 rounded-2xl p-6 flex gap-4 items-start">
			<span class="material-symbols-outlined text-orange-400 text-3xl shrink-0" aria-hidden="true">warning</span>
			<div>
				<h2 class="text-[0.95rem] font-bold text-navy-900 mb-2">
					{UI.disclaimer.homeCardTitle}
				</h2>
				<p class="text-[0.8rem] text-gray-600 leading-relaxed">
					{UI.disclaimer.homeCardDesc} 詳しくは<a href="/disclaimer/" class="font-bold text-navy-900 underline underline-offset-4">免責事項</a>をご確認ください。
				</p>
			</div>
		</div>
	</section>
</Layout>
