---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.hero {
				padding: 2rem 1.5rem 1rem;
			}
			.hero-title {
				font-size: 1.75rem;
				line-height: 1.4;
				font-weight: 700;
				margin-bottom: 1rem;
				color: var(--text-heading);
			}
			.hero-desc {
				font-size: 0.85rem;
				color: var(--text-muted);
				margin-bottom: 2rem;
				line-height: 1.6;
			}
			.hero-buttons {
				display: flex;
				gap: 1rem;
			}
			
			/* 今週の実験 */
			.section-container {
				padding: 1.5rem;
			}
			.section-header {
				display: flex;
				justify-content: space-between;
				align-items: center;
				margin-bottom: 1rem;
			}
			.section-title {
				font-size: 1.1rem;
				font-weight: 700;
			}
			.link-see-all {
				font-size: 0.8rem;
				color: var(--accent-mint);
				display: flex;
				align-items: center;
				gap: 0.25rem;
			}
			
			.exp-row {
				display: flex;
				gap: 1rem;
				margin-bottom: 1rem;
				align-items: flex-start;
			}
			.exp-row:last-child {
				margin-bottom: 0;
			}
			.exp-icon {
				color: var(--text-muted);
				font-size: 1.25rem;
				margin-top: 0.1rem;
			}
			.exp-label {
				font-size: 0.8rem;
				color: var(--text-muted);
				width: 4rem;
				flex-shrink: 0;
			}
			.exp-value {
				font-size: 0.85rem;
				font-weight: 500;
				color: var(--text-heading);
			}
			
			/* 無料ツールグリッド */
			.tools-grid {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 1rem;
			}
			.tool-item {
				display: flex;
				flex-direction: column;
				align-items: center;
				text-align: center;
				gap: 0.5rem;
			}
			.tool-icon-circle {
				width: 56px;
				height: 56px;
				border-radius: 50%;
				background-color: var(--bg-mint-light);
				color: var(--accent-mint);
				display: flex;
				align-items: center;
				justify-content: center;
			}
			.tool-icon-circle .material-symbols-outlined {
				font-size: 1.75rem;
			}
			.tool-name {
				font-size: 0.8rem;
				font-weight: 600;
				line-height: 1.3;
			}
			
			/* 新着実験ログ */
			.log-list {
				display: flex;
				flex-direction: column;
			}
			.log-item {
				padding: 1rem 0;
				border-bottom: 1px solid var(--border-light);
				display: flex;
				justify-content: space-between;
				align-items: center;
			}
			.log-item:last-child {
				border-bottom: none;
			}
			.log-content {
				display: flex;
				flex-direction: column;
				gap: 0.25rem;
			}
			.log-num {
				font-size: 0.65rem;
				color: var(--text-muted);
				font-weight: 600;
			}
			.log-title {
				font-size: 0.9rem;
				font-weight: 600;
				line-height: 1.4;
			}
			.log-date {
				font-size: 0.75rem;
				color: var(--text-muted);
			}
			.log-arrow {
				color: var(--text-muted);
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h2 class="hero-title">育児の正解は語れない。<br/>だから、困ったことを<br/>小さな道具にして<br/>試してみる。</h2>
				<p class="hero-desc">0歳育児の困りごとを、週5時間だけでテンプレ・メモ・小さなWebツールにして試す実験ログ。</p>
				<div class="hero-buttons">
					<a href="/logs" class="btn-primary">
						実験ログを見る <span class="material-symbols-outlined" style="font-size: 1.1rem">chevron_right</span>
					</a>
					<a href="/tools" class="btn-outline">
						無料ツールを見る <span class="material-symbols-outlined" style="font-size: 1.1rem">chevron_right</span>
					</a>
				</div>
			</section>

			<section class="section-container">
				<h3 class="section-title">今週の実験</h3>
				<div class="card mt-2">
					<div class="exp-row">
						<span class="material-symbols-outlined exp-icon">description</span>
						<span class="exp-label">困りごと</span>
						<span class="exp-value">夜中のミルク対応を忘れてしまう</span>
					</div>
					<div class="exp-row">
						<span class="material-symbols-outlined exp-icon">edit</span>
						<span class="exp-label">作ったもの</span>
						<span class="exp-value">夜間対応メモ</span>
					</div>
					<div class="exp-row">
						<span class="material-symbols-outlined exp-icon">check_circle</span>
						<span class="exp-label">結果</span>
						<span class="exp-value">メモを見て思い出せる回数が増えた</span>
					</div>
				</div>
			</section>

			<section class="section-container">
				<div class="section-header">
					<h3 class="section-title">無料で使える小さな道具</h3>
					<a href="/tools" class="link-see-all">すべて見る <span class="material-symbols-outlined" style="font-size: 1rem">chevron_right</span></a>
				</div>
				<div class="tools-grid mt-2">
					<a href="/tools/1" class="tool-item">
						<div class="tool-icon-circle">
							<span class="material-symbols-outlined">baby_changing_station</span>
						</div>
						<span class="tool-name">授乳・ミルク・<br/>睡眠メモ</span>
					</a>
					<a href="/tools/2" class="tool-item">
						<div class="tool-icon-circle">
							<span class="material-symbols-outlined">description</span>
						</div>
						<span class="tool-name">夜間対応<br/>メモ</span>
					</a>
					<a href="/tools/3" class="tool-item">
						<div class="tool-icon-circle">
							<span class="material-symbols-outlined">group</span>
						</div>
						<span class="tool-name">夫婦共有<br/>ログ</span>
					</a>
					<a href="/tools/4" class="tool-item">
						<div class="tool-icon-circle">
							<span class="material-symbols-outlined">medical_services</span>
						</div>
						<span class="tool-name">予防接種<br/>チェック表</span>
					</a>
				</div>
			</section>

			<section class="section-container">
				<div class="section-header">
					<h3 class="section-title">新着実験ログ</h3>
					<a href="/logs" class="link-see-all">すべて見る <span class="material-symbols-outlined" style="font-size: 1rem">chevron_right</span></a>
				</div>
				<div class="log-list mt-2">
					<a href="/logs/1" class="log-item">
						<div class="log-content">
							<span class="log-num">#001</span>
							<span class="log-title">夜中のミルク対応、朝になると記憶があいまい</span>
							<span class="log-date">2024/05/12</span>
						</div>
						<span class="material-symbols-outlined log-arrow">chevron_right</span>
					</a>
					<a href="/logs/2" class="log-item">
						<div class="log-content">
							<span class="log-num">#002</span>
							<span class="log-title">予防接種の予定が頭に入らない問題</span>
							<span class="log-date">2024/05/10</span>
						</div>
						<span class="material-symbols-outlined log-arrow">chevron_right</span>
					</a>
				</div>
			</section>

		</main>
		<Footer />
	</body>
</html>
