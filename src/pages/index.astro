---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import {
	SITE_TITLE,
	SITE_DESCRIPTION,
} from "../consts";
import { UI } from "../i18n/ja";

const logs =
	await getCollection(
		"logs",
	);
logs.sort(
	(
		a,
		b,
	) =>
		b.data.logNumber.localeCompare(
			a
				.data
				.logNumber,
		),
);
const recentLogs =
	logs.slice(
		0,
		3,
	); // Changed to 3 rows as requested

const knowhow = await getCollection('knowhow');
knowhow.sort((a, b) => a.data.order - b.data.order);
const firstKnowhow = knowhow.slice(0, 4);

const apps = await getCollection('apps');
apps.sort((a, b) => a.data.order - b.data.order);
const firstApps = apps.slice(0, 4);

const items = await getCollection('items');
items.sort((a, b) => a.data.order - b.data.order);
const firstItems = items.slice(0, 4);

---

<Layout
	title={SITE_TITLE}
	description={SITE_DESCRIPTION}
>
	<section
		class="px-6 pt-12 pb-16 lg:pt-24 lg:pb-28 bg-[url('/hero-bg.png')] bg-cover bg-right bg-no-repeat relative"
	>
		<!-- Gradient overlay: Solid white at top for title readability, fading to transparent for image visibility -->
		<div
			class="absolute inset-0 bg-gradient-to-b from-white via-white/80 to-white/30 backdrop-blur-[2px] sm:bg-none sm:bg-transparent sm:backdrop-blur-none"
		>
		</div>

		<div
			class="relative z-10 max-w-2xl"
		>
			<h2
				class="text-[1.75rem] lg:text-[2.5rem] leading-tight font-bold mb-6 text-navy-900"
				set:html={UI
					.home
					.heroTitle}
			/>
			{UI.home.heroDesc && (
				<p
					class="text-[0.85rem] lg:text-base text-gray-700 mb-8 leading-relaxed max-w-lg font-medium"
					set:html={UI.home.heroDesc}
				/>
			)}
			<div class="flex flex-col sm:flex-row gap-4">
				<a
					href="/knowhow"
					class="inline-flex items-center justify-center gap-2 bg-mint-500 hover:bg-mint-600 text-white py-3 px-8 rounded-full text-sm font-semibold transition-colors"
				>
					{UI.home.btnTools}
				</a>
			</div>
		</div>
	</section>

	<!-- 今週の工夫 (非表示) -->
	{/* 
	<section
		class="px-6 py-6 lg:py-10"
	>
		...
	</section>
	*/}

	
	
	<!-- knowhowTitle -->
	<section class="px-6 py-6 lg:py-10">
		<div class="flex justify-between items-center mb-4 lg:mb-6">
			<h3 class="text-[1.1rem] lg:text-[1.25rem] font-bold text-navy-900">
				{UI.home.knowhowTitle}
			</h3>
		</div>
		<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-6">
			{firstKnowhow.map((item) => (
				<a href={`/knowhow/${item.id}/`} class="flex flex-col bg-white border border-gray-200 rounded-2xl p-6 hover:bg-gray-50 transition-colors group relative">
					<div class="w-14 h-14 rounded-full bg-mint-50 text-mint-500 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
						<span class="material-symbols-outlined text-[1.75rem]">{item.data.icon}</span>
					</div>
					<h4 class="text-[0.95rem] font-bold mb-2 text-navy-900">{item.data.title}</h4>
					<p class="text-[0.8rem] text-gray-500 leading-relaxed mb-4" set:html={item.data.description.replace('。', '。<br/>')} />
				</a>
			))}
		</div>
	</section>

	<!-- appsTitle -->
	<section class="px-6 py-6 lg:py-10">
		<div class="flex justify-between items-center mb-4 lg:mb-6">
			<h3 class="text-[1.1rem] lg:text-[1.25rem] font-bold text-navy-900">
				{UI.home.appsTitle}
			</h3>
		</div>
		<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-6">
			{firstApps.map((item) => (
				<a href={`/apps/${item.id}/`} class="flex flex-col bg-white border border-gray-200 rounded-2xl p-6 hover:bg-gray-50 transition-colors group relative">
					<div class="w-14 h-14 rounded-full bg-mint-50 text-mint-500 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
						<span class="material-symbols-outlined text-[1.75rem]">{item.data.icon}</span>
					</div>
					<h4 class="text-[0.95rem] font-bold mb-2 text-navy-900">{item.data.title}</h4>
					<p class="text-[0.8rem] text-gray-500 leading-relaxed mb-4" set:html={item.data.description.replace('。', '。<br/>')} />
				</a>
			))}
		</div>
	</section>

	<!-- itemsTitle -->
	<section class="px-6 py-6 lg:py-10">
		<div class="flex justify-between items-center mb-4 lg:mb-6">
			<h3 class="text-[1.1rem] lg:text-[1.25rem] font-bold text-navy-900">
				{UI.home.itemsTitle}
			</h3>
		</div>
		<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-6">
			{firstItems.map((item) => (
				<a href={`/items/${item.id}/`} class="flex flex-col bg-white border border-gray-200 rounded-2xl p-6 hover:bg-gray-50 transition-colors group relative">
					<div class="w-14 h-14 rounded-full bg-mint-50 text-mint-500 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
						<span class="material-symbols-outlined text-[1.75rem]">{item.data.icon}</span>
					</div>
					<h4 class="text-[0.95rem] font-bold mb-2 text-navy-900">{item.data.title}</h4>
					<p class="text-[0.8rem] text-gray-500 leading-relaxed mb-4" set:html={item.data.description.replace('。', '。<br/>')} />
				</a>
			))}
		</div>
	</section>

	<!-- 免責カード -->
	<section
		class="px-6 py-10 lg:py-16"
	>
		<div
			class="bg-orange-50 border border-orange-100 rounded-2xl p-6 flex gap-4 items-start"
		>
			<span
				class="material-symbols-outlined text-orange-400 text-2xl shrink-0"
				>shield</span
			>
			<div
			>
				<p
					class="text-sm font-bold text-orange-900 mb-1"
				>
					{
						UI
							.disclaimer
							.homeCardTitle
					}
				</p>
				<p
					class="text-xs text-orange-800"
				>
					{
						UI
							.disclaimer
							.homeCardDesc
					}
				</p>
			</div>
		</div>
	</section>
</Layout>
