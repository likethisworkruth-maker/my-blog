---
import '../../styles/global.css';
---
<!doctype html>
<html lang="ja">
<head>
  <meta charset="utf-8" /><meta name="viewport" content="width=device-width,initial-scale=1" />
  <meta name="robots" content="noindex,nofollow,noarchive" /><meta name="referrer" content="no-referrer" />
  <meta http-equiv="Cache-Control" content="no-store" /><title>回答の更新・削除</title>
</head>
<body class="bg-gray-50 text-gray-700"><main class="mx-auto min-h-screen max-w-2xl px-6 py-10 lg:py-16">
  <a href="/" class="font-bold text-navy-900">育児の困りごとメモ</a>
  <section class="mt-7 rounded-3xl border border-gray-200 bg-white p-6 lg:p-9">
    <h1 class="text-2xl font-bold text-navy-900">回答の更新・削除</h1><p class="mt-3 text-sm leading-7 text-gray-600">このページは、回答時に発行した編集URLを持っている方だけが利用できます。URLは外部へ共有しないでください。</p>
    <p data-loading class="mt-6 rounded-xl bg-gray-50 p-4 text-sm">回答を確認しています…</p><p data-error class="mt-6 text-sm font-bold text-red-600" role="alert"></p>
    <form data-edit-form class="mt-7 space-y-5" hidden>
      <label class="block text-sm font-bold">お子さんの年齢区分<select name="age_band" class="mt-2 w-full rounded-xl border border-gray-300 px-4 py-3 font-normal"><option value="">回答しない</option><option value="pregnancy">妊娠中</option><option value="0_5m">0〜5か月</option><option value="6_11m">6〜11か月</option><option value="1y">1歳</option><option value="2y">2歳</option><option value="3_5y">3〜5歳</option><option value="6y_plus">6歳以上</option></select></label>
      <label class="block text-sm font-bold">継続状況<select name="continuation_status" class="mt-2 w-full rounded-xl border border-gray-300 px-4 py-3 font-normal"><option value="">回答しない</option><option value="continuing">続けている</option><option value="sometimes">ときどき使う</option><option value="stopped">やめた</option><option value="not_started">まだ始めていない</option></select></label>
      <label class="block text-sm font-bold">使った期間<input name="usage_period" maxlength="80" class="mt-2 w-full rounded-xl border border-gray-300 px-4 py-3 font-normal" /></label>
      <label class="block text-sm font-bold">続けにくかった点<textarea name="difficulty_text" maxlength="500" rows="3" class="mt-2 w-full rounded-xl border border-gray-300 px-4 py-3 font-normal"></textarea></label>
      <label class="block text-sm font-bold">困っていた状況<textarea name="situation_text" maxlength="1000" rows="4" class="mt-2 w-full rounded-xl border border-gray-300 px-4 py-3 font-normal"></textarea></label>
      <label class="block text-sm font-bold">具体的な使い方<textarea name="usage_text" maxlength="1000" rows="4" class="mt-2 w-full rounded-xl border border-gray-300 px-4 py-3 font-normal"></textarea></label>
      <label class="block text-sm font-bold">良かった点<textarea name="good_points_text" maxlength="1000" rows="4" class="mt-2 w-full rounded-xl border border-gray-300 px-4 py-3 font-normal"></textarea></label>
      <label class="block text-sm font-bold">合いそうな家庭<textarea name="fit_household_text" maxlength="700" rows="3" class="mt-2 w-full rounded-xl border border-gray-300 px-4 py-3 font-normal"></textarea></label>
      <label class="block text-sm font-bold">次に見直すこと<textarea name="next_step_text" maxlength="700" rows="3" class="mt-2 w-full rounded-xl border border-gray-300 px-4 py-3 font-normal"></textarea></label>
      <button type="submit" class="rounded-full bg-mint-500 px-6 py-3 text-sm font-bold text-white">変更を保存</button><p data-status class="text-sm font-bold" role="status"></p>
    </form>
    <div data-delete-wrap class="mt-10 border-t border-gray-200 pt-7" hidden><h2 class="font-bold text-navy-900">回答を削除する</h2><p class="mt-2 text-sm leading-6 text-gray-600">削除すると、速やかに公開・集計対象から外れます。バックアップ等の保管期間を経た後に削除します。</p><button data-delete type="button" class="mt-4 rounded-full border border-red-300 px-5 py-2 text-sm font-bold text-red-600">回答を削除</button></div>
  </section>
</main>
<script>
  import { trialApi } from '../../lib/trialApi';
  const params = new URLSearchParams(location.hash.slice(1)); const id = params.get('id') ?? ''; const token = params.get('token') ?? '';
  const form = document.querySelector<HTMLFormElement>('[data-edit-form]')!; const error = document.querySelector<HTMLElement>('[data-error]')!; const loading = document.querySelector<HTMLElement>('[data-loading]')!; let version = 0;
  const fields = ['age_band','continuation_status','usage_period','difficulty_text','situation_text','usage_text','good_points_text','fit_household_text','next_step_text'];
  async function load() { try { if (!id || !token) throw new Error('編集URLが正しくありません。'); const data = await trialApi.getEditable(id, token); version = data.response.version; fields.forEach(name => { const control = form.elements.namedItem(name) as HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement | null; if (control) control.value = data.response[name] ?? ''; }); loading.hidden = true; form.hidden = false; document.querySelector<HTMLElement>('[data-delete-wrap]')!.hidden = false; } catch (e) { loading.hidden = true; error.textContent = e instanceof Error ? e.message : '回答を確認できませんでした。'; } }
  form.addEventListener('submit', async (event) => { event.preventDefault(); const status = document.querySelector<HTMLElement>('[data-status]')!; const payload = Object.fromEntries([...new FormData(form)].map(([k,v]) => [k,String(v).trim()])); try { const result = await trialApi.update(id, token, version, payload); version = result.version; status.className = 'text-sm font-bold text-mint-600'; status.textContent = '変更を保存しました。確認後に公開・集計へ反映します。'; } catch (e) { status.className = 'text-sm font-bold text-red-600'; status.textContent = e instanceof Error ? e.message : '保存できませんでした。'; } });
  document.querySelector('[data-delete]')?.addEventListener('click', async () => { if (!confirm('この回答を削除します。よろしいですか？')) return; try { await trialApi.delete(id, token); form.hidden = true; document.querySelector<HTMLElement>('[data-delete-wrap]')!.hidden = true; error.className = 'mt-6 text-sm font-bold text-mint-600'; error.textContent = '回答を削除しました。公開集計から速やかに除外されます。'; history.replaceState(null, '', location.pathname); } catch (e) { error.textContent = e instanceof Error ? e.message : '削除できませんでした。'; } });
  load();
</script>
</body></html>
