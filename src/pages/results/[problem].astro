---
import Layout from '../../layouts/Layout.astro';
import ResultSummary from '../../components/results/ResultSummary.astro';
import ShareResultCard from '../../components/results/ShareResultCard.astro';
import { loadInitialTrialCatalog } from '../../data/trialRepository';
export async function getStaticPaths() { const catalog = await loadInitialTrialCatalog(); return [{ params: { problem: catalog.problem.slug }, props: catalog }]; }
const { problem: initialProblem } = Astro.props;
---
<Layout title={`回答結果：${initialProblem.title}`} description="審査済みの回答を少数データ保護ルールに沿って集計します。"><section class="px-6 py-12 lg:py-20"><div class="mx-auto max-w-3xl"><p class="text-sm font-bold text-mint-600">回答結果</p><h1 class="mt-2 text-2xl font-bold leading-relaxed text-navy-900">{initialProblem.questionText}</h1><div class="mt-7"><ResultSummary problemSlug={initialProblem.slug} /></div><div class="mt-6"><ShareResultCard problemSlug={initialProblem.slug} questionText={initialProblem.questionText} /></div><a href={`/answer/${initialProblem.slug}/`} class="mt-7 inline-block rounded-full bg-mint-500 px-7 py-3 font-bold text-white">あなたの家庭について回答する</a></div></section></Layout>
