---
import Layout from '../../layouts/Layout.astro';
import ResultSummary from '../../components/results/ResultSummary.astro';
import ShareResultCard from '../../components/results/ShareResultCard.astro';
import { loadInitialTrialCatalog } from '../../data/trialRepository';
export async function getStaticPaths() { const catalog = await loadInitialTrialCatalog(); return [{ params: { problem: catalog.problem.slug }, props: catalog }]; }
const { problem: initialProblem } = Astro.props;
---
<Layout title={`回答結果（内部テスト中）：${initialProblem.title}`} description="現在内部テスト中です。" noindex={true}><section class="px-6 py-12 lg:py-20"><div class="mx-auto max-w-3xl">
  <div class="mb-6 p-4 bg-orange-50 text-orange-600 rounded-xl text-sm font-bold flex items-center gap-2"><span class="material-symbols-outlined" aria-hidden="true">science</span>現在は集計機能の内部テスト中です。</div>
  <p class="text-sm font-bold text-mint-600">回答結果</p><h1 class="mt-2 text-2xl font-bold leading-relaxed text-navy-900">{initialProblem.questionText}</h1><div class="mt-7"><ResultSummary problemSlug={initialProblem.slug} /></div><div class="mt-6"><ShareResultCard problemSlug={initialProblem.slug} questionText={initialProblem.questionText} /></div><a href={`/answer/${initialProblem.slug}/`} class="mt-7 inline-block rounded-full bg-mint-500 px-7 py-3 font-bold text-white">あなたの家庭について回答する</a></div></section></Layout>
