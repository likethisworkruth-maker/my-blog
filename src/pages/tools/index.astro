---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';

const tools = await getCollection('tools');
tools.sort((a, b) => a.data.order - b.data.order);
---

<Layout title={`無料ツール | ${SITE_TITLE}`} description={SITE_DESCRIPTION}>
	
	<div class="px-6 py-8 lg:py-12">
		<!-- Header -->
		<div class="mb-8">
			<div class="text-[0.85rem] text-gray-400 mb-4 hidden lg:block">ホーム &gt; <span class="text-mint-500 font-bold">無料ツール</span></div>
			<h2 class="text-[1.5rem] lg:text-[2rem] font-bold text-navy-900 mb-2">無料ツール</h2>
			<p class="text-[0.85rem] lg:text-base text-gray-500">うちで試した小さなメモ・テンプレ・Webツール</p>
		</div>
		
		<!-- Hero Card -->
		<div class="bg-orange-50/50 rounded-2xl border border-orange-100 p-8 lg:p-12 mb-8 flex flex-col lg:flex-row items-center gap-8">
			<div class="flex-1 flex flex-col items-center lg:items-start text-center lg:text-left gap-4">
				<div class="w-16 h-16 rounded-full bg-mint-50 text-mint-500 flex items-center justify-center shrink-0">
					<span class="material-symbols-outlined text-[2rem]">build</span>
				</div>
				<div>
					<h3 class="text-[1.25rem] lg:text-[1.5rem] font-bold text-navy-900 mb-2">無料ツール一覧</h3>
					<p class="text-[0.9rem] lg:text-base text-gray-600 leading-relaxed max-w-sm">育児や夫婦の協力体制づくりに役立つツールを、すべて無料で使えます。</p>
				</div>
			</div>
			<!-- Right Illustration Placeholder -->
			<div class="hidden lg:flex w-64 h-48 bg-white border border-gray-100 shadow-sm rounded-xl items-center justify-center rotate-3">
				<span class="material-symbols-outlined text-gray-300 text-6xl">checklist</span>
			</div>
		</div>
		
		<!-- Filters -->
		<div class="flex gap-3 overflow-x-auto pb-4 scrollbar-hide mb-8">
			<button class="px-5 py-2 rounded-full border border-mint-500 bg-mint-50 text-mint-500 text-sm font-bold whitespace-nowrap shrink-0">すべて</button>
			<button class="px-5 py-2 rounded-full border border-gray-200 bg-white text-gray-500 text-sm font-medium whitespace-nowrap shrink-0 hover:bg-gray-50 transition-colors">メモ</button>
			<button class="px-5 py-2 rounded-full border border-gray-200 bg-white text-gray-500 text-sm font-medium whitespace-nowrap shrink-0 hover:bg-gray-50 transition-colors">テンプレ</button>
			<button class="px-5 py-2 rounded-full border border-gray-200 bg-white text-gray-500 text-sm font-medium whitespace-nowrap shrink-0 hover:bg-gray-50 transition-colors">Webツール</button>
			<button class="px-5 py-2 rounded-full border border-gray-200 bg-white text-gray-500 text-sm font-medium whitespace-nowrap shrink-0 hover:bg-gray-50 transition-colors">0歳育児</button>
		</div>
		
		<!-- Tool Grid -->
		<div class="grid grid-cols-1 lg:grid-cols-2 gap-4 lg:gap-6">
			{tools.map((tool) => (
				<a href={`/tools/${tool.id}/`} class="flex flex-col sm:flex-row items-center gap-6 bg-white rounded-2xl border border-gray-200 shadow-sm p-6 lg:p-8 hover:shadow-md transition-shadow relative group">
					<div class="w-20 h-20 rounded-full bg-orange-50 text-orange-400 flex items-center justify-center shrink-0 border border-orange-100">
						<span class="material-symbols-outlined text-4xl">{tool.data.icon}</span>
					</div>
					<div class="flex-grow pr-12 text-center sm:text-left">
						<h3 class="text-[1.1rem] lg:text-[1.25rem] font-bold mb-2 text-navy-900">{tool.data.title}</h3>
						<p class="text-[0.85rem] lg:text-sm text-gray-500 leading-relaxed" set:html={tool.data.description.replace('。', '。<br/>')} />
					</div>
					{tool.data.isFree && <span class="absolute top-6 right-6 bg-mint-50 text-mint-500 font-bold text-[0.7rem] px-3 py-1 rounded-full">無料</span>}
					<span class="material-symbols-outlined absolute right-6 bottom-1/2 translate-y-1/2 text-gray-300 group-hover:text-mint-500 transition-colors hidden sm:block">arrow_forward_ios</span>
				</a>
			))}
		</div>
	</div>
</Layout>

<style>
	.scrollbar-hide::-webkit-scrollbar {
		display: none;
	}
	.scrollbar-hide {
		-ms-overflow-style: none;
		scrollbar-width: none;
	}
</style>
