---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import {
	SITE_TITLE,
	SITE_DESCRIPTION,
} from "../../consts";
import { UI } from "../../i18n/ja";

const tools =
	await getCollection(
		"tools",
	);
tools.sort(
	(
		a,
		b,
	) =>
		a
			.data
			.order -
		b
			.data
			.order,
);

const uniqueCategories =
	[
		...new Set(
			tools.flatMap(
				(
					tool,
				) =>
					tool
						.data
						.categories ||
					[],
			),
		),
	];
const displayCategories =
	uniqueCategories.length >
	0
		? [
				"すべて",
				...uniqueCategories,
			]
		: [
				"すべて",
				"メモ",
				"テンプレ",
				"アプリ",
				"0歳育児",
			];

const uniqueAges =
	[
		...new Set(
			tools
				.map(
					(
						tool,
					) =>
						tool
							.data
							.childAgeMonths,
				)
				.filter(
					(
						age,
					) =>
						age !==
						undefined,
				),
		),
	].sort(
		(
			a,
			b,
		) =>
			a! -
			b!,
	);
---

<Layout
	title={`${UI.tools.pageTitle} | ${SITE_TITLE}`}
	description={SITE_DESCRIPTION}
>
	<div
		class="px-6 py-8 lg:py-12"
	>
		<h2
			class="text-[1.5rem] lg:text-[2rem] font-bold text-navy-900 mb-6"
		>
			{
				UI
					.tools
					.pageTitle
			}
		</h2>

		<div
			class="flex flex-col lg:flex-row gap-4 mb-8 items-start lg:items-center justify-between"
		>
			<!-- Categories -->
			<div
				class="flex gap-3 overflow-x-auto pb-2 lg:pb-0 scrollbar-hide w-full lg:w-auto"
				id="category-filters"
			>
				{
					displayCategories.map(
						(
							category,
							index,
						) => (
							<button
								class={`category-btn px-4 py-2 rounded-full border text-sm whitespace-nowrap shrink-0 transition-colors ${index === 0 ? "border-mint-500 bg-mint-50 text-mint-500 font-bold" : "border-gray-200 bg-white text-gray-500 font-medium hover:bg-gray-50"}`}
								data-category={
									category
								}
							>
								{
									category
								}
							</button>
						),
					)
				}
			</div>

			<!-- Age & Sort -->
			<div
				class="flex gap-3 w-full lg:w-auto shrink-0"
			>
				<select
					id="age-filter"
					class="flex-1 lg:flex-none border border-gray-200 rounded-lg px-3 py-2 text-sm text-gray-700 bg-white focus:outline-none focus:border-mint-500"
				>
					<option
						value="all"
						>すべての対象</option
					>
					{
						uniqueAges.map(
							(
								age,
							) => (
								<option
									value={age.toString()}
								>
									生後
									{
										age
									}
									ヶ月向け
								</option>
							),
						)
					}
					<option
						value="none"
						>月齢未指定</option
					>
				</select>

				<select
					id="sort-order"
					class="flex-1 lg:flex-none border border-gray-200 rounded-lg px-3 py-2 text-sm text-gray-700 bg-white focus:outline-none focus:border-mint-500"
				>
					<option
						value="recommended"
						>おすすめ順</option
					>
					<option
						value="age-asc"
						>月齢が低い順</option
					>
					<option
						value="age-desc"
						>月齢が高い順</option
					>
				</select>
			</div>
		</div>

		<!-- Tool Grid -->
		<div
			class="grid grid-cols-1 lg:grid-cols-2 gap-4 lg:gap-6"
			id="tools-container"
		>
			{
				tools.map(
					(
						tool,
					) => (
						<a
							href={`/tools/${tool.id}/`}
							class="tool-card flex flex-col sm:flex-row items-center gap-6 bg-white rounded-2xl border border-gray-200 p-6 lg:p-8 hover:bg-gray-50 transition-colors relative group"
							data-categories={(
								tool
									.data
									.categories ||
								[]
							).join(
								",",
							)}
							data-age={
								tool
									.data
									.childAgeMonths ??
								"none"
							}
							data-order={
								tool
									.data
									.order
							}
						>
							<div class="w-20 h-20 rounded-full bg-orange-50 text-orange-400 flex items-center justify-center shrink-0 border border-orange-100">
								<span class="material-symbols-outlined text-4xl">
									{
										tool
											.data
											.icon
									}
								</span>
							</div>
							<div class="flex-grow pr-12 text-center sm:text-left">
								<div class="flex items-center justify-center sm:justify-start gap-2 mb-2">
									<h3 class="text-[1.1rem] lg:text-[1.25rem] font-bold text-navy-900">
										{
											tool
												.data
												.title
										}
									</h3>
									{tool
										.data
										.childAgeMonths !==
										undefined && (
										<span class="bg-gray-100 text-gray-600 px-2 py-0.5 rounded text-[0.7rem] font-bold shrink-0">
											生後
											{
												tool
													.data
													.childAgeMonths
											}
											ヶ月
										</span>
									)}
								</div>
								<p
									class="text-[0.85rem] lg:text-sm text-gray-500 leading-relaxed"
									set:html={tool.data.description.replace(
										"。",
										"。<br/>",
									)}
								/>
							</div>
							{tool
								.data
								.isFree && (
								<span class="absolute top-6 right-6 bg-mint-50 text-mint-500 font-bold text-[0.7rem] px-3 py-1 rounded-full">
									{
										UI
											.common
											.freeBadge
									}
								</span>
							)}
							<span class="material-symbols-outlined absolute right-6 bottom-1/2 translate-y-1/2 text-gray-300 group-hover:text-mint-500 transition-colors hidden sm:block">
								arrow_forward_ios
							</span>
						</a>
					),
				)
			}
		</div>
	</div>
</Layout>

<script
>
	const categoryButtons =
		document.querySelectorAll(
			".category-btn",
		);
	const ageFilter =
		document.getElementById(
			"age-filter",
		) as HTMLSelectElement;
	const sortOrder =
		document.getElementById(
			"sort-order",
		) as HTMLSelectElement;
	const toolsContainer =
		document.getElementById(
			"tools-container",
		);
	const cards =
		Array.from(
			document.querySelectorAll(
				".tool-card",
			),
		) as HTMLElement[];

	let currentCategory =
		"すべて";
	let currentAge =
		"all";
	let currentSort =
		"recommended";

	function updateView() {
		// Filter
		cards.forEach(
			(
				card,
			) => {
				const categoryMatch =
					currentCategory ===
						"すべて" ||
					(
						card.getAttribute(
							"data-categories",
						) ||
						""
					)
						.split(
							",",
						)
						.includes(
							currentCategory,
						);
				const ageMatch =
					currentAge ===
						"all" ||
					card.getAttribute(
						"data-age",
					) ===
						currentAge;

				if (
					categoryMatch &&
					ageMatch
				) {
					card.style.display =
						"flex";
				} else {
					card.style.display =
						"none";
				}
			},
		);

		// Sort
		const visibleCards =
			cards.filter(
				(
					card,
				) =>
					card
						.style
						.display !==
					"none",
			);
		const hiddenCards =
			cards.filter(
				(
					card,
				) =>
					card
						.style
						.display ===
					"none",
			);

		visibleCards.sort(
			(
				a,
				b,
			) => {
				if (
					currentSort ===
					"recommended"
				) {
					const numA =
						parseInt(
							a.getAttribute(
								"data-order",
							) ||
								"0",
							10,
						);
					const numB =
						parseInt(
							b.getAttribute(
								"data-order",
							) ||
								"0",
							10,
						);
					return (
						numA -
						numB
					);
				} else {
					const ageA =
						a.getAttribute(
							"data-age",
						);
					const ageB =
						b.getAttribute(
							"data-age",
						);
					const valA =
						ageA ===
						"none"
							? Infinity
							: parseInt(
									ageA ||
										"0",
									10,
								);
					const valB =
						ageB ===
						"none"
							? Infinity
							: parseInt(
									ageB ||
										"0",
									10,
								);

					if (
						currentSort ===
						"age-asc"
					) {
						return (
							valA -
							valB
						);
					} else {
						// age-desc
						if (
							valA ===
								Infinity &&
							valB !==
								Infinity
						)
							return 1;
						if (
							valB ===
								Infinity &&
							valA !==
								Infinity
						)
							return -1;
						return (
							valB -
							valA
						);
					}
				}
			},
		);

		// Re-append to DOM in order
		if (
			toolsContainer
		) {
			visibleCards.forEach(
				(
					card,
				) =>
					toolsContainer.appendChild(
						card,
					),
			);
			hiddenCards.forEach(
				(
					card,
				) =>
					toolsContainer.appendChild(
						card,
					),
			);
		}
	}

	categoryButtons.forEach(
		(
			button,
		) => {
			button.addEventListener(
				"click",
				() => {
					currentCategory =
						button.getAttribute(
							"data-category",
						) ||
						"すべて";

					// Update button styles
					categoryButtons.forEach(
						(
							btn,
						) => {
							btn.classList.remove(
								"border-mint-500",
								"bg-mint-50",
								"text-mint-500",
								"font-bold",
							);
							btn.classList.add(
								"border-gray-200",
								"bg-white",
								"text-gray-500",
								"font-medium",
							);
						},
					);
					button.classList.remove(
						"border-gray-200",
						"bg-white",
						"text-gray-500",
						"font-medium",
					);
					button.classList.add(
						"border-mint-500",
						"bg-mint-50",
						"text-mint-500",
						"font-bold",
					);

					updateView();
				},
			);
		},
	);

	ageFilter?.addEventListener(
		"change",
		(
			e,
		) => {
			currentAge =
				(
					e.target as HTMLSelectElement
				)
					.value;
			updateView();
		},
	);

	sortOrder?.addEventListener(
		"change",
		(
			e,
		) => {
			currentSort =
				(
					e.target as HTMLSelectElement
				)
					.value;
			updateView();
		},
	);
</script>

<style
>
	.scrollbar-hide::-webkit-scrollbar {
		display: none;
	}
	.scrollbar-hide {
		-ms-overflow-style: none;
		scrollbar-width: none;
	}
</style>
