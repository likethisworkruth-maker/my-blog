---
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import LikeButton from "../../components/LikeButton.astro";
import Comments from "../../components/Comments.astro";
import { SITE_TITLE } from "../../consts";
import { UI } from "../../i18n/ja";

export async function getStaticPaths() {
	const tools = await getCollection("tools");
	return tools.map((tool) => ({
		params: { id: tool.id },
		props: { tool },
	}));
}

const { tool } = Astro.props;
const { Content } = await render(tool);
---

<Layout
	title={`${tool.data.title} | ${SITE_TITLE}`}
	description={tool.data.description}
>
	<!-- Top Image Area (Full width on mobile, rounded on PC) -->
	<div class="w-full max-w-5xl mx-auto lg:mt-8 lg:px-6">
		<div class="w-full aspect-video lg:rounded-2xl bg-mint-50 flex items-center justify-center overflow-hidden border-b lg:border border-gray-200">
			{tool.data.coverImage ? (
				<img src={tool.data.coverImage} alt={tool.data.title} class="w-full h-full object-cover" />
			) : (
				<span class="material-symbols-outlined text-mint-200 text-5xl">image</span>
			)}
		</div>
	</div>

	<div class="px-6 py-6 lg:py-8 max-w-5xl mx-auto">
		
		<div class="bg-white rounded-2xl border-none lg:border lg:border-gray-200 shadow-none lg:p-10 mb-8">
			<!-- Header inside card -->
			<div class="pb-8 border-b border-gray-100 mb-8">
				<div class="flex items-center gap-2 text-gray-400 font-bold text-[0.85rem] mb-3">
					{tool.data.categories && tool.data.categories.join(', ')}
					{tool.data.childAgeMonths !== undefined && (tool.data.categories ? ` • 生後${tool.data.childAgeMonths}ヶ月` : `生後${tool.data.childAgeMonths}ヶ月`)}
				</div>
				<h1 class="text-[1.5rem] lg:text-[2rem] font-bold leading-tight mb-2 text-navy-900">{tool.data.title}</h1>
				<p class="text-gray-600 text-[0.95rem] lg:text-[1.1rem] leading-relaxed mt-4 mb-6">
					{tool.data.description}
				</p>
				
				<div class="flex flex-col sm:flex-row gap-4 w-full sm:w-auto">
					{tool.data.actionUrl ? (
						<a
							href={tool.data.actionUrl}
							target="_blank"
							rel="noopener noreferrer"
							class="bg-mint-500 hover:bg-mint-600 text-white font-bold py-3 px-8 rounded-full transition-colors flex items-center justify-center gap-2 w-full sm:w-auto"
						>
							{tool.data.actionText || UI.tools.btnTry}
							<span class="material-symbols-outlined text-[1.1rem]">chevron_right</span>
						</a>
					) : (
						<button
							class="bg-mint-500 hover:bg-mint-600 text-white font-bold py-3 px-8 rounded-full transition-colors flex items-center justify-center gap-2 w-full sm:w-auto"
						>
							{tool.data.actionText || UI.tools.btnTry}
							<span class="material-symbols-outlined text-[1.1rem]">chevron_right</span>
						</button>
					)}
					<a
						href="/logs"
						class="bg-white border border-mint-500 hover:bg-mint-50 text-mint-500 font-bold py-3 px-8 rounded-full transition-colors flex items-center justify-center gap-2"
					>
						<span class="material-symbols-outlined text-[1.1rem]">menu_book</span>
						{UI.tools.btnReadLog}
					</a>
				</div>
			</div>
			
			<!-- Content Area -->
			<div class="content-area">
				<Content />
			</div>

			<!-- Action Bar (Bottom of Content) -->
			<div class="flex items-center justify-start gap-3 my-12 pt-8 border-t border-gray-100">
				<LikeButton slug={`tools/${tool.id}`} />
				<button 
					class="w-10 h-10 flex items-center justify-center text-gray-400 hover:text-gray-600 transition-colors active:scale-95 ml-2" 
					onclick="document.getElementById('comments').scrollIntoView({behavior: 'smooth'})"
				>
					<span class="material-symbols-outlined text-[1.5rem] font-light">chat_bubble</span>
				</button>
				<button 
					class="w-10 h-10 flex items-center justify-center text-gray-400 hover:text-gray-600 transition-colors active:scale-95" 
					onclick="if(window.openShareModal) window.openShareModal()"
				>
					<span class="material-symbols-outlined text-[1.5rem] font-light">ios_share</span>
				</button>
			</div>

			<Comments slug={`tools/${tool.id}`} />

		</div>
	</div>
</Layout>

<style>
	/* Standard Markdown Content Styles */
	.content-area {
		display: flex;
		flex-direction: column;
	}
	
	.content-area :global(> h3) {
		font-size: 1.25rem;
		font-weight: 700;
		color: var(--color-mint-500);
		margin: 2.5rem 0 1rem;
		padding-bottom: 0.5rem;
		border-bottom: 2px solid var(--color-mint-50);
	}

	.content-area :global(> p), .content-area :global(> ul) {
		margin-bottom: 1.5rem;
		line-height: 1.8;
		color: var(--color-gray-700);
	}

	.content-area :global(blockquote) {
		border-left: 4px solid var(--color-mint-200);
		background-color: var(--color-mint-50);
		padding: 1rem 1.5rem;
		margin: 1.5rem 0;
		border-radius: 0 8px 8px 0;
		color: var(--color-gray-700);
	}
</style>
