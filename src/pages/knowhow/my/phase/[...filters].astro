---
import KnowhowIndexPage from '../../../../components/KnowhowIndexPage.astro';

export function getStaticPaths() {
	const phases = ['pregnancy', '0-3', '4-6', '7-11', '1-plus'];
	const scenes = ['outing', 'medical', 'daily', 'travel', 'nursery', 'disaster'];
	return phases.flatMap((phase) => [
		{ params: { filters: phase } },
		...scenes.map((scene) => ({ params: { filters: `${phase}/scene/${scene}` } })),
	]);
}
---

<KnowhowIndexPage />
