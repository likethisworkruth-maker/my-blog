---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import ActionBar from "../../components/ActionBar.astro";
import Comments from "../../components/Comments.astro";
import {
	SITE_TITLE,
	SITE_DESCRIPTION,
} from "../../consts";
import { UI } from "../../i18n/ja";

const knowhow =
	await getCollection(
		"knowhow",
	);
knowhow.sort(
	(
		a,
		b,
	) =>
		a
			.data
			.order -
		b
			.data
			.order,
);

const uniqueCategories =
	[
		...new Set(
			knowhow.flatMap(
				(
					knowhow,
				) =>
					knowhow
						.data
						.categories ||
					[],
			),
		),
	];
const displayCategories =
	uniqueCategories.length >
	0
		? [
				"すべて",
				...uniqueCategories,
			]
		: [
				"すべて",
				"メモ",
				"テンプレ",
				"アプリ",
				"0歳育児",
			];

const uniqueAges =
	[
		...new Set(
			knowhow
				.map(
					(
						knowhow,
					) =>
						knowhow
							.data
							.childAgeMonths,
				)
				.filter(
					(
						age,
					) =>
						age !==
						undefined,
				),
		),
	].sort(
		(
			a,
			b,
		) =>
			a! -
			b!,
	);
---

<Layout
	title={`${UI.knowhow.pageTitle} | ${SITE_TITLE}`}
	description={SITE_DESCRIPTION}
>
	<div class="px-4 py-8 lg:py-12 max-w-xl mx-auto flex flex-col gap-8">
		<h2 class="text-[1.5rem] lg:text-[2rem] font-bold text-navy-900 mb-2">
			{UI.knowhow.pageTitle}
		</h2>

		<!-- Search Bar -->
		<div class="relative mb-2">
			<span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-gray-400">search</span>
			<input type="text" id="knowhow-search" placeholder="ノウハウを検索" class="w-full bg-white border border-gray-200 rounded-full py-3 pl-12 pr-4 text-[0.95rem] focus:outline-none focus:border-mint-500 shadow-sm transition-colors" />
		</div>

		<div class="flex flex-col gap-4 mb-4">
			<!-- Categories -->
			<div
				class="flex gap-2 overflow-x-auto pb-2 scrollbar-hide w-full"
				id="category-filters"
			>
				{
					displayCategories.map(
						(
							category,
							index,
						) => (
							<button
								class={`category-btn px-4 py-1.5 rounded-full border text-[0.85rem] whitespace-nowrap shrink-0 transition-colors ${index === 0 ? "border-mint-500 bg-mint-50 text-mint-500 font-bold" : "border-gray-200 bg-white text-gray-500 font-medium hover:bg-gray-50"}`}
								data-category={
									category
								}
							>
								{
									category
								}
							</button>
						),
					)
				}
			</div>

			<!-- Age & Sort -->
			<div
				class="flex gap-2 w-full"
			>
				<select
					id="age-filter"
					class="flex-1 border border-gray-200 rounded-lg px-3 py-2 text-[0.85rem] text-gray-700 bg-white focus:outline-none focus:border-mint-500"
				>
					<option
						value="all"
						>すべての対象</option
					>
					{
						uniqueAges.map(
							(
								age,
							) => (
								<option
									value={age.toString()}
								>
									生後
									{
										age
									}
									ヶ月向け
								</option>
							),
						)
					}
					<option
						value="none"
						>月齢未指定</option
					>
				</select>

				<select
					id="sort-order"
					class="flex-1 border border-gray-200 rounded-lg px-3 py-2 text-[0.85rem] text-gray-700 bg-white focus:outline-none focus:border-mint-500"
				>
					<option
						value="recommended"
						>おすすめ順</option
					>
					<option
						value="age-asc"
						>月齢が低い順</option
					>
					<option
						value="age-desc"
						>月齢が高い順</option
					>
				</select>
			</div>
		</div>

		<!-- Feed Container -->
		<div
			class="flex flex-col gap-10"
			id="knowhow-container"
		>
			{
				knowhow.map(
					(
						post,
					) => (
						<article 
							class="knowhow-card bg-white rounded-xl lg:border border-gray-200 lg:shadow-sm overflow-hidden"
							data-categories={(
								post
									.data
									.categories ||
								[]
							).join(
								",",
							)}
							data-age={
								post
									.data
									.childAgeMonths ??
								"none"
							}
							data-order={
								post
									.data
									.order
							}
						>
							<!-- Header Removed -->

							<!-- Main Image -->
							<div class="w-full bg-gray-50 flex items-center justify-center cursor-pointer border-y border-gray-100" onclick={`if(window.openModal) window.openModal('${post.id}')`}>
								{post.data.coverImage ? (
									<img src={post.data.coverImage} alt={post.data.title} class="w-full h-auto object-cover max-h-[60vh]" />
								) : (
									<div class="w-full h-64 flex items-center justify-center">
										<span class="material-symbols-outlined text-gray-300 text-5xl">image</span>
									</div>
								)}
							</div>

							<!-- Action Bar -->
							<div class="px-4">
								<ActionBar slug={`knowhow/${post.id}`} variant="feed" />
							</div>

							<!-- Caption -->
							<div class="px-4 pb-4">
								<p class="text-[0.9rem] text-navy-900 leading-snug">
									<span class="font-bold mr-1">{SITE_TITLE}</span>
									<span>{post.data.title}</span>
								</p>
								<p class="text-[0.85rem] text-gray-600 mt-1 line-clamp-2 leading-relaxed" set:text={post.data.description}></p>
								<button class="text-gray-400 text-[0.85rem] mt-1.5 hover:text-gray-600" onclick={`if(window.openModal) window.openModal('${post.id}')`}>
									続きを読む...
								</button>
							</div>
						</article>
					),
				)
			}
		</div>
	</div>

	<!-- Hidden comments to ensure script is loaded -->
	<div class="hidden">
		<Comments slug="dummy" />
	</div>

	<!-- Modal (Reels Fullscreen Viewer) -->
	<dialog id="post-modal" class="bg-gray-100 w-full h-full max-w-none max-h-none m-0 p-0 border-none outline-none">
		<div class="relative w-full h-full flex flex-col items-center justify-center mx-auto overflow-hidden">
			<button id="close-modal" class="absolute top-4 lg:top-6 left-4 lg:left-6 z-50 text-white text-3xl font-light hover:text-gray-300 transition-colors bg-black/30 w-10 h-10 rounded-full flex items-center justify-center cursor-pointer outline-none border border-white/10 shadow-lg backdrop-blur-sm">
				<span class="material-symbols-outlined">close</span>
			</button>
			<div id="modal-content-wrapper" class="w-full flex justify-center items-center h-full">
				<div id="loading-spinner" class="flex flex-col items-center gap-3 text-white">
					<span class="material-symbols-outlined animate-spin text-4xl">progress_activity</span>
					<span class="text-sm">読み込み中...</span>
				</div>
			</div>
		</div>
	</dialog>
</Layout>

<script>
	// Modal Logic
	const modal = document.getElementById('post-modal') as HTMLDialogElement;
	const closeBtn = document.getElementById('close-modal');
	const wrapper = document.getElementById('modal-content-wrapper');
	const loadingSpinner = document.getElementById('loading-spinner');

	function closeModal() {
		if (modal && modal.open) {
			modal.close();
			// Revert URL
			if (window.location.pathname !== '/knowhow' && window.location.pathname !== '/knowhow/') {
				history.pushState(null, '', '/knowhow');
			}
		}
	}

	if (closeBtn) {
		closeBtn.addEventListener('click', closeModal);
	}

	if (modal) {
		modal.addEventListener('click', (e) => {
			if (e.target === modal) {
				closeModal();
			}
		});
	}

	// Handle browser back button
	window.addEventListener('popstate', () => {
		if (window.location.pathname === '/knowhow' || window.location.pathname === '/knowhow/') {
			if (modal && modal.open) {
				modal.close();
			}
		}
	});

	declare global {
		interface Window {
			openModal: (id: string) => void;
			toggleCommentsPanel: () => void;
			toggleDescPanel: () => void;
            toggleInfoPanel: () => void;
            toggleTab: (tab: 'desc' | 'comments') => void;
            switchTab: (tab: 'desc' | 'comments') => void;
		}
	}

    const isMobile = () => window.innerWidth < 1024;
    
    const setUrlTab = (tab: string | null) => {
        const url = new URL(window.location.href);
        if (tab) url.searchParams.set('tab', tab);
        else url.searchParams.delete('tab');
        history.replaceState(null, '', url.toString());
    };

    window.switchTab = (tab: 'desc' | 'comments') => {
        const tabBtnDesc = document.getElementById('tab-btn-desc');
        const tabBtnComments = document.getElementById('tab-btn-comments');
        const tabContentDesc = document.getElementById('tab-content-desc');
        const tabContentComments = document.getElementById('tab-content-comments');

        if (tab === 'desc') {
            tabBtnDesc?.classList.replace('text-gray-400', 'text-navy-900');
            tabBtnDesc?.classList.replace('border-transparent', 'border-navy-900');
            tabBtnComments?.classList.replace('text-navy-900', 'text-gray-400');
            tabBtnComments?.classList.replace('border-navy-900', 'border-transparent');
            tabContentDesc?.classList.remove('hidden');
            tabContentComments?.classList.add('hidden');
            tabContentComments?.classList.remove('flex');
        } else {
            tabBtnComments?.classList.replace('text-gray-400', 'text-navy-900');
            tabBtnComments?.classList.replace('border-transparent', 'border-navy-900');
            tabBtnDesc?.classList.replace('text-navy-900', 'text-gray-400');
            tabBtnDesc?.classList.replace('border-navy-900', 'border-transparent');
            tabContentComments?.classList.remove('hidden');
            tabContentComments?.classList.add('flex');
            tabContentDesc?.classList.add('hidden');
            
            const form = tabContentComments?.querySelector('input[type="text"]') as HTMLInputElement;
            if (form) form.focus();
        }
    };

    window.toggleInfoPanel = () => {
        const infoPanel = document.getElementById('info-panel');
        if (!infoPanel) return;
        const mobile = isMobile();
        
        if (mobile) {
            infoPanel.classList.toggle('translate-y-full');
        } else {
            if (infoPanel.classList.contains('lg:w-0')) {
                infoPanel.classList.remove('lg:w-0', 'lg:opacity-0', 'lg:ml-0');
                infoPanel.classList.add('lg:w-[400px]', 'lg:opacity-100', 'lg:ml-4');
            } else {
                infoPanel.classList.add('lg:w-0', 'lg:opacity-0', 'lg:ml-0');
                infoPanel.classList.remove('lg:w-[400px]', 'lg:opacity-100', 'lg:ml-4');
            }
        }

        const isOpened = mobile ? !infoPanel.classList.contains('translate-y-full') : !infoPanel.classList.contains('lg:w-0');
        if (isOpened) {
            const tabContentDesc = document.getElementById('tab-content-desc');
            const activeTab = tabContentDesc?.classList.contains('hidden') ? 'comments' : 'desc';
            setUrlTab(activeTab);
        } else {
            setUrlTab(null);
        }
    };

    window.toggleTab = (tab: 'desc' | 'comments') => {
        const infoPanel = document.getElementById('info-panel');
        if (!infoPanel) return;
        const mobile = isMobile();
        const isOpened = mobile ? !infoPanel.classList.contains('translate-y-full') : !infoPanel.classList.contains('lg:w-0');
        
        const tabContentDesc = document.getElementById('tab-content-desc');
        const activeTab = tabContentDesc?.classList.contains('hidden') ? 'comments' : 'desc';

        if (isOpened && activeTab === tab) {
            window.toggleInfoPanel();
        } else if (isOpened) {
            window.switchTab(tab);
            setUrlTab(tab);
        } else {
            window.switchTab(tab);
            if (mobile) {
                infoPanel.classList.remove('translate-y-full');
            } else {
                infoPanel.classList.remove('lg:w-0', 'lg:opacity-0', 'lg:ml-0');
                infoPanel.classList.add('lg:w-[400px]', 'lg:opacity-100', 'lg:ml-4');
            }
            setUrlTab(tab);
        }
    };

	window.toggleCommentsPanel = () => window.toggleTab('comments');
	window.toggleDescPanel = () => window.toggleTab('desc');

	// Close panel if clicked outside
	document.addEventListener('click', (e) => {
		const target = e.target as HTMLElement;
		const container = document.getElementById('knowhow-modal-container');
        const infoPanel = document.getElementById('info-panel');
		
		if (container &&
			container.contains(target) && 
			(!infoPanel || !infoPanel.contains(target)) && 
			!target.closest('button[onclick*="toggleCommentsPanel"]') &&
			!target.closest('button[onclick*="toggleDescPanel"]') &&
            !target.closest('button[onclick*="toggleTab"]') &&
            !target.closest('div[onclick*="toggleDescPanel"]') &&
			!target.closest('.like-btn')
		) {
            if (infoPanel) {
                if (isMobile()) infoPanel.classList.add('translate-y-full');
                else {
                    infoPanel.classList.add('lg:w-0', 'lg:opacity-0', 'lg:ml-0');
                    infoPanel.classList.remove('lg:w-[400px]', 'lg:opacity-100', 'lg:ml-4');
                }
            }
            setUrlTab(null);
		}
	});

	let currentPostId = '';
	let isNavigating = false;

	window.openModal = async function(id: string) {
		if (!modal || !wrapper || !loadingSpinner || isNavigating) return;
		
		isNavigating = true;
		currentPostId = id;
		
		// Update URL
		history.pushState({ id }, '', `/knowhow/${id}/`);

		if (!modal.open) {
			modal.showModal();
		}
		wrapper.innerHTML = '';
		wrapper.appendChild(loadingSpinner);
		loadingSpinner.style.display = 'flex';

		try {
			const res = await fetch(`/knowhow/${id}/`);
			const html = await res.text();
			const doc = new DOMParser().parseFromString(html, 'text/html');
			const content = doc.getElementById('knowhow-modal-container');
			if (content) {
				loadingSpinner.style.display = 'none';
				wrapper.innerHTML = '';
				wrapper.appendChild(content);
				
				// Initialize Tabs manually since this is injected HTML
				const tabBtns = wrapper.querySelectorAll('.tab-btn');
				tabBtns.forEach(btn => {
					btn.addEventListener('click', () => {
						const targetId = btn.getAttribute('data-target');
                        if (targetId === 'tab-content-comments') {
                            window.toggleTab('comments');
                        } else {
                            window.toggleTab('desc');
                        }
					});
				});

				// Re-initialize comments
				document.dispatchEvent(new Event('astro:page-load'));

				// Check initial URL to open comments panel if ?tab=comments
				const urlParams = new URLSearchParams(window.location.search);
				if (urlParams.get('tab') === 'comments') {
                    window.toggleTab('comments');
				} else if (urlParams.get('tab') === 'desc') {
                    window.toggleTab('desc');
				}
			}
		} catch (err) {
			console.error(err);
			wrapper.innerHTML = '<div class="text-white text-center p-4">読み込みに失敗しました。</div>';
		} finally {
			isNavigating = false;
		}
	};

	// Swipe and Wheel Navigation Logic
	let startY = 0;
	let endY = 0;
	
	const navigateToRelative = (direction: 1 | -1) => {
		if (isNavigating || !currentPostId) return;
		
		// Find currently visible cards in the DOM to determine the order
		const visibleCards = Array.from(document.querySelectorAll(".knowhow-card")).filter(card => (card as HTMLElement).style.display !== "none");
		if (visibleCards.length === 0) return;

		// Find index of current post
		const currentIndex = visibleCards.findIndex(card => {
			// Find the click handler string to extract ID
			const html = card.innerHTML;
			return html.includes(`openModal('${currentPostId}')`);
		});

		if (currentIndex !== -1) {
			const targetIndex = currentIndex + direction;
			if (targetIndex >= 0 && targetIndex < visibleCards.length) {
				const targetCard = visibleCards[targetIndex];
				const match = targetCard.innerHTML.match(/openModal\('([^']+)'\)/);
				if (match && match[1]) {
					window.openModal(match[1]);
				}
			}
		}
	};

	// Touch Events (Mobile)
	wrapper?.addEventListener('touchstart', (e) => {
		// Only trigger swipe if we are not scrolling a comment panel or content area
		const target = e.target as HTMLElement;
		if (target.closest('.overflow-y-auto') || target.closest('textarea')) return;
		startY = e.touches[0].clientY;
	}, { passive: true });

	wrapper?.addEventListener('touchmove', (e) => {
		const target = e.target as HTMLElement;
		if (target.closest('.overflow-y-auto') || target.closest('textarea')) return;
		endY = e.touches[0].clientY;
	}, { passive: true });

	wrapper?.addEventListener('touchend', (e) => {
		const target = e.target as HTMLElement;
		if (target.closest('.overflow-y-auto') || target.closest('textarea')) return;
		
		const distance = startY - endY;
		if (distance > 50) {
			// Swipe up -> Next
			navigateToRelative(1);
		} else if (distance < -50) {
			// Swipe down -> Prev
			navigateToRelative(-1);
		}
		startY = 0;
		endY = 0;
	});

	// Wheel Event (PC)
	let wheelTimeout: NodeJS.Timeout | null = null;
	wrapper?.addEventListener('wheel', (e) => {
		const target = e.target as HTMLElement;
		if (target.closest('.overflow-y-auto') || target.closest('textarea')) return;
		
		// Debounce wheel events to prevent double navigation
		if (wheelTimeout) return;
		
		if (e.deltaY > 50) {
			navigateToRelative(1);
			wheelTimeout = setTimeout(() => { wheelTimeout = null; }, 800);
		} else if (e.deltaY < -50) {
			navigateToRelative(-1);
			wheelTimeout = setTimeout(() => { wheelTimeout = null; }, 800);
		}
	}, { passive: true });

	// Filtering Logic
	const categoryButtons = document.querySelectorAll(".category-btn");
	const ageFilter = document.getElementById("age-filter") as HTMLSelectElement;
	const sortOrder = document.getElementById("sort-order") as HTMLSelectElement;
	const knowhowContainer = document.getElementById("knowhow-container");
	const cards = Array.from(document.querySelectorAll(".knowhow-card")) as HTMLElement[];
	const searchInput = document.getElementById("knowhow-search") as HTMLInputElement;

	let currentCategory = "すべて";
	let currentAge = "all";
	let currentSort = "recommended";
	let searchQuery = "";

	function updateView() {
		// Filter
		cards.forEach((card) => {
			const titleText = (card.querySelector('h3')?.textContent || card.querySelector('p')?.textContent || '').toLowerCase();
			const descText = (card.querySelector('.line-clamp-2')?.textContent || '').toLowerCase();
			const searchMatch = !searchQuery || titleText.includes(searchQuery) || descText.includes(searchQuery);

			const categoryMatch = currentCategory === "すべて" || (card.getAttribute("data-categories") || "").split(",").includes(currentCategory);
			const ageMatch = currentAge === "all" || card.getAttribute("data-age") === currentAge;

			if (categoryMatch && ageMatch && searchMatch) {
				card.style.display = "block";
			} else {
				card.style.display = "none";
			}
		});

		// Sort
		const visibleCards = cards.filter((card) => card.style.display !== "none");
		const hiddenCards = cards.filter((card) => card.style.display === "none");

		visibleCards.sort((a, b) => {
			if (currentSort === "recommended") {
				const numA = parseInt(a.getAttribute("data-order") || "0", 10);
				const numB = parseInt(b.getAttribute("data-order") || "0", 10);
				return numA - numB;
			} else {
				const ageA = a.getAttribute("data-age");
				const ageB = b.getAttribute("data-age");
				const valA = ageA === "none" ? Infinity : parseInt(ageA || "0", 10);
				const valB = ageB === "none" ? Infinity : parseInt(ageB || "0", 10);

				if (currentSort === "age-asc") {
					return valA - valB;
				} else {
					// age-desc
					if (valA === Infinity && valB !== Infinity) return 1;
					if (valB === Infinity && valA !== Infinity) return -1;
					return valB - valA;
				}
			}
		});

		// Re-append to DOM in order
		if (knowhowContainer) {
			visibleCards.forEach((card) => knowhowContainer.appendChild(card));
			hiddenCards.forEach((card) => knowhowContainer.appendChild(card));
		}
	}

	categoryButtons.forEach((button) => {
		button.addEventListener("click", () => {
			currentCategory = button.getAttribute("data-category") || "すべて";

			// Update button styles
			categoryButtons.forEach((btn) => {
				btn.classList.remove("border-mint-500", "bg-mint-50", "text-mint-500", "font-bold");
				btn.classList.add("border-gray-200", "bg-white", "text-gray-500", "font-medium");
			});
			button.classList.remove("border-gray-200", "bg-white", "text-gray-500", "font-medium");
			button.classList.add("border-mint-500", "bg-mint-50", "text-mint-500", "font-bold");

			updateView();
		});
	});

	ageFilter?.addEventListener("change", (e) => {
		currentAge = (e.target as HTMLSelectElement).value;
		updateView();
	});

	sortOrder?.addEventListener("change", (e) => {
		currentSort = (e.target as HTMLSelectElement).value;
		updateView();
	});

	searchInput?.addEventListener("input", (e) => {
		searchQuery = (e.target as HTMLInputElement).value.toLowerCase();
		updateView();
	});
</script>

<style>
	.scrollbar-hide::-webkit-scrollbar {
		display: none;
	}
	.scrollbar-hide {
		-ms-overflow-style: none;
		scrollbar-width: none;
	}
	
	dialog::backdrop {
		background: rgba(0, 0, 0, 0.85);
	}
</style>
