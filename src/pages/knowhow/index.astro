---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../../consts";
import { UI } from "../../i18n/ja";

const posts = await getCollection("knowhow");
posts.sort((a, b) => a.data.order - b.data.order);
---

<Layout title={`${UI.knowhow.pageTitle} | ${SITE_TITLE}`} description={SITE_DESCRIPTION}>
	<div class="px-6 py-8 lg:py-12 max-w-4xl mx-auto">
		<h1 class="text-[1.5rem] lg:text-[2rem] font-bold text-navy-900 mb-2">
			{UI.knowhow.pageTitle}
		</h1>
		<p class="text-sm text-gray-500 mb-8">{UI.knowhow.pageDesc}</p>

		<div class="grid gap-6 md:grid-cols-2">
			{posts.map((post) => (
				<a href={`/knowhow/${post.id}/`} class="flex flex-col bg-white border border-gray-200 rounded-2xl overflow-hidden hover:shadow-md transition-shadow group">
					{post.data.coverImage && (
						<div class="aspect-video w-full overflow-hidden bg-gray-50 flex items-center justify-center border-b border-gray-100">
							<img src={post.data.coverImage} alt={post.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
						</div>
					)}
					<div class="p-6 flex-grow flex flex-col justify-between">
						<div>
							<div class="flex items-center gap-2 mb-2">
								<span class="material-symbols-outlined text-mint-500 text-lg" aria-hidden="true">{post.data.icon || 'description'}</span>
								{post.data.childAgeMonths !== undefined && (
									<span class="text-xs text-gray-500">生後{post.data.childAgeMonths}ヶ月〜</span>
								)}
							</div>
							<h2 class="text-lg font-bold text-navy-900 leading-snug group-hover:text-mint-600 transition-colors">{post.data.title}</h2>
							<p class="text-sm text-gray-600 mt-2 leading-relaxed line-clamp-3">{post.data.description}</p>
						</div>
						<span class="text-xs font-bold text-mint-600 mt-6 flex items-center gap-0.5">詳しく見る <span class="material-symbols-outlined text-xs" aria-hidden="true">chevron_right</span></span>
					</div>
				</a>
			))}
		</div>
	</div>
</Layout>
