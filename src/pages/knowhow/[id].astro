---
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import ActionBar from "../../components/ActionBar.astro";
import { SITE_TITLE } from "../../consts";

export async function getStaticPaths() {
	const knowhow = await getCollection("knowhow");
	return knowhow.map((item) => ({
		params: { id: item.id },
		props: { knowhow: item },
	}));
}

const { knowhow } = Astro.props;
const { Content } = await render(knowhow);
---

<Layout
	title={`${knowhow.data.title} | ${SITE_TITLE}`}
	description={knowhow.data.description}
	image={knowhow.data.coverImage}
>
	<!-- Top Image Area -->
	<div class="w-full max-w-5xl mx-auto lg:mt-8 lg:px-6">
		<div class="w-full aspect-video lg:rounded-2xl bg-mint-50 flex items-center justify-center overflow-hidden border-b lg:border border-gray-200">
			{knowhow.data.coverImage ? (
				<img src={knowhow.data.coverImage} alt={knowhow.data.title} class="w-full h-full object-cover" />
			) : (
				<span class="material-symbols-outlined text-mint-200 text-5xl" aria-hidden="true">image</span>
			)}
		</div>
	</div>

	<div class="px-4 sm:px-6 py-6 lg:py-10 max-w-5xl mx-auto">
		<!-- Header -->
		<div class="mb-6">
			<div class="pt-1 sm:pt-2 flex-grow min-w-0">
				<h1 class="text-[1.35rem] sm:text-[1.75rem] font-bold text-navy-900 leading-tight mb-1 sm:mb-2 break-all sm:break-auto">
					{knowhow.data.title}
				</h1>
			</div>
		</div>

		<!-- Metrics Row -->
		<div class="flex items-center gap-6 sm:gap-8 mb-6 pb-6 border-b border-gray-100">
			<!-- Age -->
			<div class="flex flex-col items-center">
				<div class="font-bold text-gray-800 text-[1.1rem]">
					{knowhow.data.childAgeMonths !== undefined ? `生後${knowhow.data.childAgeMonths}ヶ月〜` : '全年齢'}
				</div>
				<div class="text-[0.7rem] text-gray-500">使い始めた時期</div>
			</div>
		</div>

		<!-- Content -->
		<div class="bg-gray-50 rounded-3xl p-6 sm:p-8 mb-10 border border-gray-100 mt-8">
			<h2 class="text-[1.25rem] font-bold text-navy-900 mb-6 flex items-center gap-2">
				使ってみた感想
			</h2>
			<div class="content-area">
				<Content />
			</div>
		</div>

		<!-- Bottom Actions -->
		<ActionBar slug={`knowhow/${knowhow.id}`} />
	</div>
</Layout>

<style>
	/* Standard Markdown Content Styles */
	.content-area {
		display: flex;
		flex-direction: column;
	}
	
	.content-area :global(> h3) {
		font-size: 1.15rem;
		font-weight: 700;
		color: var(--color-navy-900);
		margin: 2rem 0 1rem;
	}

	.content-area :global(> p), .content-area :global(> ul) {
		margin-bottom: 1.5rem;
		line-height: 1.8;
		color: var(--color-gray-700);
	}
</style>
