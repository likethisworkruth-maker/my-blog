---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { SITE_TITLE } from '../../consts';

export async function getStaticPaths() {
	const logs = await getCollection('logs');
	return logs.map((log) => ({
		params: { id: log.id },
		props: { log },
	}));
}

const { log } = Astro.props;
const { Content } = await render(log);
---

<Layout title={`${log.data.title} | ${SITE_TITLE}`} description={log.data.problem || ''}>
	<div class="px-6 py-8 lg:py-12 max-w-5xl mx-auto">
		<div class="flex items-center gap-4 mb-8">
			<a href="/logs" class="inline-flex items-center justify-center w-10 h-10 rounded-full hover:bg-gray-100 transition-colors">
				<span class="material-symbols-outlined text-gray-500">arrow_back</span>
			</a>
			<h2 class="text-[1.2rem] font-bold text-navy-900">実験ログ詳細</h2>
		</div>
		
		<div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6 lg:p-10 mb-8">
			<!-- Header inside card -->
			<div class="flex flex-col lg:flex-row gap-8 lg:items-center pb-8 border-b border-gray-100 mb-8">
				<div class="flex-1">
					<span class="inline-block bg-mint-50 text-mint-500 font-bold text-sm px-3 py-1 rounded-full mb-4">困りごと</span>
					<h1 class="text-[1.5rem] lg:text-[2rem] font-bold leading-tight mb-4 text-navy-900">{log.data.title}</h1>
					<div class="flex items-center gap-2 text-gray-500 text-[0.9rem]">
						<span class="material-symbols-outlined text-[1.1rem]">calendar_today</span>
						{log.data.pubDate.toLocaleDateString('ja-JP')}
					</div>
				</div>
				<!-- Right Illustration Placeholder -->
				<div class="hidden lg:flex w-64 h-48 bg-mint-50/50 rounded-xl items-center justify-center shrink-0 border border-mint-100">
					<span class="material-symbols-outlined text-mint-200 text-6xl">edit_note</span>
				</div>
			</div>
			
			<!-- Content Area -->
			<div class="content-area">
				<Content />
			</div>
			
			<!-- Bottom Actions -->
			<div class="mt-12 pt-8 border-t border-gray-100 flex flex-col sm:flex-row gap-4">
				<button class="flex-1 bg-white border border-mint-500 text-mint-500 hover:bg-mint-50 font-bold py-4 rounded-xl transition-colors">
					テンプレを見る
				</button>
				<button class="flex-1 bg-white border border-mint-500 text-mint-500 hover:bg-mint-50 font-bold py-4 rounded-xl transition-colors">
					関連する実験を見る
				</button>
			</div>
		</div>
		
		<!-- 免責カード -->
		<div class="bg-orange-50 border border-orange-100 rounded-xl p-6 flex gap-4 items-start">
			<span class="material-symbols-outlined text-gray-400 text-2xl shrink-0">info</span>
			<div>
				<p class="text-[0.85rem] font-bold text-gray-700 mb-1">この記録は、個人の家庭内での実験記録です。</p>
				<p class="text-[0.8rem] text-gray-500 m-0">医療や発達・育児に関するアドバイスではありません。</p>
			</div>
		</div>
	</div>
</Layout>

<style>
	/* Markdown Content Styles - Table-like Layout for PC */
	.content-area {
		display: flex;
		flex-direction: column;
	}
	
	@media (min-width: 1024px) {
		.content-area :global(> h3) {
			display: flex;
			align-items: flex-start;
			gap: 1rem;
			font-size: 1.1rem;
			font-weight: 700;
			color: var(--color-mint-500);
			margin: 0;
			padding: 2rem 0;
			width: 30%;
			float: left;
			clear: left;
		}
		.content-area :global(> p), .content-area :global(> ul) {
			width: 70%;
			float: left;
			margin: 0;
			padding: 2rem 0 2rem 2rem;
			border-left: 1px dotted var(--color-gray-200);
			border-bottom: 1px solid var(--color-gray-100);
			color: var(--color-gray-700);
			line-height: 1.8;
			min-height: 100px; /* To match h3 height */
		}
		.content-area::after {
			content: "";
			display: table;
			clear: both;
		}
		/* Add icons via CSS pseudo elements for specific headings if needed, or rely on text */
	}

	@media (max-width: 1023px) {
		.content-area :global(h3) {
			font-size: 1.1rem;
			font-weight: 700;
			margin: 2rem 0 1rem;
			color: var(--color-mint-500);
			border-bottom: 2px solid var(--color-mint-50);
			padding-bottom: 0.5rem;
		}
		.content-area :global(p) {
			margin-bottom: 1rem;
			line-height: 1.8;
			color: var(--color-gray-700);
		}
	}
</style>
