---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import LogCard from '../../components/LogCard.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { UI } from '../../i18n/ja';

const logs = await getCollection('logs');
logs.sort((a, b) => b.data.logNumber.localeCompare(a.data.logNumber));

const uniqueCategories = [...new Set(logs.flatMap(log => log.data.categories || []))];
const displayCategories = uniqueCategories.length > 0 ? ['すべて', ...uniqueCategories] : ['すべて', '子育て記録', '夫婦共有', '予定・健診', '離乳食'];

const uniqueAges = [...new Set(logs.map(log => log.data.childAgeMonths).filter(age => age !== undefined))].sort((a, b) => a! - b!);
---

<Layout title={`${UI.logs.pageTitle} | ${SITE_TITLE}`} description={SITE_DESCRIPTION}>

	<div class="px-6 py-8 lg:py-12">
		<div class="flex flex-col lg:flex-row gap-4 mb-8 items-start lg:items-center justify-between">
			<!-- Categories -->
			<div class="flex gap-3 overflow-x-auto pb-2 lg:pb-0 scrollbar-hide w-full lg:w-auto" id="category-filters">
				{displayCategories.map((category, index) => (
					<button
						class={`category-btn px-4 py-2 rounded-full border text-sm whitespace-nowrap shrink-0 transition-colors ${index === 0 ? 'border-mint-500 bg-mint-50 text-mint-500 font-bold' : 'border-gray-200 bg-white text-gray-500 font-medium hover:bg-gray-50'}`}
						data-category={category}
					>
						{category}
					</button>
				))}
			</div>

			<!-- Age & Sort -->
			<div class="flex gap-3 w-full lg:w-auto shrink-0">
				<select id="age-filter" class="flex-1 lg:flex-none border border-gray-200 rounded-lg px-3 py-2 text-sm text-gray-700 bg-white focus:outline-none focus:border-mint-500">
					<option value="all">すべての月齢</option>
					{uniqueAges.map(age => (
						<option value={age.toString()}>生後{age}ヶ月</option>
					))}
					<option value="none">月齢未指定</option>
				</select>

				<select id="sort-order" class="flex-1 lg:flex-none border border-gray-200 rounded-lg px-3 py-2 text-sm text-gray-700 bg-white focus:outline-none focus:border-mint-500">
					<option value="newest">最新順</option>
					<option value="age-asc">月齢が低い順</option>
					<option value="age-desc">月齢が高い順</option>
				</select>
			</div>
		</div>

		<div class="flex flex-col gap-0 md:grid md:grid-cols-2 lg:grid-cols-3 md:gap-6" id="logs-container">
			{logs.map((log) => <LogCard log={log} />)}
		</div>
	</div>
</Layout>

<script>
	const categoryButtons = document.querySelectorAll('.category-btn');
	const ageFilter = document.getElementById('age-filter') as HTMLSelectElement;
	const sortOrder = document.getElementById('sort-order') as HTMLSelectElement;
	const logsContainer = document.getElementById('logs-container');
	const cards = Array.from(document.querySelectorAll('.log-card')) as HTMLElement[];

	let currentCategory = 'すべて';
	let currentAge = 'all';
	let currentSort = 'newest';

	function updateView() {
		// Filter
		cards.forEach(card => {
			const categoryMatch = currentCategory === 'すべて' || (card.getAttribute('data-categories') || '').split(',').includes(currentCategory);
			const ageMatch = currentAge === 'all' || card.getAttribute('data-age') === currentAge;

			if (categoryMatch && ageMatch) {
				card.style.display = 'flex';
			} else {
				card.style.display = 'none';
			}
		});

		// Sort
		const visibleCards = cards.filter(card => card.style.display !== 'none');
		const hiddenCards = cards.filter(card => card.style.display === 'none');

		visibleCards.sort((a, b) => {
			if (currentSort === 'newest') {
				const numA = a.getAttribute('data-lognumber') || '';
				const numB = b.getAttribute('data-lognumber') || '';
				return numB.localeCompare(numA);
			} else {
				const ageA = a.getAttribute('data-age');
				const ageB = b.getAttribute('data-age');
				const valA = ageA === 'none' ? Infinity : parseInt(ageA || '0', 10);
				const valB = ageB === 'none' ? Infinity : parseInt(ageB || '0', 10);

				if (currentSort === 'age-asc') {
					return valA - valB;
				} else { // age-desc
					if (valA === Infinity && valB !== Infinity) return 1;
					if (valB === Infinity && valA !== Infinity) return -1;
					return valB - valA;
				}
			}
		});

		// Re-append to DOM in order
		if (logsContainer) {
			visibleCards.forEach(card => logsContainer.appendChild(card));
			hiddenCards.forEach(card => logsContainer.appendChild(card));
		}
	}

	categoryButtons.forEach(button => {
		button.addEventListener('click', () => {
			currentCategory = button.getAttribute('data-category') || 'すべて';

			// Update button styles
			categoryButtons.forEach(btn => {
				btn.classList.remove('border-mint-500', 'bg-mint-50', 'text-mint-500', 'font-bold');
				btn.classList.add('border-gray-200', 'bg-white', 'text-gray-500', 'font-medium');
			});
			button.classList.remove('border-gray-200', 'bg-white', 'text-gray-500', 'font-medium');
			button.classList.add('border-mint-500', 'bg-mint-50', 'text-mint-500', 'font-bold');

			updateView();
		});
	});

	ageFilter?.addEventListener('change', (e) => {
		currentAge = (e.target as HTMLSelectElement).value;
		updateView();
	});

	sortOrder?.addEventListener('change', (e) => {
		currentSort = (e.target as HTMLSelectElement).value;
		updateView();
	});
</script>

<style>
	.scrollbar-hide::-webkit-scrollbar {
		display: none;
	}
	.scrollbar-hide {
		-ms-overflow-style: none;
		scrollbar-width: none;
	}
</style>
