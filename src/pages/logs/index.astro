---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';

const logs = await getCollection('logs');
logs.sort((a, b) => b.data.logNumber.localeCompare(a.data.logNumber));
---

<Layout title={`実験ログ | ${SITE_TITLE}`} description={SITE_DESCRIPTION}>
	
	<div class="px-6 py-8 lg:py-12">
		<h2 class="text-[1.5rem] lg:text-[2rem] font-bold text-navy-900 mb-6">実験ログ</h2>
		
		<div class="flex gap-3 overflow-x-auto pb-4 scrollbar-hide mb-8">
			<button class="px-4 py-2 rounded-full border border-mint-500 bg-mint-50 text-mint-500 text-sm font-bold whitespace-nowrap shrink-0">すべて</button>
			<button class="px-4 py-2 rounded-full border border-gray-200 bg-white text-gray-500 text-sm font-medium whitespace-nowrap shrink-0 hover:bg-gray-50 transition-colors">育児記録</button>
			<button class="px-4 py-2 rounded-full border border-gray-200 bg-white text-gray-500 text-sm font-medium whitespace-nowrap shrink-0 hover:bg-gray-50 transition-colors">夫婦共有</button>
			<button class="px-4 py-2 rounded-full border border-gray-200 bg-white text-gray-500 text-sm font-medium whitespace-nowrap shrink-0 hover:bg-gray-50 transition-colors">予定・健診</button>
			<button class="px-4 py-2 rounded-full border border-gray-200 bg-white text-gray-500 text-sm font-medium whitespace-nowrap shrink-0 hover:bg-gray-50 transition-colors">離乳食</button>
		</div>
		
		<div class="flex flex-col gap-6">
			{logs.map((log) => (
				<a href={`/logs/${log.id}/`} class="flex flex-col sm:flex-row bg-white rounded-2xl border border-gray-200 shadow-sm hover:shadow-md transition-shadow group overflow-hidden">
					<!-- Thumbnail Placeholder (for both Mobile and PC) -->
					<div class="w-full sm:w-64 h-48 sm:h-auto bg-gray-100 shrink-0 relative flex items-center justify-center border-b sm:border-b-0 sm:border-r border-gray-100">
						<span class="material-symbols-outlined text-gray-300 text-5xl">image</span>
					</div>
					
					<div class="flex-grow p-6 lg:p-8 flex flex-col justify-center relative">
						<div class="mb-2">
							<span class="text-[0.8rem] font-bold text-navy-900">#{log.data.logNumber}</span>
						</div>
						<h3 class="text-[1.1rem] lg:text-[1.25rem] font-bold leading-snug text-navy-900 mb-4">{log.data.title}</h3>
						
						<div class="flex flex-col gap-2">
							{log.data.createdTool && (
								<div class="flex items-center gap-2 text-[0.85rem]">
									<span class="bg-mint-50 text-mint-500 px-2 py-0.5 rounded text-[0.7rem] font-bold shrink-0">作ったもの</span>
									<span class="text-gray-600">{log.data.createdTool}</span>
								</div>
							)}
							{log.data.result && (
								<div class="flex items-center gap-2 text-[0.85rem]">
									<span class="bg-mint-50 text-mint-500 px-2 py-0.5 rounded text-[0.7rem] font-bold shrink-0">結果</span>
									<span class="text-gray-600">{log.data.result}</span>
								</div>
							)}
						</div>
						
						<div class="mt-4 flex items-center gap-2 text-[0.85rem] text-gray-400">
							<span class="material-symbols-outlined text-[1rem]">calendar_today</span>
							<span>{log.data.pubDate.toLocaleDateString('ja-JP')}</span>
						</div>
						
						<!-- Arrow Icon right aligned on PC -->
						<span class="material-symbols-outlined absolute right-6 top-1/2 -translate-y-1/2 text-gray-300 group-hover:text-mint-500 transition-colors hidden sm:block">arrow_forward_ios</span>
					</div>
				</a>
			))}
		</div>
	</div>
</Layout>

<style>
	.scrollbar-hide::-webkit-scrollbar {
		display: none;
	}
	.scrollbar-hide {
		-ms-overflow-style: none;
		scrollbar-width: none;
	}
</style>
