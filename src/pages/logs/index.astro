---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { UI } from '../../i18n/ja';

const logs = await getCollection('logs');
logs.sort((a, b) => b.data.logNumber.localeCompare(a.data.logNumber));
---

<Layout title={`${UI.logs.logsTitle || '読みもの'} | ${SITE_TITLE}`} description={SITE_DESCRIPTION}>
	<div class="px-6 py-8 lg:py-12 max-w-4xl mx-auto">
		<h1 class="text-[1.5rem] lg:text-[2rem] font-bold text-navy-900 mb-2">読みもの</h1>
		<p class="text-sm text-gray-500 mb-8">わが家で直面した困りごとと、試行錯誤した日々の記録です。</p>
		
		<div class="grid gap-6 md:grid-cols-2">
			{logs.map((log) => (
				<a href={`/logs/${log.id}/`} class="flex flex-col bg-white border border-gray-200 rounded-2xl overflow-hidden hover:shadow-md transition-shadow group">
					{log.data.coverImage && (
						<div class="aspect-video w-full overflow-hidden bg-gray-50 flex items-center justify-center border-b border-gray-100">
							<img src={log.data.coverImage} alt={log.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
						</div>
					)}
					<div class="p-6 flex-grow flex flex-col justify-between">
						<div>
							<div class="flex items-center gap-2 mb-2">
								{log.data.childAgeMonths !== undefined && (
									<span class="bg-gray-100 text-gray-600 px-2 py-0.5 rounded-full text-xs font-bold">
										生後{log.data.childAgeMonths}ヶ月頃
									</span>
								)}
							</div>
							<h2 class="text-lg font-bold text-navy-900 leading-snug group-hover:text-mint-600 transition-colors">{log.data.title}</h2>
							<p class="text-sm text-gray-600 mt-2 leading-relaxed">{log.data.problem}</p>
						</div>
						<span class="text-xs font-bold text-mint-600 mt-6 flex items-center gap-0.5">詳しく見る <span class="material-symbols-outlined text-xs" aria-hidden="true">chevron_right</span></span>
					</div>
				</a>
			))}
		</div>
	</div>
</Layout>
