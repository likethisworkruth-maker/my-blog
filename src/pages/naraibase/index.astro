---
import Layout from "../../layouts/Layout.astro";
import { SITE_TITLE } from "../../consts";
import { NARAIBASE_LESSONS as lessons } from "../../data/naraibase";
---

<Layout title={`Naraibase（ナライベース） | 子どもの習い事を考える | ${SITE_TITLE}`} description="経験者の本音とデータから、子どもの習い事を考える「Naraibase」。ピアノ、水泳、英会話などの役立ち度を掲載。">
	<!-- Hero -->
	<section class="px-6 py-12 lg:py-16 bg-navy-900 text-white">
		<div class="max-w-4xl mx-auto">
			<span class="text-xs font-bold text-mint-400 bg-mint-950/50 px-3 py-1 rounded-full border border-mint-900">子どものこれからを考える</span>
			<h1 class="text-3xl lg:text-4xl font-black mt-4 tracking-tight">Naraibase <span class="text-lg lg:text-xl font-normal text-gray-300">（ナライベース）</span></h1>
			<p class="text-base lg:text-lg text-mint-300 font-bold mt-2">経験者の本音とデータから、子どもの習い事を考える。</p>
			
			<p class="text-sm text-gray-300 mt-4 leading-relaxed max-w-2xl">
				ピアノ、水泳、英会話、スポーツなどを経験した大人に、大人になった今どう感じているかを聞いています。
				「役立ったか」「自分の子どもにも勧めたいか」という回答と、その理由を掲載します。
			</p>
			
			<div class="mt-6 p-4 rounded-xl bg-navy-950 border border-navy-800 text-xs text-gray-400 leading-relaxed max-w-2xl">
				⚠️ 子どもの適性を診断したり、特定の習い事の効果を保証したりするサービスではありません。
			</div>
		</div>
	</section>

	<!-- Call to Action -->
	<section class="px-6 py-8 bg-mint-50/20 border-b border-gray-100">
		<div class="max-w-4xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4">
			<div class="text-center sm:text-left">
				<h2 class="font-bold text-navy-900 text-sm sm:text-base">あなたの習い事の経験を共有しませんか？</h2>
				<p class="text-xs text-gray-500 mt-1">選択式の必須項目は4問（約20秒）。経験者の理由を読むための回答としても使えます。</p>
			</div>
			<a href="/naraibase/answer/" class="rounded-full bg-mint-500 hover:bg-mint-600 text-white font-bold py-3 px-6 text-xs transition-all shadow-sm shrink-0">
				自分の経験を回答する
			</a>
		</div>
	</section>

	<!-- Lessons Grid -->
	<section class="px-6 py-12 lg:py-16">
		<div class="max-w-4xl mx-auto">
			<h2 class="text-xl font-bold text-navy-900 mb-8">習い事一覧</h2>
			
			<div class="grid gap-6 sm:grid-cols-2 md:grid-cols-3">
				{lessons.map((lesson) => (
					<a href={`/naraibase/${lesson.slug}/`} class="block bg-white border border-gray-200 rounded-2xl p-6 hover:shadow-md hover:border-mint-500 transition-all group">
						<div class="w-10 h-10 rounded-lg bg-gray-50 text-gray-600 flex items-center justify-center mb-4 group-hover:bg-mint-50 group-hover:text-mint-600 transition-colors">
							<span class="material-symbols-outlined text-xl" aria-hidden="true">school</span>
						</div>
						<h3 class="font-bold text-navy-900 text-lg group-hover:text-mint-600 transition-colors">
							{lesson.name}
						</h3>
						<p class="mt-2 text-xs leading-relaxed text-gray-500">
							経験者による回答の集計と理由を確認できます。
						</p>
						<span class="text-xs font-bold text-mint-600 mt-4 inline-flex items-center gap-0.5">データを見る <span class="material-symbols-outlined text-xs" aria-hidden="true">chevron_right</span></span>
					</a>
				))}
			</div>
		</div>
	</section>
</Layout>
