---
import Layout from "../../../layouts/Layout.astro";
import { SITE_TITLE } from "../../../consts";
import { NARAIBASE_LESSONS } from "../../../data/naraibase";
---

<Layout title={`回答を編集・削除する | Naraibase | ${SITE_TITLE}`} description="Naraibaseへ送信した回答の編集・削除ページです。" noindex={true}>
	<section class="px-6 py-10 lg:py-16 max-w-2xl mx-auto">
		<div class="mb-6">
			<a href="/naraibase/" class="text-xs font-bold text-gray-500 hover:text-mint-600">← Naraibaseトップへ戻る</a>
		</div>
		<div class="bg-white border border-gray-200 rounded-3xl p-6 lg:p-10 shadow-sm">
			<header class="border-b border-gray-100 pb-6 mb-8">
				<h1 class="text-2xl lg:text-3xl font-black text-navy-900">回答の編集・削除</h1>
				<p class="mt-2 text-xs leading-relaxed text-gray-500">回答後に表示された専用URLを持つ方だけが操作できます。</p>
			</header>

			<div id="edit-loading" class="py-8 text-center text-sm text-gray-500">回答を読み込んでいます…</div>
			<p id="edit-error" class="hidden rounded-xl bg-red-50 p-4 text-xs font-bold text-red-700" role="alert"></p>
			<div id="edit-complete" class="hidden py-8 text-center">
				<span class="material-symbols-outlined text-5xl text-mint-500" aria-hidden="true">check_circle</span>
				<h2 id="edit-complete-title" class="mt-3 text-lg font-bold text-navy-900"></h2>
				<a href="/naraibase/" class="mt-6 inline-block rounded-full bg-mint-500 px-7 py-3 text-xs font-bold text-white">Naraibaseへ戻る</a>
			</div>

			<form id="edit-form" class="hidden space-y-7">
				<fieldset class="space-y-3">
					<legend class="text-sm font-bold text-navy-900">性別</legend>
					<div class="flex gap-5">
						<label class="flex items-center gap-2 text-sm"><input type="radio" name="gender" value="male" required class="accent-mint-500" />男性</label>
						<label class="flex items-center gap-2 text-sm"><input type="radio" name="gender" value="female" required class="accent-mint-500" />女性</label>
					</div>
				</fieldset>

				<div class="space-y-3">
					<label for="edit-lesson" class="block text-sm font-bold text-navy-900">経験した習い事</label>
					<select id="edit-lesson" name="lesson_slug" required class="w-full rounded-xl border border-gray-300 bg-white px-4 py-3 text-sm">
						{NARAIBASE_LESSONS.map((lesson) => <option value={lesson.slug}>{lesson.name}</option>)}
					</select>
				</div>

				<fieldset class="space-y-3">
					<legend class="text-sm font-bold text-navy-900">大人になった今、役に立ったと思いますか？</legend>
					<div class="flex gap-5">
						<label class="flex items-center gap-2 text-sm"><input type="radio" name="is_useful" value="true" required class="accent-mint-500" />はい</label>
						<label class="flex items-center gap-2 text-sm"><input type="radio" name="is_useful" value="false" required class="accent-mint-500" />いいえ</label>
					</div>
				</fieldset>

				<fieldset class="space-y-3">
					<legend class="text-sm font-bold text-navy-900">自分の子どもにも勧めたいと思いますか？</legend>
					<div class="flex gap-5">
						<label class="flex items-center gap-2 text-sm"><input type="radio" name="is_recommended" value="true" required class="accent-mint-500" />はい</label>
						<label class="flex items-center gap-2 text-sm"><input type="radio" name="is_recommended" value="false" required class="accent-mint-500" />いいえ</label>
					</div>
				</fieldset>

				<div class="space-y-3">
					<label for="edit-useful-reason" class="block text-sm font-bold text-navy-900">役に立った／立たなかった理由（任意）</label>
					<textarea id="edit-useful-reason" name="useful_reason" maxlength="500" rows="4" class="w-full rounded-xl border border-gray-300 px-4 py-3 text-sm"></textarea>
				</div>
				<div class="space-y-3">
					<label for="edit-recommended-reason" class="block text-sm font-bold text-navy-900">勧めたい／勧めたくない理由（任意）</label>
					<textarea id="edit-recommended-reason" name="recommended_reason" maxlength="500" rows="4" class="w-full rounded-xl border border-gray-300 px-4 py-3 text-sm"></textarea>
				</div>

				<p id="edit-submit-error" class="text-xs font-bold text-red-600" role="alert"></p>
				<div class="flex flex-col gap-3 border-t border-gray-100 pt-6 sm:flex-row">
					<button data-update type="submit" class="rounded-full bg-mint-500 px-7 py-3 text-sm font-bold text-white disabled:opacity-50">変更を保存する</button>
					<button data-delete type="button" class="rounded-full border border-red-300 px-7 py-3 text-sm font-bold text-red-700 disabled:opacity-50">この回答を削除する</button>
				</div>
			</form>
		</div>
	</section>

	<script>
		import { naraibaseClient } from "../../../lib/naraibaseClient";
		import type { NaraibaseEditable } from "../../../lib/naraibaseClient";

		const fragment = new URLSearchParams(location.hash.slice(1));
		const responseId = Number(fragment.get('id'));
		const editToken = fragment.get('token') ?? '';
		const form = document.getElementById('edit-form') as HTMLFormElement;
		const loading = document.getElementById('edit-loading')!;
		const loadError = document.getElementById('edit-error')!;
		const submitError = document.getElementById('edit-submit-error')!;
		const complete = document.getElementById('edit-complete')!;
		const completeTitle = document.getElementById('edit-complete-title')!;

		function showError(message: string) {
			loading.classList.add('hidden');
			loadError.textContent = message;
			loadError.classList.remove('hidden');
		}

		function setRadio(name: string, value: string) {
			const input = form.querySelector<HTMLInputElement>(`input[name="${name}"][value="${value}"]`);
			if (input) input.checked = true;
		}

		function formValue(): NaraibaseEditable {
			const data = new FormData(form);
			return {
				gender: String(data.get('gender')) as 'male' | 'female',
				lesson_slug: String(data.get('lesson_slug')),
				is_useful: data.get('is_useful') === 'true',
				is_recommended: data.get('is_recommended') === 'true',
				useful_reason: String(data.get('useful_reason') ?? '').trim(),
				recommended_reason: String(data.get('recommended_reason') ?? '').trim(),
			};
		}

		async function initialize() {
			if (!Number.isSafeInteger(responseId) || responseId <= 0 || editToken.length < 32) {
				showError('編集URLが正しくありません。回答後に表示されたURLをそのまま開いてください。');
				return;
			}
			try {
				const result = await naraibaseClient.getEditable(responseId, editToken);
				const response = result.response;
				setRadio('gender', response.gender);
				(form.elements.namedItem('lesson_slug') as HTMLSelectElement).value = response.lesson_slug;
				setRadio('is_useful', String(response.is_useful));
				setRadio('is_recommended', String(response.is_recommended));
				(form.elements.namedItem('useful_reason') as HTMLTextAreaElement).value = response.useful_reason ?? '';
				(form.elements.namedItem('recommended_reason') as HTMLTextAreaElement).value = response.recommended_reason ?? '';
				loading.classList.add('hidden');
				form.classList.remove('hidden');
			} catch (error) {
				showError(error instanceof Error ? error.message : '回答を読み込めませんでした。');
			}
		}

		function finish(message: string) {
			form.classList.add('hidden');
			loadError.classList.add('hidden');
			completeTitle.textContent = message;
			complete.classList.remove('hidden');
		}

		form.addEventListener('submit', async (event) => {
			event.preventDefault();
			submitError.textContent = '';
			const button = form.querySelector<HTMLButtonElement>('[data-update]')!;
			button.disabled = true;
			try {
				await naraibaseClient.update(responseId, editToken, formValue());
				finish('回答を更新しました');
			} catch (error) {
				submitError.textContent = error instanceof Error ? error.message : '更新できませんでした。';
				button.disabled = false;
			}
		});

		form.querySelector<HTMLButtonElement>('[data-delete]')!.addEventListener('click', async () => {
			if (!confirm('この回答を削除します。削除後は元に戻せません。よろしいですか？')) return;
			submitError.textContent = '';
			const button = form.querySelector<HTMLButtonElement>('[data-delete]')!;
			button.disabled = true;
			try {
				await naraibaseClient.delete(responseId, editToken);
				finish('回答を削除しました');
			} catch (error) {
				submitError.textContent = error instanceof Error ? error.message : '削除できませんでした。';
				button.disabled = false;
			}
		});

		initialize();
	</script>
</Layout>
