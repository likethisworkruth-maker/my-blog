---
import Layout from '../layouts/Layout.astro';
import { SITE_TITLE } from '../consts';
import { UI } from '../i18n/ja';
---

<Layout title={`${UI.error.notFoundTitle} | ${SITE_TITLE}`} description={UI.error.notFoundDesc}>
	<div class="px-6 py-16 lg:py-32 flex flex-col items-center justify-center text-center min-h-[60vh]">
		<div class="w-24 h-24 bg-gray-50 rounded-full flex items-center justify-center mb-6 border border-gray-100 text-gray-400">
			<span class="material-symbols-outlined text-[3rem]" aria-hidden="true">search_off</span>
		</div>
		<h1 class="text-[2rem] lg:text-[3rem] font-bold text-navy-900 mb-4">{UI.error.notFoundCode}</h1>
		<h2 class="text-[1.25rem] font-bold text-gray-700 mb-4">{UI.error.notFoundTitle}</h2>
		<p class="text-gray-500 mb-8 max-w-md leading-relaxed" set:html={UI.error.notFoundDesc}></p>
		<a href="/" class="bg-mint-500 hover:bg-mint-600 text-white font-bold py-3 px-8 rounded-full transition-colors flex items-center gap-2 inline-flex">
			<span class="material-symbols-outlined text-[1.1rem]" aria-hidden="true">home</span> {UI.error.btnHome}
		</a>
	</div>
</Layout>
