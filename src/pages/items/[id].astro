---
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import ActionBar from "../../components/ActionBar.astro";
import { SITE_TITLE } from "../../consts";
import { UI } from "../../i18n/ja";

export async function getStaticPaths() {
	const items = await getCollection("items");
	return items.map((item) => ({
		params: { id: item.id },
		props: { item },
	}));
}

const { item } = Astro.props;
const { Content } = await render(item);
---

<Layout
	title={`${item.data.title} | ${SITE_TITLE}`}
	description={item.data.description}
	image={item.data.coverImage}
>
	<!-- Top Image Area (Full width on mobile, rounded on PC) -->
	<div class="w-full max-w-5xl mx-auto lg:mt-8 lg:px-6">
		<div class="w-full aspect-video lg:rounded-2xl bg-mint-50 flex items-center justify-center overflow-hidden border-b lg:border border-gray-200">
			{item.data.coverImage ? (
				<img src={item.data.coverImage} alt={item.data.title} class="w-full h-full object-cover" />
			) : (
				<span class="material-symbols-outlined text-mint-200 text-5xl" aria-hidden="true">image</span>
			)}
		</div>
	</div>

	<div class="px-6 py-6 lg:py-8 max-w-5xl mx-auto">
		
		<div class="bg-white rounded-2xl border-none lg:border lg:border-gray-200 shadow-none lg:p-10 mb-8">
			<!-- Header inside card -->
			<div class="pb-8 border-b border-gray-100 mb-8">
				<div class="flex items-center gap-2 text-gray-400 font-bold text-[0.85rem] mb-3">
					{item.data.categories && item.data.categories.join(', ')}
					{item.data.childAgeMonths !== undefined && (item.data.categories ? ` • 生後${item.data.childAgeMonths}ヶ月` : `生後${item.data.childAgeMonths}ヶ月`)}
				</div>
				<h1 class="text-[1.5rem] lg:text-[2rem] font-bold leading-tight mb-2 text-navy-900">{item.data.title}</h1>
				<p class="text-gray-600 text-[0.95rem] lg:text-[1.1rem] leading-relaxed mt-4 mb-6">
					{item.data.description}
				</p>
				
				<div class="flex flex-col sm:flex-row gap-4 w-full sm:w-auto">
					{item.data.actionUrl ? (
						<a
							href={item.data.actionUrl}
							target="_blank"
							rel="noopener noreferrer"
							class="bg-mint-500 hover:bg-mint-600 text-white font-bold py-3 px-8 rounded-full transition-colors flex items-center justify-center gap-2 w-full sm:w-auto"
						>
							{item.data.actionText || UI.items.btnTry}
						</a>
					) : (
						<button
							class="bg-mint-500 hover:bg-mint-600 text-white font-bold py-3 px-8 rounded-full transition-colors flex items-center justify-center gap-2 w-full sm:w-auto"
						>
							{item.data.actionText || UI.items.btnTry}
						</button>
					)}
					<a
						href="/logs"
						class="bg-white border border-mint-500 hover:bg-mint-50 text-mint-500 font-bold py-3 px-8 rounded-full transition-colors flex items-center justify-center gap-2"
					>
						{UI.items.btnReadLog}
					</a>
				</div>
			</div>
			
			<!-- Content Area -->
			<div class="content-area">
				<Content />
			</div>

			<!-- Action Bar (Bottom of Content) -->
			<ActionBar slug={`items/${item.id}`} />

		</div>
	</div>
</Layout>

<style>
	/* Standard Markdown Content Styles */
	.content-area {
		display: flex;
		flex-direction: column;
	}
	
	.content-area :global(> h3) {
		font-size: 1.25rem;
		font-weight: 700;
		color: var(--color-mint-500);
		margin: 2.5rem 0 1rem;
		padding-bottom: 0.5rem;
		border-bottom: 2px solid var(--color-mint-50);
	}

	.content-area :global(> p), .content-area :global(> ul) {
		margin-bottom: 1.5rem;
		line-height: 1.8;
		color: var(--color-gray-700);
	}

	.content-area :global(blockquote) {
		border-left: 4px solid var(--color-mint-200);
		background-color: var(--color-mint-50);
		padding: 1rem 1.5rem;
		margin: 1.5rem 0;
		border-radius: 0 8px 8px 0;
		color: var(--color-gray-700);
	}
</style>
