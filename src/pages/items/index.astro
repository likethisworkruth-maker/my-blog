---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../../consts";
import { UI } from "../../i18n/ja";

const items = await getCollection("items");
items.sort((a, b) => a.data.order - b.data.order);
---

<Layout title={`${UI.items.pageTitle} | ${SITE_TITLE}`} description={SITE_DESCRIPTION}>
	<div class="px-6 py-8 lg:py-12 max-w-4xl mx-auto">
		<h1 class="text-[1.5rem] lg:text-[2rem] font-bold text-navy-900 mb-2">
			{UI.items.pageTitle}
		</h1>
		<p class="text-sm text-gray-500 mb-8">{UI.items.pageDesc}</p>

		{items.length === 0 ? (
			<div class="bg-gray-50 rounded-2xl border border-gray-200 p-8 text-center">
				<span class="material-symbols-outlined text-gray-300 text-5xl mb-4" aria-hidden="true">shopping_bag</span>
				<p class="text-sm text-gray-500 font-medium">現在、わが家で使ったアイテムの記録を準備しています。</p>
			</div>
		) : (
			<div class="grid gap-6 md:grid-cols-2">
				{items.map((item) => (
					<a href={`/items/${item.id}/`} class="flex items-center gap-4 bg-white p-6 rounded-2xl hover:shadow-md transition-shadow border border-gray-200 group">
						<div class="w-16 h-16 sm:w-20 sm:h-20 rounded-2xl bg-mint-50 text-mint-600 flex items-center justify-center shrink-0 border border-mint-100 group-hover:scale-105 transition-transform">
							<span class="material-symbols-outlined text-3xl sm:text-4xl" aria-hidden="true">{item.data.icon}</span>
						</div>
						
						<div class="flex-grow min-w-0">
							<div class="flex items-center gap-2 mb-1">
								{item.data.childAgeMonths !== undefined && (
									<span class="text-xs text-gray-400">生後{item.data.childAgeMonths}ヶ月〜</span>
								)}
							</div>
							<h2 class="text-base sm:text-lg font-bold text-navy-900 truncate group-hover:text-mint-600 transition-colors">
								{item.data.title}
							</h2>
							<p class="text-xs sm:text-sm text-gray-600 mt-1 line-clamp-2 leading-relaxed">
								{item.data.description}
							</p>
						</div>
					</a>
				))}
			</div>
		)}
	</div>
</Layout>
