---
import Layout from '../../layouts/Layout.astro';
import MethodCard from '../../components/methods/MethodCard.astro';
import { methodTypeLabels } from '../../data/trialCatalog';
import { loadInitialTrialCatalog } from '../../data/trialRepository';
const { methods: trialMethods } = await loadInitialTrialCatalog();
---
<Layout title="試した方法 | 育児の困りごとメモ" description="家庭内の工夫、アプリ、商品を、わが家で試した結果から紹介します。">
  <section class="px-6 py-12 lg:py-20">
    <div class="mx-auto max-w-4xl">
      <h1 class="text-3xl font-bold text-navy-900">試した方法</h1>
      
      {((['household_rule', 'app', 'item'] as const).filter(type => trialMethods.some(m => m.methodType === type))).map(type => (
        <section class="mt-10">
          <h2 class="text-xl font-bold text-navy-900">{methodTypeLabels[type]}</h2>
          <div class="mt-4 grid gap-4 md:grid-cols-2">
            {trialMethods.filter(m => m.methodType === type).map(method => (
              <MethodCard method={method} />
            ))}
          </div>
        </section>
      ))}
    </div>
  </section>
</Layout>
