---
import Layout from '../../layouts/Layout.astro';
import ResultSummary from '../../components/results/ResultSummary.astro';
import { methodTypeLabels } from '../../data/trialCatalog';
import { loadInitialTrialCatalog } from '../../data/trialRepository';
export async function getStaticPaths() { const catalog = await loadInitialTrialCatalog(); return catalog.methods.map(method => ({ params: { slug: method.slug }, props: { method, initialProblem: catalog.problem } })); }
const { method, initialProblem } = Astro.props;
---
<Layout title={`${method.name}を試した結果 | 育児の困りごとメモ`} description={method.description}>
  <section class="px-6 py-10 lg:py-16"><article class="mx-auto max-w-3xl"><a href="/methods/" class="text-sm font-bold text-gray-500">← 試した方法一覧</a><header class="mt-6 rounded-3xl border border-gray-200 bg-white p-7 lg:p-10"><p class="text-sm font-bold text-mint-600">{methodTypeLabels[method.methodType]}</p><div class="mt-3 flex items-start gap-4"><span class="material-symbols-outlined flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-mint-50 text-3xl text-mint-600">{method.icon}</span><div><h1 class="text-2xl font-bold text-navy-900 lg:text-3xl">{method.name}</h1><p class="mt-3 leading-8 text-gray-600">{method.description}</p></div></div>{method.pricingNote && <p class="mt-5 rounded-xl bg-gray-50 p-4 text-sm text-gray-600">料金：{method.pricingNote} 最新情報は公式サイトで確認してください。</p>}{method.officialUrl && <a href={method.officialUrl} target="_blank" rel="noopener noreferrer" class="mt-5 inline-flex items-center gap-1 text-sm font-bold text-mint-600">公式サイトを確認 <span aria-hidden="true">↗</span></a>}</header><div class="mt-7"><ResultSummary methodSlug={method.slug} /></div><section class="mt-8 rounded-2xl bg-mint-50 p-6"><h2 class="font-bold text-navy-900">この方法を試しましたか？</h2><p class="mt-2 text-sm leading-6 text-gray-600">「{initialProblem.title}」について、3問で結果を残せます。</p><a href={`/answer/${initialProblem.slug}/`} class="mt-4 inline-block rounded-full bg-mint-500 px-6 py-3 text-sm font-bold text-white">回答する</a></section></article></section>
</Layout>
