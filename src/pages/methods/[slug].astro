---
import Layout from '../../layouts/Layout.astro';
import ResultSummary from '../../components/results/ResultSummary.astro';
import { methodTypeLabels } from '../../data/trialCatalog';
import { loadInitialTrialCatalog } from '../../data/trialRepository';

export async function getStaticPaths() {
  const catalog = await loadInitialTrialCatalog();
  return catalog.methods.map(method => ({
    params: { slug: method.slug },
    props: { method, initialProblem: catalog.problem }
  }));
}

const { method } = Astro.props;
---

<Layout 
  title={`${method.name}で予定を共有する | 育児の困りごとメモ`} 
  description={method.description}
  noindex={true}
>
  <section class="px-6 py-10 lg:py-16">
    <article class="mx-auto max-w-3xl">
      <a href="/methods/" class="text-sm font-bold text-gray-500 hover:text-mint-600 transition-colors flex items-center gap-1">
        <span class="material-symbols-outlined text-sm" aria-hidden="true">arrow_back</span> 試した方法一覧へ戻る
      </a>
      
      <!-- Method Main Header Card -->
      <header class="mt-6 rounded-3xl border border-gray-200 bg-white p-6 lg:p-10">
        <p class="text-xs font-bold text-mint-600 uppercase tracking-wider">{methodTypeLabels[method.methodType]}</p>
        <div class="mt-4 flex items-start gap-4">
          <span class="material-symbols-outlined flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-mint-50 text-3xl text-mint-600" aria-hidden="true">
            {method.icon}
          </span>
          <div>
            <h1 class="text-2xl font-bold text-navy-900 lg:text-3xl">{method.name}で予定を共有する</h1>
            <p class="mt-3 leading-relaxed text-gray-600 text-sm sm:text-base">{method.description}</p>
          </div>
        </div>
        
        {method.pricingNote && (
          <p class="mt-6 rounded-xl bg-gray-50 p-4 text-xs sm:text-sm text-gray-600">
            料金：{method.pricingNote} 最新情報は公式サイト等でご確認ください。
          </p>
        )}
        
        {method.officialUrl && (
          <div class="mt-4">
            <a href={method.officialUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 text-xs sm:text-sm font-bold text-mint-600 hover:underline">
              公式サイトを確認 <span class="material-symbols-outlined text-xs" aria-hidden="true">open_in_new</span>
            </a>
          </div>
        )}
      </header>
      
      <!-- Operator Experience Details -->
      {method.operatorExperience && (
        <section class="mt-8 rounded-3xl border border-gray-200 bg-white p-6 lg:p-10">
          <h2 class="text-lg font-bold text-navy-900 mb-6 flex items-center gap-2 border-b border-gray-100 pb-3">
            <span class="material-symbols-outlined text-mint-500" aria-hidden="true">visibility</span>
            わが家での使い方・体験談
          </h2>
          
          <!-- Details / Usage -->
          {method.operatorExperience.details && (
            <div class="mb-6">
              <h3 class="text-sm font-bold text-gray-800 mb-2">具体的な使い方</h3>
              <p class="text-sm leading-relaxed text-gray-600 whitespace-pre-wrap">{method.operatorExperience.details}</p>
            </div>
          )}

          <!-- Good Points -->
          {method.operatorExperience.goodPoints && method.operatorExperience.goodPoints.length > 0 && (
            <div class="mb-6">
              <h3 class="text-sm font-bold text-mint-600 mb-2 flex items-center gap-1">
                <span class="material-symbols-outlined text-sm" aria-hidden="true">check_circle</span> 良かった点
              </h3>
              <ul class="list-disc pl-5 text-sm text-gray-600 space-y-1.5">
                {method.operatorExperience.goodPoints.map(point => <li>{point}</li>)}
              </ul>
            </div>
          )}

          <!-- Bad/Difficult Points -->
          {method.operatorExperience.badPoints && method.operatorExperience.badPoints.length > 0 && (
            <div class="mb-6">
              <h3 class="text-sm font-bold text-orange-600 mb-2 flex items-center gap-1">
                <span class="material-symbols-outlined text-sm" aria-hidden="true">warning</span> 面倒だった点
              </h3>
              <ul class="list-disc pl-5 text-sm text-gray-600 space-y-1.5">
                {method.operatorExperience.badPoints.map(point => <li>{point}</li>)}
              </ul>
            </div>
          )}

          <!-- Usage Period and Still Using status -->
          {method.operatorExperience.status === 'tried' && (
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mt-6 pt-6 border-t border-gray-100 text-xs sm:text-sm">
              {method.operatorExperience.period && (
                <div>
                  <span class="font-bold text-gray-500 block mb-1">使用期間</span>
                  <span class="text-gray-700 font-medium">{method.operatorExperience.period}</span>
                </div>
              )}
              {method.operatorExperience.stillUsing && (
                <div>
                  <span class="font-bold text-gray-500 block mb-1">今も続けているか</span>
                  <span class="text-gray-700 font-medium">{method.operatorExperience.stillUsing}</span>
                </div>
              )}
            </div>
          )}

          <!-- Related Logs -->
          {method.operatorExperience.relatedLogs && method.operatorExperience.relatedLogs.length > 0 && (
            <div class="mt-6 pt-6 border-t border-gray-100">
              <h3 class="text-xs font-bold text-gray-500 mb-3">関連する読みもの</h3>
              <ul class="space-y-2">
                {method.operatorExperience.relatedLogs.map(log => (
                  <li>
                    <a href={log.url} class="text-sm font-bold text-navy-900 hover:text-mint-600 transition-colors underline decoration-mint-200 underline-offset-4 flex items-center gap-1">
                      <span class="material-symbols-outlined text-sm" aria-hidden="true">menu_book</span> {log.title}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </section>
      )}

      <!-- Results Summary (Hidden client-side if 0 entries exist) -->
      <div class="mt-8">
        <ResultSummary methodSlug={method.slug} />
      </div>
    </article>
  </section>
</Layout>
