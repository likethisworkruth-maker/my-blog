---
import Layout from '../../layouts/Layout.astro';
import ResultSummary from '../../components/results/ResultSummary.astro';
import { methodTypeLabels } from '../../data/trialCatalog';
import { loadInitialTrialCatalog } from '../../data/trialRepository';
export async function getStaticPaths() { const catalog = await loadInitialTrialCatalog(); return catalog.methods.map(method => ({ params: { slug: method.slug }, props: { method, initialProblem: catalog.problem } })); }
const { method, initialProblem } = Astro.props;
---
<Layout title={`${method.name}を試した結果 | 育児の困りごとメモ`} description={method.description}>
  <section class="px-6 py-10 lg:py-16"><article class="mx-auto max-w-3xl"><a href="/methods/" class="text-sm font-bold text-gray-500">← 試した方法一覧</a><header class="mt-6 rounded-3xl border border-gray-200 bg-white p-7 lg:p-10"><p class="text-sm font-bold text-mint-600">{methodTypeLabels[method.methodType]}</p><div class="mt-3 flex items-start gap-4"><span class="material-symbols-outlined flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-mint-50 text-3xl text-mint-600" aria-hidden="true">{method.icon}</span><div><h1 class="text-2xl font-bold text-navy-900 lg:text-3xl">{method.name}</h1><p class="mt-3 leading-8 text-gray-600">{method.description}</p></div></div>{method.pricingNote && <p class="mt-5 rounded-xl bg-gray-50 p-4 text-sm text-gray-600">料金：{method.pricingNote} 最新情報は公式サイトで確認してください。</p>}{method.officialUrl && <a href={method.officialUrl} target="_blank" rel="noopener noreferrer" class="mt-5 inline-flex items-center gap-1 text-sm font-bold text-mint-600">公式サイトを確認 <span aria-hidden="true">↗</span></a>}</header>
  
  {method.operatorExperience && (
    <section class="mt-8 rounded-2xl border border-mint-200 bg-white p-6 lg:p-8">
      <h2 class="text-lg font-bold text-navy-900 mb-4 flex items-center gap-2">
        <span class="material-symbols-outlined text-mint-500" aria-hidden="true">edit_note</span>
        運営者の記録：{method.operatorExperience.status === 'tried' ? '試してみました' : '現在検討中の候補です'}
      </h2>
      
      {method.operatorExperience.period && (
        <p class="text-sm text-gray-600 mb-4"><span class="font-bold">使用期間：</span>{method.operatorExperience.period}</p>
      )}
      
      {method.operatorExperience.details && (
        <p class="text-sm leading-7 text-gray-700 mb-4">{method.operatorExperience.details}</p>
      )}

      {method.operatorExperience.goodPoints && method.operatorExperience.goodPoints.length > 0 && (
        <div class="mb-4">
          <p class="text-sm font-bold text-mint-600 mb-2 flex items-center gap-1"><span class="material-symbols-outlined text-sm" aria-hidden="true">thumb_up</span>良かった点</p>
          <ul class="list-disc pl-5 text-sm text-gray-700 space-y-1">
            {method.operatorExperience.goodPoints.map(point => <li>{point}</li>)}
          </ul>
        </div>
      )}

      {method.operatorExperience.badPoints && method.operatorExperience.badPoints.length > 0 && (
        <div class="mb-4">
          <p class="text-sm font-bold text-orange-500 mb-2 flex items-center gap-1"><span class="material-symbols-outlined text-sm" aria-hidden="true">thumb_down</span>続かなかった・微妙だった点</p>
          <ul class="list-disc pl-5 text-sm text-gray-700 space-y-1">
            {method.operatorExperience.badPoints.map(point => <li>{point}</li>)}
          </ul>
        </div>
      )}

      {method.operatorExperience.relatedLogs && method.operatorExperience.relatedLogs.length > 0 && (
        <div class="mt-4 pt-4 border-t border-gray-100">
          <p class="text-xs font-bold text-gray-500 mb-2">関連記事</p>
          <ul class="space-y-2">
            {method.operatorExperience.relatedLogs.map(log => (
              <li><a href={log.url} class="text-sm font-bold text-navy-900 hover:text-mint-600 transition-colors underline decoration-mint-200 underline-offset-4">{log.title}</a></li>
            ))}
          </ul>
        </div>
      )}
    </section>
  )}

  <div class="mt-7"><ResultSummary methodSlug={method.slug} /></div><section class="mt-8 rounded-2xl bg-gray-50 p-6 border border-gray-100"><h2 class="font-bold text-navy-900">この方法を試しましたか？</h2><p class="mt-2 text-sm leading-6 text-gray-600">将来、「{initialProblem.title}」について、3問で結果を残せるようになる予定です。（現在は内部テスト中です）</p><a href={`/answer/${initialProblem.slug}/`} class="mt-4 inline-block rounded-full bg-gray-200 px-6 py-3 text-sm font-bold text-gray-600 hover:bg-gray-300">回答機能は準備中です</a></section></article></section>
</Layout>
